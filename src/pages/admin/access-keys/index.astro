---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import { getAccessKeys } from "../../../lib/queries/admin-permissions";

const deleted = Astro.url.searchParams.get("deleted") === "1";
const keys = await getAccessKeys();
---

<AdminLayout title="Access Keys">

  {deleted && (
    <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">Access key deleted.</div>
  )}

  <div class="flex items-center justify-between mb-4">
    <span class="text-sm text-gray-500">{keys.length} key{keys.length !== 1 ? "s" : ""}</span>
    <a href="/admin/access-keys/new"
       class="bg-blue-600 text-white px-4 py-1.5 rounded text-sm hover:bg-blue-700">
      + Add Access Key
    </a>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="px-4 py-2.5 text-left font-medium text-gray-600">ID</th>
          <th class="px-4 py-2.5 text-left font-medium text-gray-600">Name</th>
          <th class="px-4 py-2.5 text-left font-medium text-gray-600">Type</th>
          <th class="px-4 py-2.5"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {keys.length === 0 && (
          <tr><td colspan="4" class="px-4 py-8 text-center text-gray-400">No access keys found.</td></tr>
        )}
        {keys.map((k) => (
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-2.5 text-xs font-mono text-gray-400">{k.accesskey_ID}</td>
            <td class="px-4 py-2.5 font-medium text-gray-800">{k.Name}</td>
            <td class="px-4 py-2.5">
              {k.System
                ? <span class="text-xs bg-amber-100 text-amber-700 px-1.5 py-0.5 rounded">System</span>
                : <span class="text-xs bg-blue-100 text-blue-700 px-1.5 py-0.5 rounded">User</span>}
            </td>
            <td class="px-4 py-2.5">
              {!k.System && (
                <a href={`/admin/access-keys/${k.accesskey_ID}`}
                   class="text-xs text-blue-500 hover:underline">Edit</a>
              )}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

</AdminLayout>
