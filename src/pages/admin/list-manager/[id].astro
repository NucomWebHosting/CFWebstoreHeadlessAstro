---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import {
  getList, updateList, deleteList,
  normalizePriority, displayPriority,
} from "../../../lib/queries/admin-list-manager";

const id = parseInt(Astro.params.id ?? "0") || 0;
if (!id) return new Response(null, { status: 404 });

let error = "";

if (Astro.request.method === "POST") {
  const d = await Astro.request.formData();
  const g = (k: string) => (d.get(k) as string ?? "").trim();
  const action = g("_action");

  if (action === "delete") {
    await deleteList(id);
    return Astro.redirect("/admin/list-manager?deleted=1");
  } else {
    try {
      await updateList(id, {
        name:       g("name"),
        text:       g("text"),
        list_style: parseInt(g("list_style")) || 2,
        priority:   normalizePriority(g("priority")),
      });
      return Astro.redirect(`/admin/list-manager/${id}?saved=1`);
    } catch (e: unknown) {
      error = e instanceof Error ? e.message : String(e);
    }
  }
}

const saved = Astro.url.searchParams.get("saved") === "1";
const rec = await getList(id);
if (!rec) return new Response(`List ${id} not found.`, { status: 404, headers: { "content-type": "text/plain" } });
---

<AdminLayout title={`List ${id}`}>
  <div class="flex items-center gap-3 mb-5">
    <a href="/admin/list-manager" class="text-sm text-blue-600 hover:underline">← Back to Lists</a>
  </div>

  {saved && (
    <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">Saved.</div>
  )}
  {error && (
    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
  )}

  <form method="post" class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-4 max-w-2xl">
    <input type="hidden" name="_action" value="update" />

    <div class="flex items-center justify-between border-b border-gray-100 pb-2">
      <h2 class="text-sm font-semibold text-gray-700">List #{id}</h2>
      <a href={`/admin/list-manager/${id}/questions`}
         class="text-xs text-blue-500 hover:underline">View Questions →</a>
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Name <span class="text-red-500">*</span></label>
      <input type="text" name="name" value={rec.name} required maxlength="100"
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-start">
      <label class="text-sm text-gray-600 font-medium text-right pt-1">Description</label>
      <div class="col-span-2">
        <input type="text" name="text" value={rec.text ?? ""} maxlength="100"
               class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
        <p class="text-xs text-gray-400 mt-0.5">For your reference only — not displayed to users.</p>
      </div>
    </div>

    <div class="grid grid-cols-3 gap-3 items-start">
      <span class="text-sm text-gray-600 font-medium text-right pt-1">Layout Style <span class="text-red-500">*</span></span>
      <div class="col-span-2 space-y-1.5">
        {[
          { value: "2", label: "Text Only" },
          { value: "0", label: "Minimal Accordion" },
          { value: "1", label: "Boxed Accordion" },
          { value: "4", label: "Masonry Boxes" },
        ].map(({ value, label }) => (
          <label class="flex items-center gap-2 text-sm">
            <input type="radio" name="list_style" value={value} required
                   checked={rec.list_style === parseInt(value)} />
            {label}
          </label>
        ))}
      </div>
    </div>

    <div class="pt-2">
      <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded text-sm hover:bg-blue-700">
        Update List
      </button>
    </div>
  </form>

  <!-- Delete -->
  <div class="mt-5 max-w-2xl">
    <form method="post"
          onsubmit={`return confirm('Delete List ${id} and all its questions?')`}>
      <input type="hidden" name="_action" value="delete" />
      <button type="submit" class="px-4 py-2 rounded text-sm border border-red-300 text-red-600 hover:bg-red-50">
        Delete List
      </button>
    </form>
  </div>

</AdminLayout>
