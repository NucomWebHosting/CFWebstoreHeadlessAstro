---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import {
  getShipSettings, getShipRates, saveShipRate, deleteShipRate,
} from "../../../lib/queries/admin-shipping";

const CUSTOM_TYPES = ["Price", "Price2", "Weight", "Weight2", "Items"];
const PCT_TYPES    = ["Price2", "Weight2"];

if (Astro.request.method === "POST") {
  const d = await Astro.request.formData();
  const g  = (k: string) => (d.get(k) as string) ?? "";
  const action  = g("_action");
  const tableId = parseInt(g("Table_Id")) || 1;

  if (action === "delete") {
    await deleteShipRate(parseInt(g("ID")));
  } else {
    const id  = parseInt(g("ID")) || 0;
    const isPct = (await getShipSettings())?.ShipType;
    const rawAmt = parseFloat(g("Amount")) || 0;
    const amount = isPct && PCT_TYPES.includes(isPct ?? "") ? rawAmt / 100 : rawAmt;
    await saveShipRate(id, tableId, {
      MinOrder: parseFloat(g("MinOrder")) || 0,
      MaxOrder: parseFloat(g("MaxOrder")) || 0,
      Amount:   amount,
    });
  }
  return Astro.redirect("/admin/shipping/rates?saved=1");
}

const [s, rates1, rates2] = await Promise.all([
  getShipSettings(),
  getShipRates(1),
  getShipRates(2),
]);

const isPct    = s ? PCT_TYPES.includes(s.ShipType) : false;
const isItems  = s?.ShipType === "Items";
const saved    = Astro.url.searchParams.get("saved") === "1";
const editId1  = parseInt(Astro.url.searchParams.get("edit1") ?? "0") || 0;
const editId2  = parseInt(Astro.url.searchParams.get("edit2") ?? "0") || 0;

const unitLabel = isItems ? "Items" : isPct ? "$ (order total)" : "$ (order total)";
const amtLabel  = isPct ? "%" : "$";

function displayAmt(amt: number) {
  return isPct ? parseFloat((amt * 100).toPrecision(10)).toString() : amt.toFixed(2);
}
---

<AdminLayout title="Shipping — Rates">

  <div class="mb-5">
    <a href="/admin/shipping" class="text-sm text-blue-600 hover:underline">← Shipping Types</a>
  </div>

  <nav class="flex flex-wrap gap-1 mb-6 text-sm border-b border-gray-200 pb-0">
    {[
      ["/admin/shipping",                  "← Types"],
      ["/admin/shipping/rates",            "Rates"],
      ["/admin/shipping/country-rates",    "Country Rates"],
      ["/admin/shipping/methods",          "Methods"],
      ["/admin/shipping/custom-settings",  "Custom Settings"],
      ["/admin/shipping/promotions",       "Promotions"],
    ].map(([href, label]) => {
      const active = Astro.url.pathname === href;
      return (
        <a href={href}
           class={`px-4 py-2 font-medium border-b-2 -mb-px transition-colors ${
             active ? "border-blue-600 text-blue-600" : "border-transparent text-gray-500 hover:text-gray-700"
           }`}>{label}</a>
      );
    })}
  </nav>

  {saved && (
    <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">Saved.</div>
  )}

  {!CUSTOM_TYPES.includes(s?.ShipType ?? "") && (
    <div class="bg-yellow-50 border border-yellow-200 rounded-lg px-4 py-3 text-sm text-yellow-700">
      Shipping type is <strong>{s?.ShipType}</strong>. Custom rate tables are only used with Price, Weight, or Items shipping types.
    </div>
  )}

  {CUSTOM_TYPES.includes(s?.ShipType ?? "") && (
    <div class="space-y-8">

      {/* ── Table 1: Regular ── */}
      {[{tableId: 1, label: "Shipping Rates", rates: rates1, editId: editId1, editParam: "edit1"},
        {tableId: 2, label: "Shipping Rates — Alaska & Hawaii", rates: rates2, editId: editId2, editParam: "edit2"}
      ].map(({ tableId, label, rates, editId, editParam }) => {
        const editing = rates.find(r => r.ID === editId);
        return (
          <section class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
            <h2 class="text-sm font-semibold text-gray-700 mb-4">{label}</h2>

            {/* Add / Edit form */}
            <form method="post" class="space-y-3 mb-6 pb-5 border-b border-gray-100">
              <input type="hidden" name="ID"       value={String(editing?.ID ?? 0)} />
              <input type="hidden" name="Table_Id" value={String(tableId)} />

              <div class="grid grid-cols-3 gap-3 items-center max-w-lg">
                <label class="text-sm text-gray-600 font-medium text-right">
                  {isItems ? "Min Items" : "Min Order"}
                </label>
                <div class="col-span-2 flex items-center gap-2">
                  <input type="number" name="MinOrder" step="any" min="0"
                         value={editing ? editing.MinOrder.toFixed(2) : "0.00"}
                         class="w-28 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
                  <span class="text-sm text-gray-400">{unitLabel}</span>
                </div>
              </div>

              <div class="grid grid-cols-3 gap-3 items-center max-w-lg">
                <label class="text-sm text-gray-600 font-medium text-right">
                  {isItems ? "Max Items" : "Max Order"}
                </label>
                <div class="col-span-2 flex items-center gap-2">
                  <input type="number" name="MaxOrder" step="any" min="0"
                         value={editing ? editing.MaxOrder.toFixed(2) : "0.00"}
                         class="w-28 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
                  <span class="text-sm text-gray-400">{unitLabel}</span>
                </div>
              </div>

              <div class="grid grid-cols-3 gap-3 items-center max-w-lg">
                <label class="text-sm text-gray-600 font-medium text-right">
                  {isPct ? "Shipping %" : "Shipping Amount"}
                </label>
                <div class="col-span-2 flex items-center gap-2">
                  <input type="number" name="Amount" step="any" min="0"
                         value={editing ? displayAmt(editing.Amount) : "0"}
                         class="w-28 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
                  <span class="text-sm text-gray-400">{amtLabel}</span>
                </div>
              </div>

              <div class="flex gap-2">
                <button type="submit" class="bg-blue-600 text-white px-4 py-1.5 rounded text-sm hover:bg-blue-700">
                  {editing ? "Update Rate" : "Add Rate"}
                </button>
                {editing && (
                  <a href="/admin/shipping/rates" class="px-4 py-1.5 rounded text-sm border border-gray-300 text-gray-600 hover:bg-gray-50">Cancel</a>
                )}
              </div>
            </form>

            {/* Rates table */}
            {rates.length === 0 ? (
              <p class="text-sm text-gray-400 text-center py-3">No rates entered.</p>
            ) : (
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-gray-100 text-left">
                    <th class="py-2 pr-4 text-gray-500 font-medium">
                      {isItems ? "Items" : "Order Total"}
                    </th>
                    <th class="py-2 pr-4 text-gray-500 font-medium">
                      {isPct ? "Percentage" : "Amount"}
                    </th>
                    <th class="py-2 text-gray-500 font-medium">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  {rates.map(r => (
                    <tr class="border-b border-gray-50 hover:bg-gray-50">
                      <td class="py-2 pr-4">
                        {isPct
                          ? `$${r.MinOrder.toFixed(2)} – $${r.MaxOrder.toFixed(2)}`
                          : isItems
                          ? `${r.MinOrder} – ${r.MaxOrder}`
                          : `$${r.MinOrder.toFixed(2)} – $${r.MaxOrder.toFixed(2)}`}
                      </td>
                      <td class="py-2 pr-4">
                        {isPct ? `${displayAmt(r.Amount)}%` : `$${r.Amount.toFixed(2)}`}
                      </td>
                      <td class="py-2 flex gap-2">
                        <a href={`/admin/shipping/rates?${editParam}=${r.ID}`}
                           class="text-blue-600 hover:underline text-xs">Edit</a>
                        <form method="post" class="inline">
                          <input type="hidden" name="_action"  value="delete" />
                          <input type="hidden" name="ID"       value={String(r.ID)} />
                          <input type="hidden" name="Table_Id" value={String(tableId)} />
                          <button type="submit" onclick="return confirm('Delete this rate?')"
                                  class="text-red-500 hover:underline text-xs">Delete</button>
                        </form>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            )}
          </section>
        );
      })}
    </div>
  )}
</AdminLayout>
