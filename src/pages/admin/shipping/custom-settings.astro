---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import { getCustomShipSettings, saveCustomShipSettings, getShipSettings } from "../../../lib/queries/admin-shipping";

if (Astro.request.method === "POST") {
  const d = await Astro.request.formData();
  const gb = (k: string) => (d.get(k) as string) === "1";
  await saveCustomShipSettings({
    ShowShipTable:     gb("ShowShipTable"),
    MultPerItem:       gb("MultPerItem"),
    CumulativeAmounts: gb("CumulativeAmounts"),
    MultMethods:       gb("MultMethods"),
    Debug:             gb("Debug"),
  });
  return Astro.redirect("/admin/shipping/custom-settings?saved=1");
}

const [cs, s] = await Promise.all([getCustomShipSettings(), getShipSettings()]);
const isItems = s?.ShipType === "Items";
const saved   = Astro.url.searchParams.get("saved") === "1";
---

<AdminLayout title="Shipping — Custom Settings">

  <nav class="flex flex-wrap gap-1 mb-6 text-sm border-b border-gray-200 pb-0">
    {[
      ["/admin/shipping",                  "Settings"],
      ["/admin/shipping/rates",            "Rates"],
      ["/admin/shipping/country-rates",    "Country Rates"],
      ["/admin/shipping/methods",          "Methods"],
      ["/admin/shipping/custom-settings",  "Custom Settings"],
      ["/admin/shipping/promotions",       "Promotions"],
    ].map(([href, label]) => {
      const active = Astro.url.pathname === href;
      return (
        <a href={href}
           class={`px-4 py-2 font-medium border-b-2 -mb-px transition-colors ${
             active ? "border-blue-600 text-blue-600" : "border-transparent text-gray-500 hover:text-gray-700"
           }`}>{label}</a>
      );
    })}
  </nav>

  {saved && (
    <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">Saved.</div>
  )}

  {cs && (
    <form method="post" class="space-y-4 max-w-2xl">
      <section class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 space-y-4">
        <h2 class="text-sm font-semibold text-gray-700 border-b border-gray-100 pb-2">Custom Shipping Settings</h2>

        <div class="grid grid-cols-3 gap-3 items-start">
          <span class="text-sm text-gray-600 font-medium text-right pt-1">Show Shipping Table</span>
          <div class="col-span-2 space-y-1 pt-1">
            <div class="flex gap-4">
              <label class="flex items-center gap-2 text-sm"><input type="radio" name="ShowShipTable" value="1" checked={cs.ShowShipTable} /> Yes</label>
              <label class="flex items-center gap-2 text-sm"><input type="radio" name="ShowShipTable" value="0" checked={!cs.ShowShipTable} /> No</label>
            </div>
            <p class="text-xs text-gray-400">Displays the rate table on the shopping basket page.</p>
          </div>
        </div>

        {isItems && (
          <>
            <div class="grid grid-cols-3 gap-3 items-start">
              <span class="text-sm text-gray-600 font-medium text-right pt-1">Calculate Per Item</span>
              <div class="col-span-2 space-y-1 pt-1">
                <div class="flex gap-4">
                  <label class="flex items-center gap-2 text-sm"><input type="radio" name="MultPerItem" value="1" checked={cs.MultPerItem} /> Yes</label>
                  <label class="flex items-center gap-2 text-sm"><input type="radio" name="MultPerItem" value="0" checked={!cs.MultPerItem} /> No</label>
                </div>
                <p class="text-xs text-gray-400">Multiply the shipping table amount by item count.</p>
              </div>
            </div>

            <div class="grid grid-cols-3 gap-3 items-start">
              <span class="text-sm text-gray-600 font-medium text-right pt-1">Cumulative Amounts</span>
              <div class="col-span-2 space-y-1 pt-1">
                <div class="flex gap-4">
                  <label class="flex items-center gap-2 text-sm"><input type="radio" name="CumulativeAmounts" value="1" checked={cs.CumulativeAmounts} /> Yes</label>
                  <label class="flex items-center gap-2 text-sm"><input type="radio" name="CumulativeAmounts" value="0" checked={!cs.CumulativeAmounts} /> No</label>
                </div>
                <p class="text-xs text-gray-400">Each range in the table is applied in sequence until the order amount is reached.</p>
              </div>
            </div>
          </>
        )}

        {!isItems && (
          <>
            <input type="hidden" name="MultPerItem" value="1" />
            <input type="hidden" name="CumulativeAmounts" value="0" />
          </>
        )}

        <div class="grid grid-cols-3 gap-3 items-start">
          <span class="text-sm text-gray-600 font-medium text-right pt-1">Methods Multiply Shipping</span>
          <div class="col-span-2 space-y-1 pt-1">
            <div class="flex gap-4">
              <label class="flex items-center gap-2 text-sm"><input type="radio" name="MultMethods" value="1" checked={cs.MultMethods} /> Yes</label>
              <label class="flex items-center gap-2 text-sm"><input type="radio" name="MultMethods" value="0" checked={!cs.MultMethods} /> No</label>
            </div>
            <p class="text-xs text-gray-400">If yes, method amounts multiply the shipping total. If no, they are added.</p>
          </div>
        </div>

        <div class="grid grid-cols-3 gap-3 items-start">
          <span class="text-sm text-gray-600 font-medium text-right pt-1">Debug Mode</span>
          <div class="col-span-2 flex gap-4 pt-1">
            <label class="flex items-center gap-2 text-sm"><input type="radio" name="Debug" value="1" checked={cs.Debug} /> On</label>
            <label class="flex items-center gap-2 text-sm"><input type="radio" name="Debug" value="0" checked={!cs.Debug} /> Off</label>
          </div>
        </div>
      </section>

      <div class="flex gap-3">
        <button type="submit" class="bg-blue-600 text-white px-5 py-2 rounded text-sm hover:bg-blue-700">Save Changes</button>
      </div>
    </form>
  )}
</AdminLayout>
