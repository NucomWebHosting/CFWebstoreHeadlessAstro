---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import {
  getShipSettings, saveFreeShipping, saveFlatRate,
  getShipMethods, getStates,
} from "../../../lib/queries/admin-shipping";

if (Astro.request.method === "POST") {
  const d = await Astro.request.formData();
  const g  = (k: string) => (d.get(k) as string) ?? "";

  if (g("_action") === "free") {
    const selectedIds = (d.getAll("freeship_shipids") as string[]).join(",");
    const selectedStates = (d.getAll("freeshipStates") as string[]).join(",");
    await saveFreeShipping({
      Freeship_Min:      parseFloat(g("freeship_min")) || 0,
      Freeship_ShipIDs:  selectedIds,
      FreeShipAmtFlag:   d.has("FreeShipAmtFlag"),
      FreeShipStateFlag: d.has("FreeShipStateFlag"),
      FreeshipStates:    selectedStates,
    });
  } else if (g("_action") === "flatrate") {
    await saveFlatRate({
      Flatrate:          parseFloat(g("Flatrate")) || 0,
      Flatrate_min:      parseFloat(g("Flatrate_min")) || 0,
      Flatrate_domestic: parseInt(g("Flatrate_domestic")) || 1,
    });
  }
  return Astro.redirect("/admin/shipping/promotions?saved=1");
}

const [s, methods, states] = await Promise.all([
  getShipSettings(),
  getShipMethods(),
  getStates(),
]);

const saved         = Astro.url.searchParams.get("saved") === "1";
const activeIds     = new Set((s?.Freeship_ShipIDs ?? "").split(",").filter(Boolean));
const activeStates  = new Set((s?.FreeshipStates ?? "").split(",").filter(Boolean));
const usedMethods   = methods.filter(m => m.Used);
---

<AdminLayout title="Shipping — Promotions">

  <nav class="flex flex-wrap gap-1 mb-6 text-sm border-b border-gray-200 pb-0">
    {[
      ["/admin/shipping",                  "Settings"],
      ["/admin/shipping/rates",            "Rates"],
      ["/admin/shipping/country-rates",    "Country Rates"],
      ["/admin/shipping/methods",          "Methods"],
      ["/admin/shipping/custom-settings",  "Custom Settings"],
      ["/admin/shipping/promotions",       "Promotions"],
    ].map(([href, label]) => {
      const active = Astro.url.pathname === href;
      return (
        <a href={href}
           class={`px-4 py-2 font-medium border-b-2 -mb-px transition-colors ${
             active ? "border-blue-600 text-blue-600" : "border-transparent text-gray-500 hover:text-gray-700"
           }`}>{label}</a>
      );
    })}
  </nav>

  {saved && (
    <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">Saved.</div>
  )}

  {s && (
    <div class="space-y-8 max-w-3xl">

      {/* ── Free Shipping ── */}
      <section class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 space-y-5">
        <h2 class="text-sm font-semibold text-gray-700 border-b border-gray-100 pb-2">Free Shipping Promotion</h2>

        <form method="post" class="space-y-4">
          <input type="hidden" name="_action" value="free" />

          {/* Which methods are free */}
          <div class="grid grid-cols-3 gap-3 items-start">
            <span class="text-sm text-gray-600 font-medium text-right pt-1">Free Methods</span>
            <div class="col-span-2 space-y-1 pt-1">
              {usedMethods.length === 0 ? (
                <p class="text-sm text-gray-400">No active shipping methods. Add methods first.</p>
              ) : usedMethods.map(m => (
                <label class="flex items-center gap-2 text-sm">
                  <input type="checkbox" name="freeship_shipids" value={String(m.ID)}
                         checked={activeIds.has(String(m.ID))} />
                  {m.Name}
                </label>
              ))}
            </div>
          </div>

          {/* Criteria */}
          <div class="border border-gray-100 rounded-lg overflow-hidden">
            <div class="bg-gray-50 px-4 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wide grid grid-cols-[1fr_80px_1fr]">
              <span>Criteria</span>
              <span class="text-center">Apply</span>
              <span>Settings</span>
            </div>

            {/* Basket total */}
            <div class="px-4 py-3 border-t border-gray-100 grid grid-cols-[1fr_80px_1fr] items-center gap-3">
              <span class="text-sm text-gray-600">Basket Total Over</span>
              <div class="flex justify-center">
                <input type="checkbox" name="FreeShipAmtFlag" value="1" checked={s.FreeShipAmtFlag} />
              </div>
              <div class="flex items-center gap-2">
                <span class="text-sm text-gray-400">$</span>
                <input type="number" name="freeship_min" step="any" min="0"
                       value={s.Freeship_Min > 0 ? s.Freeship_Min.toFixed(2) : "0.00"}
                       class="w-28 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
              </div>
            </div>

            {/* States */}
            <div class="px-4 py-3 border-t border-gray-100 grid grid-cols-[1fr_80px_1fr] items-start gap-3">
              <span class="text-sm text-gray-600 pt-1">Select States</span>
              <div class="flex justify-center pt-1">
                <input type="checkbox" name="FreeShipStateFlag" value="1" checked={s.FreeShipStateFlag} />
              </div>
              <select name="freeshipStates" multiple size={10}
                      class="border border-gray-300 rounded px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">
                {states.map(st => (
                  <option value={st.Abb} selected={activeStates.has(st.Abb)}>{st.Name}</option>
                ))}
              </select>
            </div>
          </div>

          <button type="submit" class="bg-blue-600 text-white px-5 py-2 rounded text-sm hover:bg-blue-700">
            Save Free Shipping
          </button>
        </form>
      </section>

      {/* ── Flat Rate ── */}
      <section class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 space-y-4">
        <h2 class="text-sm font-semibold text-gray-700 border-b border-gray-100 pb-2">Flat Rate Promotion</h2>

        <form method="post" class="space-y-4">
          <input type="hidden" name="_action" value="flatrate" />

          <div class="grid grid-cols-3 gap-3 items-center">
            <label class="text-sm text-gray-600 font-medium text-right">Cart Minimum</label>
            <div class="col-span-2 flex items-center gap-2">
              <span class="text-sm text-gray-400">$</span>
              <input type="number" name="Flatrate_min" step="any" min="0"
                     value={s.Flatrate_min.toFixed(2)}
                     class="w-28 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
            </div>
          </div>

          <div class="grid grid-cols-3 gap-3 items-center">
            <label class="text-sm text-gray-600 font-medium text-right">Flat Rate Amount</label>
            <div class="col-span-2 flex items-center gap-2">
              <span class="text-sm text-gray-400">$</span>
              <input type="number" name="Flatrate" step="any" min="0"
                     value={s.Flatrate.toFixed(2)}
                     class="w-28 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
            </div>
          </div>

          <div class="grid grid-cols-3 gap-3 items-start">
            <span class="text-sm text-gray-600 font-medium text-right pt-1">Apply To</span>
            <div class="col-span-2 flex gap-4 pt-1">
              <label class="flex items-center gap-2 text-sm"><input type="radio" name="Flatrate_domestic" value="1" checked={s.Flatrate_domestic === 1} /> Domestic</label>
              <label class="flex items-center gap-2 text-sm"><input type="radio" name="Flatrate_domestic" value="0" checked={s.Flatrate_domestic === 0} /> International</label>
            </div>
          </div>

          <button type="submit" class="bg-blue-600 text-white px-5 py-2 rounded text-sm hover:bg-blue-700">
            Save Flat Rate
          </button>
        </form>
      </section>
    </div>
  )}
</AdminLayout>
