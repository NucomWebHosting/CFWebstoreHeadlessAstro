---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import {
  getCountryRates, getAllCountriesForShipping,
  saveCountryRate, deleteCountryRate, setAllCountryRates,
} from "../../../lib/queries/admin-shipping";

if (Astro.request.method === "POST") {
  const d = await Astro.request.formData();
  const g = (k: string) => (d.get(k) as string) ?? "";

  if (g("_action") === "delete") {
    await deleteCountryRate(parseInt(g("ID")));
  } else if (g("_action") === "set-all") {
    const pct = (parseFloat(g("AllRate")) || 0) / 100;
    await setAllCountryRates(pct);
  } else {
    const id     = parseInt(g("ID")) || 0;
    const abbrev = g("Abbrev");
    const pct    = (parseFloat(g("AddShipAmount")) || 0) / 100;
    await saveCountryRate(id, abbrev, pct);
  }
  return Astro.redirect("/admin/shipping/country-rates?saved=1");
}

const [rates, allCountries] = await Promise.all([
  getCountryRates(),
  getAllCountriesForShipping(),
]);

const saved   = Astro.url.searchParams.get("saved") === "1";
const editId  = parseInt(Astro.url.searchParams.get("edit") ?? "0") || 0;
const editing = rates.find(r => r.ID === editId);

const activeAbbrevs = new Set(rates.map(r => r.Abbrev));
const availableCountries = allCountries.filter(c => !activeAbbrevs.has(c.Abbrev));
---

<AdminLayout title="Shipping — Country Rates">

  <nav class="flex flex-wrap gap-1 mb-6 text-sm border-b border-gray-200 pb-0">
    {[
      ["/admin/shipping",                  "Settings"],
      ["/admin/shipping/rates",            "Rates"],
      ["/admin/shipping/country-rates",    "Country Rates"],
      ["/admin/shipping/methods",          "Methods"],
      ["/admin/shipping/custom-settings",  "Custom Settings"],
      ["/admin/shipping/promotions",       "Promotions"],
    ].map(([href, label]) => {
      const active = Astro.url.pathname === href;
      return (
        <a href={href}
           class={`px-4 py-2 font-medium border-b-2 -mb-px transition-colors ${
             active ? "border-blue-600 text-blue-600" : "border-transparent text-gray-500 hover:text-gray-700"
           }`}>{label}</a>
      );
    })}
  </nav>

  {saved && (
    <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">Saved.</div>
  )}

  <div class="space-y-6 max-w-3xl">

    {/* Add / Edit country rate */}
    <section class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 space-y-4">
      <h2 class="text-sm font-semibold text-gray-700 border-b border-gray-100 pb-2">
        {editing ? `Edit Rate — ${editing.Name}` : "Add Country Rate"}
      </h2>

      <form method="post" class="space-y-3">
        <input type="hidden" name="ID" value={String(editing?.ID ?? 0)} />
        {editing && <input type="hidden" name="Abbrev" value={editing.Abbrev} />}

        {!editing && availableCountries.length > 0 && (
          <div class="grid grid-cols-3 gap-3 items-center">
            <label class="text-sm text-gray-600 font-medium text-right">Country</label>
            <select name="Abbrev"
                    class="col-span-2 w-auto border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">
              {availableCountries.map(c => (
                <option value={c.Abbrev}>{c.Name}</option>
              ))}
            </select>
          </div>
        )}

        {!editing && availableCountries.length === 0 && (
          <p class="text-sm text-gray-500">All countries already have rates. Edit or delete existing entries.</p>
        )}

        <div class="grid grid-cols-3 gap-3 items-center">
          <label class="text-sm text-gray-600 font-medium text-right">Percent Added</label>
          <div class="col-span-2 flex items-center gap-2">
            <input type="number" name="AddShipAmount" step="any" min="0"
                   value={editing ? parseFloat((editing.AddShipAmount * 100).toPrecision(10)).toString() : "0"}
                   class="w-28 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
            <span class="text-sm text-gray-400">%</span>
          </div>
        </div>

        <div class="flex gap-2">
          <button type="submit" class="bg-blue-600 text-white px-4 py-1.5 rounded text-sm hover:bg-blue-700">
            {editing ? "Update" : "Add Rate"}
          </button>
          {editing && (
            <a href="/admin/shipping/country-rates" class="px-4 py-1.5 rounded text-sm border border-gray-300 text-gray-600 hover:bg-gray-50">Cancel</a>
          )}
        </div>
      </form>
    </section>

    {/* Set all countries */}
    <section class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
      <h2 class="text-sm font-semibold text-gray-700 border-b border-gray-100 pb-2 mb-4">Set All Countries</h2>
      <form method="post" class="flex items-center gap-3"
            onsubmit="return confirm('This will set ALL countries to this rate and enable custom shipping for all. Continue?')">
        <input type="hidden" name="_action" value="set-all" />
        <label class="text-sm text-gray-600">Set all countries to:</label>
        <input type="number" name="AllRate" step="any" min="0" value="0"
               class="w-24 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
        <span class="text-sm text-gray-400">%</span>
        <button type="submit" class="bg-amber-500 text-white px-4 py-1.5 rounded text-sm hover:bg-amber-600">Apply to All</button>
      </form>
    </section>

    {/* Current country rates table */}
    <section class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
      <h2 class="text-sm font-semibold text-gray-700 border-b border-gray-100 pb-2 mb-4">
        Active Country Rates ({rates.length})
      </h2>
      {rates.length === 0 ? (
        <p class="text-sm text-gray-400 text-center py-3">No country rates set.</p>
      ) : (
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-100 text-left">
              <th class="py-2 pr-4 text-gray-500 font-medium">Country</th>
              <th class="py-2 pr-4 text-gray-500 font-medium text-center">% Added</th>
              <th class="py-2 text-gray-500 font-medium">Actions</th>
            </tr>
          </thead>
          <tbody>
            {rates.map(r => (
              <tr class="border-b border-gray-50 hover:bg-gray-50">
                <td class="py-2 pr-4">{r.Name}</td>
                <td class="py-2 pr-4 text-center">
                  {parseFloat((r.AddShipAmount * 100).toPrecision(10)).toString()}%
                </td>
                <td class="py-2 flex gap-2">
                  <a href={`/admin/shipping/country-rates?edit=${r.ID}`}
                     class="text-blue-600 hover:underline text-xs">Edit</a>
                  <form method="post" class="inline">
                    <input type="hidden" name="_action" value="delete" />
                    <input type="hidden" name="ID" value={String(r.ID)} />
                    <button type="submit" onclick="return confirm('Remove this country rate?')"
                            class="text-red-500 hover:underline text-xs">Delete</button>
                  </form>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </section>
  </div>
</AdminLayout>
