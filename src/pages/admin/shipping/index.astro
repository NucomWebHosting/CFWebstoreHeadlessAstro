---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import { getAllShipSettings, createShipSettings, deleteShipSettings } from "../../../lib/queries/admin-shipping";

const SHIP_TYPES: [string, string][] = [
  ["Price",    "Amount Added by Total Price"],
  ["Weight",   "Amount Added by Total Weight"],
  ["Items",    "Amount Added per Item"],
  ["Price2",   "Percentage Added by Total Price"],
  ["Weight2",  "Percentage Added by Total Weight"],
  ["UPS",      "Automated UPS Shipping Rates"],
  ["USPS",     "Automated USPS Shipping Rates"],
  ["FedEx",    "Automated FedEx Shipping Rates"],
  ["Easypost", "Automated Easypost Shipping Rates"],
];

const CUSTOM_TYPES = new Set(["Price", "Price2", "Weight", "Weight2", "Items"]);

let error = "";

if (Astro.request.method === "POST") {
  const d = await Astro.request.formData();
  const action = (d.get("_action") as string) ?? "";

  if (action === "add") {
    const shipType = (d.get("ShipType") as string)?.trim();
    if (!shipType) {
      error = "Please select a shipping type.";
    } else {
      const existing = await getAllShipSettings();
      const alreadyUsed = existing.some(r => r.ShipType === shipType);
      const isCustom = CUSTOM_TYPES.has(shipType);
      const customUsed = isCustom && existing.some(r => CUSTOM_TYPES.has(r.ShipType));
      if (alreadyUsed) {
        error = "That shipping type is already in use. Each type can only be added once.";
      } else if (customUsed) {
        error = "You can only have one custom shipping type (Price, Weight, or Items).";
      } else {
        const newId = await createShipSettings(shipType);
        return Astro.redirect(`/admin/shipping/${newId}`);
      }
    }
  } else if (action === "delete") {
    const id = parseInt(d.get("id") as string) || 0;
    if (id > 0) await deleteShipSettings(id);
    return Astro.redirect("/admin/shipping?deleted=1");
  }
}

const rows = await getAllShipSettings();
const deleted = Astro.url.searchParams.get("deleted") === "1";

function shipTypeLabel(val: string) {
  return SHIP_TYPES.find(([v]) => v === val)?.[1] ?? val;
}
---

<AdminLayout title="Shipping">

  {deleted && (
    <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">Shipping type deleted.</div>
  )}
  {error && (
    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
  )}

  <div class="max-w-3xl space-y-6">

    <!-- Existing shipping types -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
        <h2 class="font-semibold text-gray-800">Shipping Types</h2>
      </div>

      {rows.length === 0 ? (
        <p class="px-5 py-8 text-sm text-gray-400 text-center">No shipping types configured yet.</p>
      ) : (
        <table class="w-full text-sm">
          <thead class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
            <tr>
              <th class="px-5 py-3 text-left">Shipping Type</th>
              <th class="px-5 py-3 text-center">Base Rate</th>
              <th class="px-5 py-3 text-center">Handling</th>
              <th class="px-5 py-3 text-center">Pickup</th>
              <th class="px-5 py-3 text-center">Estimator</th>
              <th class="px-5 py-3 text-center">Drop-Ship</th>
              <th class="px-5 py-3 text-right">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {rows.map(r => (
              <tr class="hover:bg-gray-50">
                <td class="px-5 py-3 font-medium text-gray-800">
                  {shipTypeLabel(r.ShipType)}
                </td>
                <td class="px-5 py-3 text-center text-gray-600">
                  ${r.ShipBase.toFixed(2)}
                </td>
                <td class="px-5 py-3 text-center text-gray-600">
                  {(r.ShipHand * 100).toFixed(1)}%
                </td>
                <td class="px-5 py-3 text-center">
                  {r.InStorePickup
                    ? <span class="text-xs text-green-600 font-semibold">Yes</span>
                    : <span class="text-xs text-gray-300">No</span>}
                </td>
                <td class="px-5 py-3 text-center">
                  {r.ShowEstimator
                    ? <span class="text-xs text-green-600 font-semibold">Yes</span>
                    : <span class="text-xs text-gray-300">No</span>}
                </td>
                <td class="px-5 py-3 text-center">
                  {r.UseDropShippers
                    ? <span class="text-xs text-green-600 font-semibold">Yes</span>
                    : <span class="text-xs text-gray-300">No</span>}
                </td>
                <td class="px-5 py-3 text-right">
                  <div class="flex items-center justify-end gap-2">
                    <a href={`/admin/shipping/${r.ID}`}
                       class="px-3 py-1 text-xs rounded bg-blue-600 text-white hover:bg-blue-700">
                      Edit
                    </a>
                    <form method="post" onsubmit="return confirm('Delete this shipping type?')">
                      <input type="hidden" name="_action" value="delete" />
                      <input type="hidden" name="id" value={r.ID} />
                      <button type="submit"
                              class="px-3 py-1 text-xs rounded border border-red-200 text-red-600 hover:bg-red-50">
                        Delete
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>

    <!-- Add new shipping type -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
      <h2 class="font-semibold text-gray-800 mb-4">Add Shipping Type</h2>
      <form method="post" class="flex items-end gap-3 flex-wrap">
        <input type="hidden" name="_action" value="add" />
        <div>
          <label class="block text-xs text-gray-500 mb-1">Shipping Type</label>
          <select name="ShipType"
                  class="border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">
            <option value="">— Select —</option>
            {SHIP_TYPES.map(([val, label]) => (
              <option value={val}>{label}</option>
            ))}
          </select>
        </div>
        <button type="submit"
                class="bg-green-600 text-white px-4 py-1.5 rounded text-sm hover:bg-green-700">
          Add
        </button>
      </form>
    </div>

    <!-- Links to shared settings -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
      <h2 class="font-semibold text-gray-800 mb-3">Shared Settings</h2>
      <div class="flex flex-wrap gap-2 text-sm">
        {[
          ["/admin/shipping/rates",           "Rate Tables"],
          ["/admin/shipping/country-rates",   "Country Rates"],
          ["/admin/shipping/methods",         "Shipping Methods"],
          ["/admin/shipping/custom-settings", "Custom Settings"],
          ["/admin/shipping/promotions",      "Promotions"],
        ].map(([href, label]) => (
          <a href={href}
             class="px-4 py-2 rounded border border-gray-200 text-gray-600 hover:bg-gray-50 hover:border-gray-300">
            {label} →
          </a>
        ))}
      </div>
    </div>

  </div>
</AdminLayout>
