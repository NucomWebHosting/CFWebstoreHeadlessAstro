---
export const prerender = false;
import AdminLayout from "../../../../components/layout/AdminLayout.astro";
import { getEasypostMethods, getEasypostMethod, saveEasypostMethod, deleteEasypostMethod } from "../../../../lib/queries/admin-shipping-easypost";
import { getAllShipSettings } from "../../../../lib/queries/admin-shipping";

// Find the Easypost ShipSettings ID for back-link
const allSettings = await getAllShipSettings();
const easypostId  = allSettings.find(r => r.ShipType === "Easypost")?.ID ?? 0;

let saved = false;
let error = "";

if (Astro.request.method === "POST") {
  const d      = await Astro.request.formData();
  const action = (d.get("_action") as string) ?? "";

  try {
    if (action === "delete") {
      const id = parseInt(d.get("id") as string) || 0;
      if (id > 0) await deleteEasypostMethod(id);
    } else if (action === "bulk") {
      // bulk update Used + Priority for all methods
      const ids = (d.getAll("method_id") as string[]).map(Number);
      await Promise.all(ids.map(async mid => {
        const used     = (d.get(`used_${mid}`) as string) === "1";
        const priority = parseInt(d.get(`priority_${mid}`) as string) || 99;
        const m        = await getEasypostMethod(mid);
        if (m) {
          await saveEasypostMethod(mid, { ...m, Used: used, Priority: priority });
        }
      }));
    }
  } catch (e: unknown) {
    error = e instanceof Error ? e.message : String(e);
  }

  if (!error) return Astro.redirect("/admin/shipping/easypost/methods?saved=1");
}

saved = Astro.url.searchParams.get("saved") === "1";
const methods = await getEasypostMethods();

const tabs = [
  [easypostId ? `/admin/shipping/${easypostId}` : "/admin/shipping", "Settings"],
  ["/admin/shipping/easypost/methods",  "Methods"],
  ["/admin/shipping/easypost/boxes",    "Boxes"],
  ["/admin/shipping/promotions",        "Promotions"],
] as const;
---

<AdminLayout title="Easypost — Methods">

  <div class="mb-5">
    <a href="/admin/shipping" class="text-sm text-blue-600 hover:underline">← Shipping Types</a>
  </div>

  <nav class="flex flex-wrap gap-1 mb-6 text-sm border-b border-gray-200 pb-0">
    {tabs.map(([href, label]) => {
      const active = Astro.url.pathname === href;
      return (
        <a href={href}
           class={`px-4 py-2 font-medium border-b-2 -mb-px transition-colors ${
             active ? "border-blue-600 text-blue-600" : "border-transparent text-gray-500 hover:text-gray-700"
           }`}>
          {label}
        </a>
      );
    })}
  </nav>

  {saved && (
    <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">Saved.</div>
  )}
  {error && (
    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
  )}

  <div class="max-w-4xl space-y-6">

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
        <h2 class="font-semibold text-gray-800">Carrier Methods</h2>
        <a href="/admin/shipping/easypost/methods/new"
           class="px-3 py-1.5 text-xs rounded bg-green-600 text-white hover:bg-green-700">
          + Add Method
        </a>
      </div>
      <p class="px-5 pt-3 text-xs text-gray-400">
        Method Name is internal and must match the carrier's method code exactly. Friendly Name is shown to customers.
        Handling % and Extra Weight are added on top of the Easypost-calculated rate.
      </p>

      {methods.length === 0 ? (
        <p class="px-5 py-8 text-sm text-gray-400 text-center">No methods configured yet.</p>
      ) : (
        <form method="post">
          <input type="hidden" name="_action" value="bulk" />
          <table class="w-full text-sm">
            <thead class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
              <tr>
                <th class="px-5 py-3 text-left">Method Name</th>
                <th class="px-5 py-3 text-left">Friendly Name</th>
                <th class="px-5 py-3 text-center">Handling %</th>
                <th class="px-5 py-3 text-center">Extra Wt (oz)</th>
                <th class="px-5 py-3 text-center">Priority</th>
                <th class="px-5 py-3 text-center">Used</th>
                <th class="px-5 py-3 text-right">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {methods.map(m => (
                <tr class="hover:bg-gray-50">
                  <input type="hidden" name="method_id" value={m.ID} />
                  <td class="px-5 py-3 font-mono text-xs text-gray-700">{m.Name}</td>
                  <td class="px-5 py-3 text-gray-700">{m.Friendly_Name}</td>
                  <td class="px-5 py-3 text-center text-gray-600">{(m.MethodHand * 100).toFixed(1)}%</td>
                  <td class="px-5 py-3 text-center text-gray-600">{m.MethodWeight}</td>
                  <td class="px-5 py-3 text-center">
                    <input type="number" name={`priority_${m.ID}`} value={m.Priority} min="1" max="999"
                           class="w-16 border border-gray-300 rounded px-2 py-1 text-xs text-center focus:outline-none focus:ring-1 focus:ring-blue-400" />
                  </td>
                  <td class="px-5 py-3 text-center">
                    <input type="hidden" name={`used_${m.ID}`} value="0" />
                    <input type="checkbox" name={`used_${m.ID}`} value="1" checked={m.Used}
                           class="w-4 h-4 rounded border-gray-300 text-blue-600" />
                  </td>
                  <td class="px-5 py-3 text-right">
                    <div class="flex items-center justify-end gap-2">
                      <a href={`/admin/shipping/easypost/methods/${m.ID}`}
                         class="px-3 py-1 text-xs rounded bg-blue-600 text-white hover:bg-blue-700">
                        Edit
                      </a>
                      <form method="post" onsubmit="return confirm('Delete this method?')">
                        <input type="hidden" name="_action" value="delete" />
                        <input type="hidden" name="id" value={m.ID} />
                        <button type="submit"
                                class="px-3 py-1 text-xs rounded border border-red-200 text-red-600 hover:bg-red-50">
                          Delete
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
          <div class="px-5 py-4 border-t border-gray-100">
            <button type="submit" class="bg-blue-600 text-white px-4 py-1.5 rounded text-sm hover:bg-blue-700">
              Save Used &amp; Priority
            </button>
          </div>
        </form>
      )}
    </div>

  </div>
</AdminLayout>
