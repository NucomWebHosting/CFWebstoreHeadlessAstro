---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import {
  getCertificate, getCertTransactions,
  updateCertificate, adjustCertAmount, deleteCertificate
} from "../../../lib/queries/admin-gift-certificates";

const id = parseInt(Astro.params.id ?? "0");
let error = "";
let successMsg = "";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = form.get("action") as string;

  if (action === "delete") {
    try {
      await deleteCertificate(id);
      return Astro.redirect("/admin/gift-certificates");
    } catch (e: unknown) {
      error = e instanceof Error ? e.message : String(e);
    }
  } else if (action === "adjust") {
    const amt = parseFloat(form.get("amount") as string);
    const verb = form.get("verb") as "Add" | "Subtract";
    if (!amt || amt <= 0) {
      error = "Enter a valid amount.";
    } else {
      try {
        await adjustCertAmount(id, {
          amount:  amt,
          action:  verb,
          orderNo: parseInt(form.get("order_no") as string) || null,
          notes:   (form.get("notes") as string ?? "").trim(),
        });
        successMsg = `$${amt.toFixed(2)} ${verb === "Add" ? "added" : "subtracted"} successfully.`;
      } catch (e: unknown) {
        error = e instanceof Error ? e.message : String(e);
      }
    }
  } else {
    try {
      await updateCertificate(id, {
        Cust_Name: (form.get("cust_name")  as string ?? "").trim(),
        Recipient: (form.get("recipient")  as string ?? "").trim(),
        Order_No:  parseInt(form.get("order_no") as string) || null,
        StartDate: (form.get("start_date") as string ?? "").trim(),
        EndDate:   (form.get("end_date")   as string ?? "").trim(),
        Valid:     form.get("valid") === "1" ? 1 : 0,
      });
      successMsg = "Certificate updated.";
    } catch (e: unknown) {
      error = e instanceof Error ? e.message : String(e);
    }
  }
}

const cert = await getCertificate(id);
if (!cert) return Astro.redirect("/admin/gift-certificates");
const transactions = await getCertTransactions(id);

function fmtDate(d: Date | null) {
  if (!d) return "";
  return new Date(d).toISOString().split("T")[0]; // yyyy-mm-dd for input[type=date]
}
function fmtDateDisplay(d: Date | null) {
  if (!d) return "—";
  return new Date(d).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric", hour: "2-digit", minute: "2-digit" });
}

const ACTION_STYLES: Record<string, string> = {
  "Created - Manual":    "bg-green-100 text-green-700",
  "Created - Purchased": "bg-green-100 text-green-700",
  "Created - Bulk":      "bg-green-100 text-green-700",
  "Amount Added":        "bg-blue-100 text-blue-700",
  "Redeemed - Online":   "bg-amber-100 text-amber-700",
  "Redeemed - Offline":  "bg-amber-100 text-amber-700",
};
---

<AdminLayout title={`Certificate: ${cert.Cert_Code}`}>

  <div class="mb-5">
    <a href="/admin/gift-certificates" class="text-sm text-blue-600 hover:underline">← Gift Certificates</a>
  </div>

  {error && (
    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
  )}
  {successMsg && (
    <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">{successMsg}</div>
  )}

  <div class="max-w-2xl space-y-6">

    {/* Summary card */}
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
        <div>
          <p class="text-xs text-gray-400 uppercase tracking-wide mb-0.5">Certificate Code</p>
          <p class="font-mono text-xl font-bold tracking-widest text-gray-800">{cert.Cert_Code}</p>
        </div>
        <div class="text-right">
          <p class="text-xs text-gray-400 uppercase tracking-wide mb-0.5">Current Balance</p>
          <p class="text-2xl font-bold text-green-600">${cert.CertAmount.toFixed(2)}</p>
          <p class="text-xs text-gray-400">of ${cert.InitialAmount.toFixed(2)} initial</p>
        </div>
      </div>
    </div>

    {/* Edit details */}
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100">
        <h2 class="font-semibold text-gray-800">Details</h2>
      </div>
      <form method="post" class="px-5 py-5 space-y-4">
        <input type="hidden" name="action" value="update" />

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs text-gray-500 mb-1">Purchaser</label>
            <input type="text" name="cust_name" value={cert.Cust_Name ?? ""}
                   class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Recipient</label>
            <input type="text" name="recipient" value={cert.Recipient ?? ""}
                   class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs text-gray-500 mb-1">Order No</label>
            <input type="number" name="order_no" value={cert.Order_No ?? ""}
                   class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-2">Valid</label>
            <div class="flex gap-4 text-sm pt-0.5">
              <label class="flex items-center gap-1.5 cursor-pointer">
                <input type="radio" name="valid" value="1" checked={cert.Valid} /> Yes
              </label>
              <label class="flex items-center gap-1.5 cursor-pointer">
                <input type="radio" name="valid" value="0" checked={!cert.Valid} /> No
              </label>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs text-gray-500 mb-1">Start Date</label>
            <input type="date" name="start_date" value={fmtDate(cert.StartDate)}
                   class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">End Date</label>
            <input type="date" name="end_date" value={fmtDate(cert.EndDate)}
                   class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
          </div>
        </div>

        <div class="pt-1">
          <button type="submit"
                  class="bg-blue-600 text-white px-5 py-2 rounded text-sm font-medium hover:bg-blue-700">
            Save Changes
          </button>
        </div>
      </form>
    </div>

    {/* Adjust amount */}
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100">
        <h2 class="font-semibold text-gray-800">Adjust Balance</h2>
        <p class="text-xs text-gray-400 mt-0.5">Current balance: <strong>${cert.CertAmount.toFixed(2)}</strong></p>
      </div>
      <form method="post" class="px-5 py-4 space-y-3">
        <input type="hidden" name="action" value="adjust" />
        <div class="flex flex-wrap gap-3 items-end">
          <div>
            <label class="block text-xs text-gray-500 mb-1">Amount ($)</label>
            <input type="number" name="amount" min="0.01" step="0.01" required placeholder="0.00"
                   class="w-28 border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Order No</label>
            <input type="number" name="order_no" placeholder="optional"
                   class="w-28 border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
          </div>
          <div class="flex-1 min-w-40">
            <label class="block text-xs text-gray-500 mb-1">Notes</label>
            <input type="text" name="notes" placeholder="optional"
                   class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
          </div>
          <div class="flex gap-2">
            <button type="submit" name="verb" value="Add"
                    class="bg-green-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-green-700">
              Add
            </button>
            <button type="submit" name="verb" value="Subtract"
                    class="bg-amber-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-amber-700">
              Subtract
            </button>
          </div>
        </div>
      </form>
    </div>

    {/* Transaction history */}
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100">
        <h2 class="font-semibold text-gray-800">Transaction History</h2>
      </div>
      {transactions.length === 0 ? (
        <p class="px-5 py-8 text-sm text-center text-gray-400">No transactions yet.</p>
      ) : (
        <table class="w-full text-sm">
          <thead class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
            <tr>
              <th class="px-5 py-3 text-left">Date</th>
              <th class="px-5 py-3 text-left">Action</th>
              <th class="px-5 py-3 text-right">Amount</th>
              <th class="px-5 py-3 text-right">Balance After</th>
              <th class="px-5 py-3 text-center">Order</th>
              <th class="px-5 py-3 text-left">Notes</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {transactions.map(t => {
              const isDebit = t.Action.startsWith("Redeemed");
              return (
                <tr class="hover:bg-gray-50">
                  <td class="px-5 py-3 text-xs text-gray-500 whitespace-nowrap">{fmtDateDisplay(t.enterdate)}</td>
                  <td class="px-5 py-3">
                    <span class={`inline-block px-2 py-0.5 rounded-full text-xs font-medium ${ACTION_STYLES[t.Action] ?? "bg-gray-100 text-gray-600"}`}>
                      {t.Action}
                    </span>
                  </td>
                  <td class={`px-5 py-3 text-right font-mono text-xs font-medium ${isDebit ? "text-red-600" : "text-green-600"}`}>
                    {isDebit ? "-" : "+"} ${t.amount.toFixed(2)}
                  </td>
                  <td class="px-5 py-3 text-right font-mono text-xs text-gray-700">${t.CertAmount.toFixed(2)}</td>
                  <td class="px-5 py-3 text-center text-xs text-gray-500">{t.Order_No ?? "—"}</td>
                  <td class="px-5 py-3 text-xs text-gray-500">{t.notes || "—"}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      )}
    </div>

    {/* Danger Zone */}
    <div class="bg-white rounded-xl border border-red-200 shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-red-100">
        <h2 class="font-semibold text-red-700">Danger Zone</h2>
      </div>
      <div class="px-5 py-4">
        <form method="post"
              onsubmit="return confirm('Delete this certificate and all transaction history? This cannot be undone.')">
          <input type="hidden" name="action" value="delete" />
          <button type="submit"
                  class="bg-red-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-red-700">
            Delete Certificate
          </button>
        </form>
      </div>
    </div>

  </div>

</AdminLayout>
