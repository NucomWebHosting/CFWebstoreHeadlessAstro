---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import { createCertificate } from "../../../lib/queries/admin-gift-certificates";

let error = "";
let newCode = "";
let newId = 0;

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const amount = parseFloat(form.get("cert_amount") as string);
  if (!amount || amount <= 0) {
    error = "A valid amount is required.";
  } else {
    try {
      const result = await createCertificate({
        Cust_Name:  (form.get("cust_name")  as string ?? "").trim(),
        Recipient:  (form.get("recipient")  as string ?? "").trim(),
        CertAmount: amount,
        Order_No:   parseInt(form.get("order_no") as string) || null,
        StartDate:  (form.get("start_date") as string ?? "").trim(),
        EndDate:    (form.get("end_date")   as string ?? "").trim(),
        Valid:      form.get("valid") === "1" ? 1 : 0,
      });
      newCode = result.certCode;
      newId   = result.certId;
    } catch (e: unknown) {
      error = e instanceof Error ? e.message : String(e);
    }
  }
}
---

<AdminLayout title="New Gift Certificate">

  <div class="mb-5">
    <a href="/admin/gift-certificates" class="text-sm text-blue-600 hover:underline">← Gift Certificates</a>
  </div>

  {error && (
    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
  )}

  {newCode ? (
    <div class="max-w-lg bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-5 py-8 text-center space-y-3">
        <p class="text-green-600 font-semibold text-lg">Certificate Created!</p>
        <p class="text-xs text-gray-500">Certificate Code</p>
        <p class="font-mono text-2xl font-bold tracking-widest text-gray-800">{newCode}</p>
        <div class="flex justify-center gap-3 pt-4">
          <a href={`/admin/gift-certificates/${newId}`}
             class="bg-blue-600 text-white px-5 py-2 rounded text-sm font-medium hover:bg-blue-700">
            View Certificate
          </a>
          <a href="/admin/gift-certificates"
             class="px-5 py-2 rounded text-sm border border-gray-300 text-gray-600 hover:bg-gray-50">
            Certificate List
          </a>
        </div>
      </div>
    </div>
  ) : (
    <div class="max-w-xl bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100">
        <h2 class="font-semibold text-gray-800">New Gift Certificate</h2>
        <p class="text-xs text-gray-400 mt-0.5">A unique code will be generated automatically.</p>
      </div>
      <form method="post" class="px-5 py-5 space-y-4">

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs text-gray-500 mb-1">Purchaser</label>
            <input type="text" name="cust_name"
                   class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Recipient</label>
            <input type="text" name="recipient"
                   class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs text-gray-500 mb-1">Amount ($) <span class="text-red-500">*</span></label>
            <input type="number" name="cert_amount" min="0.01" step="0.01" required
                   class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Order No <span class="text-gray-400">(optional)</span></label>
            <input type="number" name="order_no" min="0"
                   class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs text-gray-500 mb-1">Start Date</label>
            <input type="date" name="start_date"
                   class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">End Date</label>
            <input type="date" name="end_date"
                   class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
          </div>
        </div>

        <div>
          <label class="block text-xs text-gray-500 mb-2">Valid</label>
          <div class="flex gap-4 text-sm">
            <label class="flex items-center gap-1.5 cursor-pointer">
              <input type="radio" name="valid" value="1" checked /> Yes
            </label>
            <label class="flex items-center gap-1.5 cursor-pointer">
              <input type="radio" name="valid" value="0" /> No
            </label>
          </div>
        </div>

        <div class="pt-2 flex gap-3">
          <button type="submit"
                  class="bg-blue-600 text-white px-5 py-2 rounded text-sm font-medium hover:bg-blue-700">
            Generate Certificate
          </button>
          <a href="/admin/gift-certificates"
             class="px-5 py-2 rounded text-sm border border-gray-300 text-gray-600 hover:bg-gray-50">
            Cancel
          </a>
        </div>

      </form>
    </div>
  )}

</AdminLayout>
