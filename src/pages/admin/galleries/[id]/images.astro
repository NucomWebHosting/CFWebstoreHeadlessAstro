---
export const prerender = false;
import AdminLayout from "../../../../components/layout/AdminLayout.astro";
import {
  getGallery,
  getGalleryImages,
  getGalleryCategories,
  addGalleryImage,
  updateGalleryImage,
  deleteGalleryImage,
} from "../../../../lib/queries/admin-galleries";

const id = parseInt(Astro.params.id ?? "0") || 0;
if (!id) return new Response(null, { status: 404 });

let error = "";

if (Astro.request.method === "POST") {
  const d = await Astro.request.formData();
  const g  = (k: string) => (d.get(k) as string ?? "").trim();
  const n  = (k: string) => parseInt(g(k)) || 0;
  const action = g("_action");

  const imgData = {
    Name:        g("Name"),
    Subtitle:    g("Subtitle"),
    Phone:       g("Phone"),
    Email:       g("Email"),
    LinkedIn:    g("LinkedIn"),
    Lg_Image:    g("Lg_Image"),
    Sm_Image:    g("Sm_Image"),
    Link:        g("Link"),
    Target:      g("Target") === "1" ? 1 : 0,
    Description: g("Description"),
    Priority:    n("Priority") || 9999,
    Category_ID: n("Category_ID"),
    StartDate:   g("StartDate") || null,
    EndDate:     g("EndDate")   || null,
  };

  try {
    if (action === "delete") {
      await deleteGalleryImage(n("Image_ID"));
    } else if (action === "update") {
      await updateGalleryImage(n("Image_ID"), imgData);
    } else if (action === "add") {
      await addGalleryImage(id, imgData);
    }
    return Astro.redirect(`/admin/galleries/${id}/images?saved=1`);
  } catch (e: unknown) {
    error = e instanceof Error ? e.message : String(e);
  }
}

const saved = Astro.url.searchParams.get("saved") === "1";
const [gallery, images, categories] = await Promise.all([
  getGallery(id),
  getGalleryImages(id),
  getGalleryCategories(),
]);
if (!gallery) return new Response(`Gallery ${id} not found.`, { status: 404, headers: { "content-type": "text/plain" } });

const isTeam = gallery.Gallery_Style === 3;

function fmtDate(d: Date | null) {
  if (!d) return "";
  return new Date(d).toISOString().substring(0, 10);
}

const inputCls = "w-full border border-gray-300 rounded px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400";
---

<AdminLayout title={`${gallery.Name} — Images`}>
  <div class="flex items-center gap-2 mb-5 text-sm">
    <a href="/admin/galleries" class="text-blue-600 hover:underline">← Galleries</a>
    <span class="text-gray-300">/</span>
    <a href={`/admin/galleries/${id}`} class="text-blue-600 hover:underline">{gallery.Name}</a>
    <span class="text-gray-300">/</span>
    <span class="text-gray-500">Images</span>
  </div>

  {saved && (
    <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">Saved.</div>
  )}
  {error && (
    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
  )}

  <!-- Existing images -->
  {images.length > 0 && (
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mb-6">
      <div class="bg-gray-50 border-b border-gray-200 px-4 py-2.5 text-sm font-semibold text-gray-700">
        {images.length} Image{images.length !== 1 ? "s" : ""}
      </div>
      <div class="divide-y divide-gray-100">
        {images.map(img => (
          <details class="group">
            <summary class="flex items-center gap-3 px-4 py-3 cursor-pointer hover:bg-gray-50 list-none">
              {img.Sm_Image
                ? <img src={`/images/${img.Sm_Image}`} alt={img.Name ?? ""} class="w-14 h-14 object-cover rounded border border-gray-200 shrink-0" />
                : <div class="w-14 h-14 rounded border border-gray-200 bg-gray-100 shrink-0 flex items-center justify-center text-gray-400 text-xs">no img</div>
              }
              <div class="flex-1 min-w-0">
                <div class="font-medium text-sm text-gray-800 truncate">{img.Name || <span class="text-gray-400 italic">unnamed</span>}</div>
                {img.Category_Name && <div class="text-xs text-gray-400">{img.Category_Name}</div>}
              </div>
              <svg class="w-4 h-4 text-gray-400 shrink-0 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </summary>

            <div class="px-4 pb-4 pt-2 bg-gray-50 border-t border-gray-100">
              <form method="post" class="space-y-3">
                <input type="hidden" name="_action" value="update" />
                <input type="hidden" name="Image_ID" value={img.Image_ID} />

                <div class="grid grid-cols-2 gap-3">
                  <div>
                    <label class="text-xs text-gray-500 mb-1 block">Name</label>
                    <input type="text" name="Name" value={img.Name ?? ""} maxlength="500" class={inputCls} />
                  </div>
                  {isTeam && (
                    <div>
                      <label class="text-xs text-gray-500 mb-1 block">Job Title</label>
                      <input type="text" name="Subtitle" value={img.Subtitle ?? ""} maxlength="500" class={inputCls} />
                    </div>
                  )}
                  {!isTeam && <input type="hidden" name="Subtitle" value={img.Subtitle ?? ""} />}
                </div>

                {isTeam && (
                  <div class="grid grid-cols-3 gap-3">
                    <div>
                      <label class="text-xs text-gray-500 mb-1 block">Phone</label>
                      <input type="tel" name="Phone" value={img.Phone ?? ""} maxlength="500" class={inputCls} />
                    </div>
                    <div>
                      <label class="text-xs text-gray-500 mb-1 block">Email</label>
                      <input type="email" name="Email" value={img.Email ?? ""} maxlength="500" class={inputCls} />
                    </div>
                    <div>
                      <label class="text-xs text-gray-500 mb-1 block">LinkedIn</label>
                      <input type="url" name="LinkedIn" value={img.LinkedIn ?? ""} maxlength="500" class={inputCls} />
                    </div>
                  </div>
                )}
                {!isTeam && (
                  <>
                    <input type="hidden" name="Phone" value={img.Phone ?? ""} />
                    <input type="hidden" name="Email" value={img.Email ?? ""} />
                    <input type="hidden" name="LinkedIn" value={img.LinkedIn ?? ""} />
                  </>
                )}

                <div class="grid grid-cols-2 gap-3">
                  <div>
                    <label class="text-xs text-gray-500 mb-1 block">Large Image</label>
                    <input type="text" name="Lg_Image" value={img.Lg_Image ?? ""} maxlength="500" class={inputCls} />
                  </div>
                  <div>
                    <label class="text-xs text-gray-500 mb-1 block">Small Image</label>
                    <input type="text" name="Sm_Image" value={img.Sm_Image ?? ""} maxlength="500" class={inputCls} />
                  </div>
                </div>

                <div class="grid grid-cols-2 gap-3">
                  <div>
                    <label class="text-xs text-gray-500 mb-1 block">Link</label>
                    <input type="text" name="Link" value={img.Link ?? ""} maxlength="500" class={inputCls} />
                  </div>
                  <div>
                    <label class="text-xs text-gray-500 mb-1 block">Open in new window?</label>
                    <div class="flex gap-4 text-sm pt-1">
                      <label class="flex items-center gap-1.5"><input type="radio" name="Target" value="1" checked={img.Target} /> Yes</label>
                      <label class="flex items-center gap-1.5"><input type="radio" name="Target" value="0" checked={!img.Target} /> No</label>
                    </div>
                  </div>
                </div>

                <div class="grid grid-cols-3 gap-3">
                  <div>
                    <label class="text-xs text-gray-500 mb-1 block">Start Date</label>
                    <input type="date" name="StartDate" value={fmtDate(img.StartDate)} class={inputCls} />
                  </div>
                  <div>
                    <label class="text-xs text-gray-500 mb-1 block">End Date</label>
                    <input type="date" name="EndDate" value={fmtDate(img.EndDate)} class={inputCls} />
                  </div>
                  <div>
                    <label class="text-xs text-gray-500 mb-1 block">Priority</label>
                    <input type="number" name="Priority" min="0" max="9999"
                           value={img.Priority === 9999 ? 0 : img.Priority} class={inputCls} />
                  </div>
                </div>

                <div>
                  <label class="text-xs text-gray-500 mb-1 block">Description</label>
                  <textarea name="Description" rows={3} class={inputCls}>{img.Description ?? ""}</textarea>
                </div>

                <div>
                  <label class="text-xs text-gray-500 mb-1 block">Category</label>
                  <select name="Category_ID" class="border border-gray-300 rounded px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">
                    <option value="0" selected={!img.Category_ID}> — none —</option>
                    {categories.map(c => (
                      <option value={c.Category_ID} selected={img.Category_ID === c.Category_ID}>{c.Name}</option>
                    ))}
                  </select>
                </div>

                <div class="flex gap-2 pt-1">
                  <button type="submit" class="bg-blue-600 text-white px-4 py-1.5 rounded text-sm hover:bg-blue-700">Update</button>
                  <button type="submit" name="_action" value="delete"
                          onclick={`return confirm('Delete this image?')`}
                          class="px-4 py-1.5 rounded text-sm border border-red-300 text-red-600 hover:bg-red-50">Delete</button>
                </div>
              </form>
            </div>
          </details>
        ))}
      </div>
    </div>
  )}

  <!-- Add image form -->
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
    <div class="bg-gray-50 border-b border-gray-200 px-4 py-2.5 text-sm font-semibold text-gray-700">Add Image</div>
    <form method="post" class="p-5 space-y-3">
      <input type="hidden" name="_action" value="add" />

      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="text-xs text-gray-500 mb-1 block">Name</label>
          <input type="text" name="Name" maxlength="500" class={inputCls} />
        </div>
        {isTeam && (
          <div>
            <label class="text-xs text-gray-500 mb-1 block">Job Title</label>
            <input type="text" name="Subtitle" maxlength="500" class={inputCls} />
          </div>
        )}
        {!isTeam && <input type="hidden" name="Subtitle" value="" />}
      </div>

      {isTeam && (
        <div class="grid grid-cols-3 gap-3">
          <div>
            <label class="text-xs text-gray-500 mb-1 block">Phone</label>
            <input type="tel" name="Phone" maxlength="500" class={inputCls} />
          </div>
          <div>
            <label class="text-xs text-gray-500 mb-1 block">Email</label>
            <input type="email" name="Email" maxlength="500" class={inputCls} />
          </div>
          <div>
            <label class="text-xs text-gray-500 mb-1 block">LinkedIn</label>
            <input type="url" name="LinkedIn" maxlength="500" class={inputCls} />
          </div>
        </div>
      )}
      {!isTeam && (
        <>
          <input type="hidden" name="Phone" value="" />
          <input type="hidden" name="Email" value="" />
          <input type="hidden" name="LinkedIn" value="" />
        </>
      )}

      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="text-xs text-gray-500 mb-1 block">Large Image path</label>
          <input type="text" name="Lg_Image" maxlength="500" placeholder="e.g. galleries/1/photo-lg.webp" class={inputCls} />
        </div>
        <div>
          <label class="text-xs text-gray-500 mb-1 block">Small Image path</label>
          <input type="text" name="Sm_Image" maxlength="500" placeholder="e.g. galleries/1/photo-sm.webp" class={inputCls} />
        </div>
      </div>

      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="text-xs text-gray-500 mb-1 block">Link</label>
          <input type="text" name="Link" maxlength="500" class={inputCls} />
        </div>
        <div>
          <label class="text-xs text-gray-500 mb-1 block">Open in new window?</label>
          <div class="flex gap-4 text-sm pt-1">
            <label class="flex items-center gap-1.5"><input type="radio" name="Target" value="1" /> Yes</label>
            <label class="flex items-center gap-1.5"><input type="radio" name="Target" value="0" checked /> No</label>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-3 gap-3">
        <div>
          <label class="text-xs text-gray-500 mb-1 block">Start Date</label>
          <input type="date" name="StartDate" class={inputCls} />
        </div>
        <div>
          <label class="text-xs text-gray-500 mb-1 block">End Date</label>
          <input type="date" name="EndDate" class={inputCls} />
        </div>
        <div>
          <label class="text-xs text-gray-500 mb-1 block">Priority</label>
          <input type="number" name="Priority" min="0" max="9999" value="0" class={inputCls} />
        </div>
      </div>

      <div>
        <label class="text-xs text-gray-500 mb-1 block">Description</label>
        <textarea name="Description" rows={3} class={inputCls}></textarea>
      </div>

      <div>
        <label class="text-xs text-gray-500 mb-1 block">Category</label>
        <select name="Category_ID" class="border border-gray-300 rounded px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">
          <option value="0"> — none —</option>
          {categories.map(c => (
            <option value={c.Category_ID}>{c.Name}</option>
          ))}
        </select>
      </div>

      <button type="submit" class="bg-blue-600 text-white px-5 py-2 rounded text-sm hover:bg-blue-700">Add Image</button>
    </form>
  </div>

</AdminLayout>
