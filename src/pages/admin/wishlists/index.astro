---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import { getWishlists } from "../../../lib/queries/admin-wishlists";
import type { WishlistFilters } from "../../../lib/queries/admin-wishlists";

const sp = Astro.url.searchParams;
const filters: WishlistFilters = {
  customer:  sp.get("customer")  || undefined,
  startDate: sp.get("startDate") || undefined,
  toDate:    sp.get("toDate")    || undefined,
  sort:      (sp.get("sort") as WishlistFilters["sort"]) || undefined,
};

let wishlists: Awaited<ReturnType<typeof getWishlists>> = [];
let fetchError = "";
try {
  wishlists = await getWishlists(filters);
} catch (e: unknown) {
  fetchError = e instanceof Error ? e.message : String(e);
}

function fmtDate(d: Date | null) {
  if (!d) return "—";
  return new Date(d).toLocaleDateString("en-US", { month: "2-digit", day: "2-digit", year: "2-digit" });
}
function fmtCurrency(n: number) {
  return "$" + Number(n ?? 0).toFixed(2);
}
function fmtName(first: string | null, last: string | null) {
  return [first, last].filter(Boolean).join(" ") || "—";
}

const grandTotal = wishlists.reduce((s, w) => s + Number(w.GTotal ?? 0), 0);
---

<AdminLayout title="Wish Lists">

  <div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-semibold text-gray-800">Wish Lists</h1>
  </div>

  {fetchError && (
    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{fetchError}</div>
  )}

  {/* Filters */}
  <form method="get" class="mb-6 bg-white border border-gray-200 rounded-xl shadow-sm px-5 py-4 flex flex-wrap gap-4 items-end">
    <div>
      <label class="block text-xs text-gray-500 mb-1">Customer</label>
      <input type="text" name="customer" value={filters.customer ?? ""}
             placeholder="First or last name"
             class="border border-gray-300 rounded px-3 py-1.5 text-sm w-44 focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>
    <div>
      <label class="block text-xs text-gray-500 mb-1">Date From</label>
      <input type="date" name="startDate" value={filters.startDate ?? ""}
             class="border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>
    <div>
      <label class="block text-xs text-gray-500 mb-1">Date Through</label>
      <input type="date" name="toDate" value={filters.toDate ?? ""}
             class="border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>
    <div>
      <label class="block text-xs text-gray-500 mb-1">Sort By</label>
      <select name="sort" class="border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">
        <option value="">Latest First</option>
        <option value="1" selected={filters.sort === "1"}>Items ASC</option>
        <option value="2" selected={filters.sort === "2"}>Items DESC</option>
        <option value="3" selected={filters.sort === "3"}>Total ASC</option>
        <option value="4" selected={filters.sort === "4"}>Total DESC</option>
      </select>
    </div>
    <div class="flex gap-2">
      <button type="submit" class="bg-blue-600 text-white px-4 py-1.5 rounded text-sm hover:bg-blue-700">Filter</button>
      <a href="/admin/wishlists" class="px-4 py-1.5 rounded text-sm border border-gray-300 text-gray-600 hover:bg-gray-50">Reset</a>
    </div>
  </form>

  {/* Table */}
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
    {wishlists.length === 0 ? (
      <p class="px-5 py-10 text-center text-sm text-gray-400">No wish lists found.</p>
    ) : (
      <table class="w-full text-sm">
        <thead class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
          <tr>
            <th class="px-5 py-3 text-left">Customer</th>
            <th class="px-5 py-3 text-center">Items</th>
            <th class="px-5 py-3 text-right">Total Value</th>
            <th class="px-5 py-3 text-center">Last Updated</th>
            <th class="px-5 py-3 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {wishlists.map(w => (
            <tr class="hover:bg-gray-50">
              <td class="px-5 py-3 font-medium text-gray-800">
                {fmtName(w.FirstName, w.LastName)}
                {w.ListName && <span class="text-xs text-gray-400 ml-1">({w.ListName})</span>}
              </td>
              <td class="px-5 py-3 text-center text-gray-600">{w.ProductCount}</td>
              <td class="px-5 py-3 text-right text-gray-700 font-mono">{fmtCurrency(w.GTotal)}</td>
              <td class="px-5 py-3 text-center text-gray-500 text-xs">{fmtDate(w.LastUpdated)}</td>
              <td class="px-5 py-3 text-right">
                <a href={`/admin/wishlists/${w.User_ID}`}
                   class="px-3 py-1 text-xs rounded bg-blue-600 text-white hover:bg-blue-700">
                  View
                </a>
              </td>
            </tr>
          ))}
        </tbody>
        <tfoot class="bg-gray-50 border-t border-gray-200">
          <tr>
            <td class="px-5 py-3 text-xs text-gray-400">{wishlists.length} wish list{wishlists.length !== 1 ? "s" : ""}</td>
            <td class="px-5 py-3 text-center text-xs font-medium text-gray-600">
              {wishlists.reduce((s, w) => s + Number(w.ProductCount ?? 0), 0)} items
            </td>
            <td class="px-5 py-3 text-right text-xs font-medium text-gray-700 font-mono">{fmtCurrency(grandTotal)}</td>
            <td colspan="2" />
          </tr>
        </tfoot>
      </table>
    )}
  </div>

</AdminLayout>
