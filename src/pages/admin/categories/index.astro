---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import { getCategoriesAdmin } from "../../../lib/queries/admin";

const categories = await getCategoriesAdmin();
// Build name lookup for parent display
const nameMap = new Map(categories.map((c) => [c.Category_ID, c.Name]));

const saved   = Astro.url.searchParams.get("saved")   === "1";
const deleted = Astro.url.searchParams.get("deleted") === "1";
---
<AdminLayout title="Categories">
  {saved   && <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">Saved successfully.</div>}
  {deleted && <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">Category deleted.</div>}

  <div class="flex justify-end mb-4">
    <a href="/admin/categories/new" class="bg-blue-600 text-white px-4 py-1.5 rounded-lg text-sm hover:bg-blue-700">
      + New Category
    </a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-5 py-3 border-b border-gray-100 text-xs text-gray-500">{categories.length} categories</div>
    <table class="w-full text-sm">
      <thead class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
        <tr>
          <th class="px-5 py-3 text-left">Name</th>
          <th class="px-5 py-3 text-left">Parent</th>
          <th class="px-5 py-3 text-right">Priority</th>
          <th class="px-5 py-3 text-center">Active</th>
          <th class="px-5 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {categories.length === 0 && (
          <tr><td colspan="5" class="px-5 py-10 text-center text-gray-400">No categories found.</td></tr>
        )}
        {categories.map((c) => (
          <tr class="hover:bg-gray-50">
            <td class="px-5 py-3 font-medium text-gray-800">
              <a href={`/admin/categories/${c.Category_ID}`} class="hover:text-blue-600">{c.Name}</a>
            </td>
            <td class="px-5 py-3 text-gray-500">
              {c.Parent_ID > 0 ? nameMap.get(c.Parent_ID) ?? `ID ${c.Parent_ID}` : "—"}
            </td>
            <td class="px-5 py-3 text-right text-gray-500">{c.Priority}</td>
            <td class="px-5 py-3 text-center">
              {c.Display
                ? <span class="text-green-600 font-bold">✓</span>
                : <span class="text-gray-300">—</span>}
            </td>
            <td class="px-5 py-3 text-right">
              <a href={`/admin/categories/${c.Category_ID}`} class="text-blue-600 hover:underline text-xs mr-3">Edit</a>
              <form method="post" action={`/admin/categories/${c.Category_ID}`} class="inline">
                <input type="hidden" name="_action" value="delete" />
                <button
                  type="submit"
                  class="text-red-500 hover:underline text-xs"
                  onclick="return confirm('Delete this category?')"
                >Delete</button>
              </form>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</AdminLayout>
