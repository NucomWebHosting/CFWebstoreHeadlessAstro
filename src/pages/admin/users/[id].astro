---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import { getUserAdmin, updateUser, getAllGroups } from "../../../lib/queries/admin-users";

const id = Number(Astro.params.id);
if (!id) return new Response(null, { status: 404 });

// ── POST ───────────────────────────────────────────────────────────────────────
if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  const g = (k: string) => (data.get(k) as string) ?? "";
  try {
    await updateUser(id, {
      Username:   g("Username"),
      Email:      g("Email"),
      Password:   g("Password") || undefined,
      Group_ID:   parseInt(g("Group_ID"))  || 0,
      Customer_ID: parseInt(g("Customer_ID")) || 0,
      ShipTo:     parseInt(g("ShipTo"))    || 0,
      Subscribe:  g("Subscribe")  === "1",
      Disable:    g("Disable")    === "1",
      EmailIsBad: g("EmailIsBad") === "1",
      Allow_PO:   g("Allow_PO")   === "1",
      AdminNotes: g("AdminNotes"),
    });
  } catch (e) {
    const msg = e instanceof Error ? e.message : String(e);
    return new Response(`Save error: ${msg}`, { status: 500, headers: { "content-type": "text/plain" } });
  }
  return Astro.redirect(`/admin/users/${id}?saved=1`);
}

// ── Fetch ──────────────────────────────────────────────────────────────────────
let userResult: Awaited<ReturnType<typeof getUserAdmin>>;
try {
  userResult = await getUserAdmin(id);
} catch (e) {
  const msg = e instanceof Error ? e.message : String(e);
  return new Response(`Query error: ${msg}`, { status: 500, headers: { "content-type": "text/plain" } });
}
const { user, customers } = userResult;
if (!user) return new Response(`User ${id} not found.`, { status: 404, headers: { "content-type": "text/plain" } });

const groups = await getAllGroups();
const saved = Astro.url.searchParams.get("saved") === "1";

function fmtDate(d: Date | null | undefined) {
  if (!d) return "—";
  return new Date(d).toLocaleDateString("en-US", { month: "2-digit", day: "2-digit", year: "2-digit" });
}
function fmtDateTime(d: Date | null | undefined) {
  if (!d) return "—";
  return new Date(d).toLocaleString("en-US", { month: "2-digit", day: "2-digit", year: "2-digit", hour: "2-digit", minute: "2-digit" });
}

// Row helper
type RadioOpts = { name: string; value: string; label: string; checked: boolean }[];
---

<AdminLayout title={`User #${user.User_ID}`}>

  {saved && (
    <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">
      Saved successfully.
    </div>
  )}

  <div class="flex items-center gap-3 mb-5">
    <a href="/admin/users" class="text-sm text-blue-600 hover:underline">← Back to Users</a>
    <span class="text-gray-300">|</span>
    <span class="text-sm text-gray-500">User ID: {user.User_ID}</span>
    {user.Disable && (
      <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-red-100 text-red-700">Disabled</span>
    )}
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">

    <!-- LEFT: edit form -->
    <div class="lg:col-span-2">
      <form method="post" class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 space-y-4">

        <!-- Username -->
        <div class="grid grid-cols-3 gap-3 items-center">
          <label class="text-sm text-gray-600 font-medium text-right">Username</label>
          <input type="text" name="Username" value={user.Username} required maxlength="100"
                 class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
        </div>

        <!-- Email -->
        <div class="grid grid-cols-3 gap-3 items-center">
          <label class="text-sm text-gray-600 font-medium text-right">Email</label>
          <input type="email" name="Email" value={user.Email} required maxlength="100"
                 class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
        </div>

        <!-- New Password -->
        <div class="grid grid-cols-3 gap-3 items-center">
          <label class="text-sm text-gray-600 font-medium text-right">New Password</label>
          <input type="text" name="Password" value="" maxlength="100" placeholder="leave blank to keep current"
                 autocomplete="off"
                 class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
        </div>

        <!-- Group -->
        <div class="grid grid-cols-3 gap-3 items-center">
          <label class="text-sm text-gray-600 font-medium text-right">Group</label>
          <select name="Group_ID"
                  class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm w-auto focus:outline-none focus:ring-1 focus:ring-blue-400">
            <option value="0">unassigned</option>
            {groups.map(g => (
              <option value={String(g.Group_ID)} selected={user.Group_ID === g.Group_ID}>{g.Name}</option>
            ))}
          </select>
        </div>

        <!-- Customer ID / ShipTo -->
        {customers.length > 0 ? (
          <>
            <div class="grid grid-cols-3 gap-3 items-center">
              <label class="text-sm text-gray-600 font-medium text-right">Customer (Bill)</label>
              <select name="Customer_ID"
                      class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm w-auto focus:outline-none focus:ring-1 focus:ring-blue-400">
                <option value="0">none</option>
                {customers.map(c => (
                  <option value={String(c.Customer_ID)} selected={user.Customer_ID === c.Customer_ID}>
                    #{c.Customer_ID}: {[c.FirstName, c.LastName].filter(Boolean).join(" ")} — {c.Address1 ?? ""}
                  </option>
                ))}
              </select>
            </div>
            <div class="grid grid-cols-3 gap-3 items-center">
              <label class="text-sm text-gray-600 font-medium text-right">Ship To</label>
              <select name="ShipTo"
                      class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm w-auto focus:outline-none focus:ring-1 focus:ring-blue-400">
                <option value="0">same as billing</option>
                {customers.map(c => (
                  <option value={String(c.Customer_ID)} selected={user.ShipTo === c.Customer_ID}>
                    #{c.Customer_ID}: {[c.FirstName, c.LastName].filter(Boolean).join(" ")} — {c.Address1 ?? ""}
                  </option>
                ))}
              </select>
            </div>
          </>
        ) : (
          <>
            <input type="hidden" name="Customer_ID" value={String(user.Customer_ID ?? 0)} />
            <input type="hidden" name="ShipTo" value={String(user.ShipTo ?? 0)} />
          </>
        )}

        <!-- Subscribe -->
        <div class="grid grid-cols-3 gap-3 items-start">
          <span class="text-sm text-gray-600 font-medium text-right pt-1">Subscribe</span>
          <div class="col-span-2 flex gap-4 pt-1">
            <label class="flex items-center gap-1.5 text-sm">
              <input type="radio" name="Subscribe" value="1" checked={user.Subscribe} /> Yes
            </label>
            <label class="flex items-center gap-1.5 text-sm">
              <input type="radio" name="Subscribe" value="0" checked={!user.Subscribe} /> No
            </label>
          </div>
        </div>

        <!-- Allow PO -->
        <div class="grid grid-cols-3 gap-3 items-start">
          <span class="text-sm text-gray-600 font-medium text-right pt-1">Allow PO</span>
          <div class="col-span-2 flex gap-4 pt-1">
            <label class="flex items-center gap-1.5 text-sm">
              <input type="radio" name="Allow_PO" value="1" checked={user.Allow_PO} /> Yes
            </label>
            <label class="flex items-center gap-1.5 text-sm">
              <input type="radio" name="Allow_PO" value="0" checked={!user.Allow_PO} /> No
            </label>
          </div>
        </div>

        <!-- Bad Email -->
        <div class="grid grid-cols-3 gap-3 items-start">
          <span class="text-sm text-gray-600 font-medium text-right pt-1">Email OK</span>
          <div class="col-span-2 flex gap-4 pt-1">
            <label class="flex items-center gap-1.5 text-sm">
              <input type="radio" name="EmailIsBad" value="0" checked={!user.EmailIsBad} /> Email OK
            </label>
            <label class="flex items-center gap-1.5 text-sm">
              <input type="radio" name="EmailIsBad" value="1" checked={user.EmailIsBad} /> Bad Email
            </label>
          </div>
        </div>

        <!-- Disable -->
        <div class="grid grid-cols-3 gap-3 items-start">
          <span class="text-sm text-gray-600 font-medium text-right pt-1">Disable</span>
          <div class="col-span-2 flex gap-4 pt-1">
            <label class="flex items-center gap-1.5 text-sm">
              <input type="radio" name="Disable" value="0" checked={!user.Disable} /> No
            </label>
            <label class="flex items-center gap-1.5 text-sm">
              <input type="radio" name="Disable" value="1" checked={user.Disable} /> Yes
            </label>
          </div>
        </div>

        <!-- Admin Notes -->
        <div class="grid grid-cols-3 gap-3 items-start">
          <label class="text-sm text-gray-600 font-medium text-right pt-1">Admin Notes</label>
          <textarea name="AdminNotes" rows="4"
                    class="col-span-2 border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400 resize-y"
          >{user.AdminNotes ?? ""}</textarea>
        </div>

        <!-- Submit -->
        <div class="grid grid-cols-3 gap-3">
          <div></div>
          <div class="col-span-2 flex gap-3">
            <button type="submit" class="bg-blue-600 text-white px-5 py-2 rounded text-sm hover:bg-blue-700">
              Save Changes
            </button>
            <a href="/admin/users" class="px-5 py-2 rounded text-sm border border-gray-300 text-gray-600 hover:bg-gray-50">
              Cancel
            </a>
          </div>
        </div>

      </form>
    </div>

    <!-- RIGHT: stats sidebar -->
    <div class="flex flex-col gap-5">

      <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4">
        <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Account Info</h3>
        <dl class="text-sm space-y-1.5">
          <div class="flex justify-between">
            <dt class="text-gray-500">User ID</dt>
            <dd class="text-gray-800 font-medium">{user.User_ID}</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-gray-500">Created</dt>
            <dd class="text-gray-800">{fmtDate(user.Created)}</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-gray-500">Last Login</dt>
            <dd class="text-gray-800">{fmtDateTime(user.LastLogin)}</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-gray-500">Total Logins</dt>
            <dd class="text-gray-800">{user.LoginsTotal ?? 0}</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-gray-500">Logins (last day)</dt>
            <dd class="text-gray-800">{user.LoginsDay ?? 0}</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-gray-500">Failed Logins</dt>
            <dd class={`font-medium ${(user.FailedLogins ?? 0) > 5 ? "text-red-600" : "text-gray-800"}`}>
              {user.FailedLogins ?? 0}
            </dd>
          </div>
          {user.EmailLock && (
            <div class="flex justify-between">
              <dt class="text-gray-500">Email Lock</dt>
              <dd class={user.EmailLock === "verified" ? "text-green-600" : "text-yellow-600 font-medium"}>
                {user.EmailLock}
              </dd>
            </div>
          )}
          {user.TaxID && (
            <div class="flex justify-between">
              <dt class="text-gray-500">Tax ID</dt>
              <dd class="text-gray-800 font-mono text-xs">{user.TaxID}</dd>
            </div>
          )}
        </dl>
      </div>

      {customers.length > 0 && (
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4">
          <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">
            Address Book ({customers.length})
          </h3>
          <ul class="space-y-1.5">
            {customers.map(c => (
              <li class="text-xs text-gray-600">
                <span class="font-medium text-gray-700">#{c.Customer_ID}</span>
                {" "}
                {[c.FirstName, c.LastName].filter(Boolean).join(" ")}
                {c.Address1 && <span class="text-gray-400"> — {c.Address1}</span>}
              </li>
            ))}
          </ul>
        </div>
      )}

    </div>
  </div>

</AdminLayout>
