---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import {
  getCustomer, findUserByUsername, updateCustomer,
  checkCustomerInUse, deleteCustomer,
  getStates, getCountries,
} from "../../../lib/queries/admin-customers";

const id = parseInt(Astro.params.id ?? "0") || 0;
if (!id) return new Response(null, { status: 404 });

let error = "";

if (Astro.request.method === "POST") {
  const d = await Astro.request.formData();
  const g = (k: string) => (d.get(k) as string ?? "").trim();
  const bit = (k: string) => g(k) === "1";
  const action = g("_action");

  if (action === "delete") {
    const inUse = await checkCustomerInUse(id);
    if (inUse) {
      error = `Cannot delete: ${inUse}`;
    } else {
      await deleteCustomer(id);
      return Astro.redirect("/admin/customers?deleted=1");
    }
  } else {
    const username = g("Username");
    const userId = await findUserByUsername(username);
    if (userId === null) {
      error = `Cannot update: "${username}" is not a valid user.`;
    } else {
      try {
        await updateCustomer(id, {
          User_ID:   userId,
          Firstname: g("Firstname"),
          LastName:  g("LastName"),
          Company:   g("Company"),
          Address1:  g("Address1"),
          Address2:  g("Address2"),
          City:      g("City"),
          County:    g("County"),
          State:     g("State"),
          State2:    g("State2"),
          Zip:       g("Zip"),
          Country:   g("Country"),
          Phone:     g("Phone"),
          Phone2:    g("Phone2"),
          Fax:       g("Fax"),
          Email:     g("Email"),
          Residence: bit("Residence"),
        });
        return Astro.redirect(`/admin/customers/${id}?saved=1`);
      } catch (e: unknown) {
        error = e instanceof Error ? e.message : String(e);
      }
    }
  }
}

const saved = Astro.url.searchParams.get("saved") === "1";
const [c, states, countries] = await Promise.all([
  getCustomer(id),
  getStates(),
  getCountries(),
]);

if (!c) return new Response(`Customer ${id} not found.`, { status: 404, headers: { "content-type": "text/plain" } });
---

<AdminLayout title={`Customer ${id}`}>
  <div class="flex items-center gap-3 mb-5">
    <a href="/admin/customers" class="text-sm text-blue-600 hover:underline">← Back to Customers</a>
  </div>

  {saved && (
    <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">Saved.</div>
  )}
  {error && (
    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
  )}

  <form method="post" class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-4 max-w-2xl">
    <input type="hidden" name="_action" value="update" />

    <div class="flex items-center justify-between border-b border-gray-100 pb-2">
      <h2 class="text-sm font-semibold text-gray-700">Customer #{id}</h2>
      {c.LastUsed && (
        <span class="text-xs text-gray-400">Last used: {new Date(c.LastUsed).toLocaleDateString()}</span>
      )}
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Username</label>
      <input type="text" name="Username" value={c.Username ?? ""} maxlength="50"
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400"
             placeholder="leave blank for no user" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">First Name <span class="text-red-500">*</span></label>
      <input type="text" name="Firstname" value={c.Firstname} maxlength="50" required
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Last Name <span class="text-red-500">*</span></label>
      <input type="text" name="LastName" value={c.LastName} maxlength="100" required
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Company</label>
      <input type="text" name="Company" value={c.Company ?? ""} maxlength="150"
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Address <span class="text-red-500">*</span></label>
      <input type="text" name="Address1" value={c.Address1 ?? ""} maxlength="150" required
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Address Line 2</label>
      <input type="text" name="Address2" value={c.Address2 ?? ""} maxlength="150"
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">City <span class="text-red-500">*</span></label>
      <input type="text" name="City" value={c.City ?? ""} maxlength="150" required
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">State / Province</label>
      <select name="State"
              class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400 w-64">
        <option value="Unlisted" selected={c.State === "Unlisted" || !c.State}>Unlisted / None</option>
        <option value="Unlisted">───────────────</option>
        {states.map(s => (
          <option value={s.Abb} selected={c.State === s.Abb}>{s.Name} ({s.Abb})</option>
        ))}
      </select>
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Other State</label>
      <div class="col-span-2">
        <input type="text" name="State2" value={c.State2 ?? ""} maxlength="50"
               class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
        <p class="text-xs text-gray-400 mt-0.5">Enter state here if not in list above.</p>
      </div>
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">County</label>
      <input type="text" name="County" value={c.County ?? ""} maxlength="100"
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Zip <span class="text-red-500">*</span></label>
      <input type="text" name="Zip" value={c.Zip ?? ""} maxlength="50" required minlength="4"
             class="col-span-2 w-36 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Country</label>
      <select name="Country"
              class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400 w-64">
        <option value="US^United States" selected={c.Country === "US^United States" || !c.Country}>United States</option>
        <option value="US^United States">───────────────</option>
        {countries.map(ctry => {
          const val = `${ctry.Abbrev}^${ctry.Name}`;
          return <option value={val} selected={c.Country === val}>{ctry.Name}</option>;
        })}
      </select>
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Phone</label>
      <input type="tel" name="Phone" value={c.Phone ?? ""} maxlength="50"
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Other Phone</label>
      <input type="tel" name="Phone2" value={c.Phone2 ?? ""} maxlength="50"
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Fax</label>
      <input type="tel" name="Fax" value={c.Fax ?? ""} maxlength="50"
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Email</label>
      <input type="email" name="Email" value={c.Email ?? ""} maxlength="150"
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <span class="text-sm text-gray-600 font-medium text-right">Residential</span>
      <div class="col-span-2 flex gap-4">
        <label class="flex items-center gap-2 text-sm">
          <input type="radio" name="Residence" value="1" checked={c.Residence} /> Yes
        </label>
        <label class="flex items-center gap-2 text-sm">
          <input type="radio" name="Residence" value="0" checked={!c.Residence} /> No
        </label>
      </div>
    </div>

    <div class="flex items-center gap-3 pt-2">
      <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded text-sm hover:bg-blue-700">
        Update Customer
      </button>
    </div>
  </form>

  <!-- Delete -->
  <div class="mt-5 max-w-2xl">
    <form method="post"
          onsubmit={`return confirm('Are you sure you want to delete Customer ${id}? All associated records will be updated.')`}>
      <input type="hidden" name="_action" value="delete" />
      <button type="submit" class="px-4 py-2 rounded text-sm border border-red-300 text-red-600 hover:bg-red-50">
        Delete Customer
      </button>
    </form>
  </div>

</AdminLayout>
