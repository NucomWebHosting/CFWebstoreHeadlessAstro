---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import { createPromotion } from "../../../lib/queries/admin-promotions";
import { TYPE1_LABELS, TYPE1_HINTS } from "../../../lib/queries/admin-promotions";

let error = "";

if (Astro.request.method === "POST") {
  const d = await Astro.request.formData();

  const amountDollar = (d.get("amount_dollar") as string)?.trim();
  const amountPct    = (d.get("amount_pct")    as string)?.trim();
  const type2  = amountDollar ? 1 : 2;
  const amount = type2 === 1 ? parseFloat(amountDollar) : parseFloat(amountPct) / 100;

  const qualifyNumMaxRaw = (d.get("QualifyNumMax") as string)?.trim();

  try {
    const newId = await createPromotion({
      Type1:         parseInt(d.get("Type1")       as string) || 1,
      Type2:         type2,
      Type3:         parseInt(d.get("Type3")       as string) || 0,
      Type4:         parseInt(d.get("Type4")       as string) || 0,
      Name:          (d.get("Name")                as string)?.trim() ?? "",
      Display:       (d.get("Display")             as string)?.trim() ?? "",
      Coup_Code:     (d.get("Coup_Code")           as string)?.trim() ?? "",
      OneTime:       d.get("OneTime") === "1",
      AccessKey:     parseInt(d.get("AccessKey")   as string) || 0,
      StartDate:     (d.get("StartDate") as string) || null,
      EndDate:       (d.get("EndDate")   as string) || null,
      Amount:        isNaN(amount) ? 0 : amount,
      QualifyNum:    parseFloat(d.get("QualifyNum") as string) || 0,
      QualifyNumMax: qualifyNumMaxRaw ? parseFloat(qualifyNumMaxRaw) : 0,
      DiscountNum:   parseInt(d.get("DiscountNum") as string) || 1,
      Multiply:      d.get("Multiply") === "1",
      Add_DiscProd:  d.get("Add_DiscProd") === "1",
    });
    return Astro.redirect(`/admin/promotions/${newId}`);
  } catch (e: unknown) {
    error = e instanceof Error ? e.message : String(e);
  }
}
---

<AdminLayout title="New Promotion">

  <div class="mb-5">
    <a href="/admin/promotions" class="text-sm text-blue-600 hover:underline">← Promotions</a>
  </div>

  {error && (
    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
  )}

  <form method="post" class="max-w-2xl space-y-6">
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100">
        <h2 class="font-semibold text-gray-800">New Promotion</h2>
      </div>
      <div class="px-5 py-5 space-y-5">

        {/* Promotion Type */}
        <fieldset>
          <legend class="block text-sm font-medium text-gray-700 mb-2">Promotion Type <span class="text-red-500">*</span></legend>
          <div class="space-y-2 text-sm">
            {Object.entries(TYPE1_LABELS).map(([val, label]) => (
              <label class="flex items-start gap-2 cursor-pointer">
                <input type="radio" name="Type1" value={val} checked={val === "1"} required class="mt-0.5 accent-blue-600" />
                <span>
                  <strong>{label}</strong>
                  <span class="text-gray-500"> — {TYPE1_HINTS[parseInt(val)]}</span>
                </span>
              </label>
            ))}
          </div>
        </fieldset>

        {/* User Level */}
        <fieldset>
          <legend class="block text-sm font-medium text-gray-700 mb-2">User Level <span class="text-red-500">*</span></legend>
          <div class="space-y-1.5 text-sm">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="Type4" value="0" checked class="accent-blue-600" />
              Available to all users
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="Type4" value="1" class="accent-blue-600" />
              Available to selected user groups only
            </label>
          </div>
        </fieldset>

        {/* Name + Display */}
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Internal Name <span class="text-red-500">*</span></label>
            <input type="text" name="Name" required maxlength="255"
                   class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Display to Customers <span class="text-red-500">*</span></label>
            <input type="text" name="Display" required maxlength="255"
                   class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
          </div>
        </div>

        {/* Coupon + OneTime */}
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Coupon Code</label>
            <input type="text" name="Coup_Code" maxlength="50"
                   placeholder="Leave blank for auto-apply"
                   class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm uppercase focus:outline-none focus:ring-1 focus:ring-blue-400" />
            <p class="text-xs text-gray-400 mt-1">Case insensitive.</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">One Time Only? <span class="text-red-500">*</span></label>
            <div class="flex gap-5 text-sm">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="OneTime" value="1" class="accent-blue-600" /> Yes
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="OneTime" value="0" checked class="accent-blue-600" /> No
              </label>
            </div>
          </div>
        </div>

        {/* Dates */}
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Start Date</label>
            <input type="date" name="StartDate"
                   class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">End Date</label>
            <input type="date" name="EndDate"
                   class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
          </div>
        </div>

        {/* Qualify Based On */}
        <fieldset>
          <legend class="block text-sm font-medium text-gray-700 mb-2">Qualify Based On <span class="text-red-500">*</span></legend>
          <div class="space-y-1.5 text-sm">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="Type3" value="0" checked class="accent-blue-600" />
              Number of items purchased
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="Type3" value="1" class="accent-blue-600" />
              Amount spent on items
            </label>
          </div>
        </fieldset>

        {/* Qualifying Amount Min/Max */}
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Qualifying Amount — Min <span class="text-red-500">*</span></label>
            <input type="number" name="QualifyNum" step="any" min="0" value="1" required
                   class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Qualifying Amount — Max</label>
            <input type="number" name="QualifyNumMax" step="any" min="0"
                   placeholder="Leave blank for no max"
                   class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
          </div>
        </div>

        {/* DiscountNum */}
        <div class="w-48">
          <label class="block text-sm font-medium text-gray-700 mb-1">Items to Discount <span class="text-red-500">*</span></label>
          <input type="number" name="DiscountNum" step="1" min="1" value="1" required
                 class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
        </div>

        {/* Amount */}
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Discount Amount <span class="text-red-500">*</span></label>
          <div class="flex items-center gap-3 text-sm">
            <input type="number" name="amount_dollar" step="0.01" min="0" placeholder="0.00"
                   class="w-28 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
            <span class="text-gray-500">$ off</span>
            <span class="text-gray-400 font-bold">OR</span>
            <input type="number" name="amount_pct" step="0.1" min="0" max="100" placeholder="0"
                   class="w-24 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
            <span class="text-gray-500">% off</span>
          </div>
          <p class="text-xs text-gray-400 mt-1">Fill in one. Dollar amount takes priority if both are entered.</p>
        </div>

        {/* Multiply + Add_DiscProd */}
        <div class="grid grid-cols-2 gap-6">
          <fieldset>
            <legend class="block text-sm font-medium text-gray-700 mb-2">Amounts can Multiply? <span class="text-red-500">*</span></legend>
            <div class="flex gap-5 text-sm">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="Multiply" value="1" class="accent-blue-600" /> Yes
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="Multiply" value="0" checked class="accent-blue-600" /> No
              </label>
            </div>
            <p class="text-xs text-gray-400 mt-1">Each additional qualifying amount earns an additional discounted item.</p>
          </fieldset>
          <fieldset>
            <legend class="block text-sm font-medium text-gray-700 mb-2">Auto-add Discounted Product? <span class="text-red-500">*</span></legend>
            <div class="flex gap-5 text-sm">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="Add_DiscProd" value="1" class="accent-blue-600" /> Yes
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="Add_DiscProd" value="0" checked class="accent-blue-600" /> No
              </label>
            </div>
            <p class="text-xs text-gray-400 mt-1">Automatically adds the discounted product to cart. Best for free-product promos only.</p>
          </fieldset>
        </div>

      </div>
    </div>

    <button type="submit" class="bg-blue-600 text-white px-5 py-2 rounded text-sm font-medium hover:bg-blue-700">
      Create Promotion
    </button>
  </form>

</AdminLayout>
