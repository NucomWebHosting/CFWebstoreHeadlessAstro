---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import ProductForm from "../../../components/admin/ProductForm.astro";
import { getProductByIdAdmin, updateProduct, deleteProduct } from "../../../lib/queries/admin";

const id = Number(Astro.params.id);
if (!id) return new Response(null, { status: 404 });

if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  if (data.get("_action") === "delete") {
    await deleteProduct(id);
    return Astro.redirect("/admin/products?deleted=1");
  }
  try {
    await updateProduct(id, data);
    return Astro.redirect(`/admin/products/${id}?saved=1`);
  } catch (e) {
    // fall through to re-render with error
  }
}

const product = await getProductByIdAdmin(id);
if (!product) return new Response(null, { status: 404 });

const saved = Astro.url.searchParams.get("saved") === "1";
---
<AdminLayout title={`Edit: ${product.Name}`}>
  <div class="flex items-center justify-between mb-4">
    <a href="/admin/products" class="text-sm text-blue-600 hover:underline">← Back to Products</a>
    {product.Permalink && (
      <a href={`/${product.Permalink}`} target="_blank" rel="noopener" class="text-sm text-gray-500 hover:text-blue-600">
        View on site →
      </a>
    )}
  </div>

  {saved && (
    <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">
      Saved successfully.
    </div>
  )}

  <ProductForm product={product} action={`/admin/products/${id}`} cancelHref="/admin/products" />

  <div class="mt-8 pt-6 border-t border-red-100">
    <h3 class="text-sm font-semibold text-red-700 mb-2">Danger Zone</h3>
    <form method="post" action={`/admin/products/${id}`}>
      <input type="hidden" name="_action" value="delete" />
      <button
        type="submit"
        class="px-4 py-2 rounded-lg text-sm bg-red-600 text-white hover:bg-red-700"
        onclick="return confirm('Permanently delete this product?')"
      >
        Delete Product
      </button>
    </form>
  </div>
</AdminLayout>
