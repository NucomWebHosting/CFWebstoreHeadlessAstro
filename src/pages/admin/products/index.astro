---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import { getProductsAdmin, getCategoryByIdAdmin } from "../../../lib/queries/admin";

const PER_PAGE = 40;

// Query params
const name          = Astro.url.searchParams.get("name") ?? "";
const upc           = Astro.url.searchParams.get("upc") ?? "";
const sku           = Astro.url.searchParams.get("sku") ?? "";
const displayStatus = Astro.url.searchParams.get("display") ?? "";
const highlight     = Astro.url.searchParams.get("highlight") ?? "";
const sale          = Astro.url.searchParams.get("sale") ?? "";
const hot           = Astro.url.searchParams.get("hot") ?? "";
const type          = Astro.url.searchParams.get("type") ?? "";
const sortBy        = Astro.url.searchParams.get("sortBy") ?? "name";
const sortOrder     = Astro.url.searchParams.get("sortOrder") ?? "asc";
const cidParam      = Astro.url.searchParams.get("cid");
const nocat         = Astro.url.searchParams.get("nocat") === "1";
const pageParam     = parseInt(Astro.url.searchParams.get("page") ?? "1") || 1;

const categoryId = cidParam !== null ? (parseInt(cidParam) || null) : null;

const { rows: products, total } = await getProductsAdmin({
  name:          name || undefined,
  upc:           upc || undefined,
  sku:           sku || undefined,
  displayStatus: displayStatus || undefined,
  highlight:     highlight || undefined,
  sale:          sale || undefined,
  hot:           hot || undefined,
  type:          type || undefined,
  categoryId,
  nocat,
  sortBy,
  sortOrder,
  page:    pageParam,
  perPage: PER_PAGE,
});

const totalPages = Math.ceil(total / PER_PAGE);
const parentCat = categoryId ? await getCategoryByIdAdmin(categoryId) : null;

const saved   = Astro.url.searchParams.get("saved")   === "1";
const deleted = Astro.url.searchParams.get("deleted") === "1";

// Preserve all active filters across pagination / sort
function filterQS(overrides: Record<string, string | number | null> = {}) {
  const p: Record<string, string> = {};
  if (name)          p.name      = name;
  if (upc)           p.upc       = upc;
  if (sku)           p.sku       = sku;
  if (displayStatus) p.display   = displayStatus;
  if (highlight)     p.highlight = highlight;
  if (sale)          p.sale      = sale;
  if (hot)           p.hot       = hot;
  if (type)          p.type      = type;
  if (sortBy !== "name")   p.sortBy    = sortBy;
  if (sortOrder !== "asc") p.sortOrder = sortOrder;
  if (cidParam !== null)   p.cid       = cidParam;
  if (nocat)               p.nocat     = "1";
  for (const [k, v] of Object.entries(overrides)) {
    if (v === null || v === "") delete p[k];
    else p[k] = String(v);
  }
  const qs = new URLSearchParams(p).toString();
  return qs ? `?${qs}` : "";
}

function pageWindow(current: number, total: number, size = 5) {
  const half  = Math.floor(size / 2);
  let start   = Math.max(1, current - half);
  const end   = Math.min(total, start + size - 1);
  start       = Math.max(1, end - size + 1);
  return { start, end };
}
const { start: winStart, end: winEnd } = pageWindow(pageParam, totalPages);
---
<AdminLayout title="Products">
  {saved   && <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">Saved successfully.</div>}
  {deleted && <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">Product deleted.</div>}

  <!-- Header -->
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-semibold text-gray-800">Product Manager</h2>
    <a href="/admin/products/new" class="bg-blue-600 text-white px-4 py-1.5 rounded-lg text-sm hover:bg-blue-700">
      + New Product
    </a>
  </div>

  <!-- Filter form -->
  <form method="get" action="/admin/products" class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 mb-3">
    {cidParam !== null && <input type="hidden" name="cid" value={cidParam} />}
    {nocat && <input type="hidden" name="nocat" value="1" />}
    <div class="flex flex-wrap gap-3 items-end mb-3">
      <div>
        <label class="block text-xs text-gray-500 mb-1">Name</label>
        <input type="text" name="name" value={name} maxlength="50"
               class="border border-gray-300 rounded px-2 py-1 text-sm w-40 focus:outline-none focus:ring-1 focus:ring-blue-400" />
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">UPC</label>
        <input type="text" name="upc" value={upc} maxlength="25"
               class="border border-gray-300 rounded px-2 py-1 text-sm w-32 focus:outline-none focus:ring-1 focus:ring-blue-400" />
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">SKU</label>
        <input type="text" name="sku" value={sku} maxlength="25"
               class="border border-gray-300 rounded px-2 py-1 text-sm w-32 focus:outline-none focus:ring-1 focus:ring-blue-400" />
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Display</label>
        <select name="display" class="border border-gray-300 rounded px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">
          <option value="">all</option>
          <option value="on"        selected={displayStatus === "on"}>display</option>
          <option value="off"       selected={displayStatus === "off"}>not displayed</option>
          <option value="current"   selected={displayStatus === "current"}>currently on sale</option>
          <option value="scheduled" selected={displayStatus === "scheduled"}>scheduled for sale</option>
          <option value="expired"   selected={displayStatus === "expired"}>expired for sale</option>
        </select>
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">New</label>
        <select name="highlight" class="border border-gray-300 rounded px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">
          <option value="">All</option>
          <option value="1" selected={highlight === "1"}>Yes</option>
          <option value="0" selected={highlight === "0"}>No</option>
        </select>
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Sale</label>
        <select name="sale" class="border border-gray-300 rounded px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">
          <option value="">All</option>
          <option value="1" selected={sale === "1"}>Yes</option>
          <option value="0" selected={sale === "0"}>No</option>
        </select>
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Hot</label>
        <select name="hot" class="border border-gray-300 rounded px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">
          <option value="">All</option>
          <option value="1" selected={hot === "1"}>Yes</option>
          <option value="0" selected={hot === "0"}>No</option>
        </select>
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Type</label>
        <select name="type" class="border border-gray-300 rounded px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">
          <option value="">All</option>
          <option value="product"     selected={type === "product"}>product</option>
          <option value="membership"  selected={type === "membership"}>membership</option>
          <option value="download"    selected={type === "download"}>download</option>
          <option value="certificate" selected={type === "certificate"}>certificate</option>
        </select>
      </div>
      <div class="flex gap-2">
        <button type="submit" class="bg-blue-600 text-white px-3 py-1.5 rounded text-sm hover:bg-blue-700">Search</button>
        <a href="/admin/products" class="border border-gray-300 px-3 py-1.5 rounded text-sm text-gray-600 hover:bg-gray-50">All</a>
      </div>
    </div>

    <!-- Sort row -->
    <div class="flex flex-wrap gap-3 items-end border-t border-gray-100 pt-3">
      <div>
        <label class="block text-xs text-gray-500 mb-1">Sort by</label>
        <select name="sortBy" class="border border-gray-300 rounded px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">
          <option value="name"     selected={sortBy === "name"}>Product Name</option>
          <option value="sku"      selected={sortBy === "sku"}>SKU</option>
          <option value="priority" selected={sortBy === "priority"}>Priority</option>
        </select>
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Order</label>
        <select name="sortOrder" class="border border-gray-300 rounded px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">
          <option value="asc"  selected={sortOrder === "asc"}>Ascending</option>
          <option value="desc" selected={sortOrder === "desc"}>Descending</option>
        </select>
      </div>
      <button type="submit" class="border border-gray-300 px-3 py-1.5 rounded text-sm text-gray-600 hover:bg-gray-50">Sort</button>
    </div>
  </form>

  <!-- Category context -->
  <div class="flex items-center justify-between mb-3">
    <div class="text-sm">
      {categoryId !== null && parentCat && (
        <span class="text-gray-600">
          In category: <span class="font-medium text-gray-800">{parentCat.Name}</span>
          <a href="/admin/products" class="ml-2 text-xs text-blue-600 hover:underline">× clear</a>
        </span>
      )}
      {nocat && (
        <span class="inline-flex items-center gap-1 text-gray-600">
          <span class="bg-blue-100 text-blue-700 text-xs px-2 py-0.5 rounded-full font-medium">Uncategorized</span>
          <a href="/admin/products" class="text-xs text-blue-600 hover:underline">× clear</a>
        </span>
      )}
    </div>
    <div class="flex gap-2">
      {!nocat && (
        <a href={`/admin/products?nocat=1`} class="border border-gray-300 px-3 py-1.5 rounded text-sm text-gray-600 hover:bg-gray-50">
          Uncategorized
        </a>
      )}
    </div>
  </div>

  <!-- Results table -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <!-- Count + pagination top -->
    <div class="px-5 py-3 border-b border-gray-100 flex items-center justify-between text-xs text-gray-500">
      <span>{total} {total === 1 ? "product" : "products"}{total > PER_PAGE ? `, page ${pageParam} of ${totalPages}` : ""}</span>
      {totalPages > 1 && (
        <div class="flex gap-1 items-center">
          {pageParam > 1
            ? <a href={filterQS({ page: pageParam - 1 })} class="px-2 py-1 border rounded hover:bg-gray-50">&lsaquo;</a>
            : <span class="px-2 py-1 border rounded text-gray-300 cursor-default">&lsaquo;</span>}
          {winStart > 1 && <span class="px-1 text-gray-400">…</span>}
          {Array.from({ length: winEnd - winStart + 1 }, (_, i) => winStart + i).map((p) => (
            <a href={filterQS({ page: p })}
               class={`px-2 py-1 border rounded ${p === pageParam ? "bg-blue-600 text-white border-blue-600" : "hover:bg-gray-50"}`}>
              {p}
            </a>
          ))}
          {winEnd < totalPages && <span class="px-1 text-gray-400">…</span>}
          {pageParam < totalPages
            ? <a href={filterQS({ page: pageParam + 1 })} class="px-2 py-1 border rounded hover:bg-gray-50">&rsaquo;</a>
            : <span class="px-2 py-1 border rounded text-gray-300 cursor-default">&rsaquo;</span>}
        </div>
      )}
    </div>

    <table class="w-full text-sm">
      <thead class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
        <tr>
          <th class="px-4 py-3 text-left w-20">ID</th>
          <th class="px-4 py-3 text-left">Name</th>
          <th class="px-4 py-3 text-left w-28">UPC</th>
          <th class="px-4 py-3 text-left w-28">SKU</th>
          <th class="px-4 py-3 text-center w-20">Display</th>
          <th class="px-4 py-3 text-center w-16">New</th>
          <th class="px-4 py-3 text-center w-16">Sale</th>
          <th class="px-4 py-3 text-center w-16">Hot</th>
          <th class="px-4 py-3 text-left w-24">Type</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {products.length === 0 && (
          <tr>
            <td colspan="9" class="px-5 py-10 text-center text-gray-400">No products found.</td>
          </tr>
        )}
        {products.map((p) => (
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 text-xs">
              <a href={`/admin/products/${p.Product_ID}`} class="text-blue-600 hover:underline font-mono">
                {p.Product_ID}
              </a>
            </td>
            <td class="px-4 py-3 font-medium text-gray-800 max-w-xs truncate">
              <a href={`/admin/products/${p.Product_ID}`} class="hover:text-blue-600">{p.Name}</a>
            </td>
            <td class="px-4 py-3 text-gray-500 text-xs">{p.UPC ?? "—"}</td>
            <td class="px-4 py-3 text-gray-500 text-xs">{p.SKU ?? "—"}</td>
            <td class="px-4 py-3 text-center">
              {p.Display
                ? <span class="text-green-600 font-bold text-xs">Yes</span>
                : <span class="text-gray-300 text-xs">No</span>}
            </td>
            <td class="px-4 py-3 text-center">
              {p.Highlight
                ? <span class="text-blue-600 font-bold text-xs">Yes</span>
                : <span class="text-gray-300 text-xs">No</span>}
            </td>
            <td class="px-4 py-3 text-center">
              {p.Sale
                ? <span class="text-yellow-600 font-bold text-xs">Yes</span>
                : <span class="text-gray-300 text-xs">No</span>}
            </td>
            <td class="px-4 py-3 text-center">
              {p.Hot
                ? <span class="text-red-600 font-bold text-xs">Yes</span>
                : <span class="text-gray-300 text-xs">No</span>}
            </td>
            <td class="px-4 py-3 text-gray-500 text-xs">{p.Prod_Type ?? "—"}</td>
          </tr>
        ))}
      </tbody>
    </table>

    <!-- Pagination bottom -->
    {totalPages > 1 && (
      <div class="px-5 py-3 border-t border-gray-100 flex justify-end">
        <div class="flex gap-1 text-xs items-center">
          {pageParam > 1
            ? <a href={filterQS({ page: pageParam - 1 })} class="px-2 py-1 border rounded hover:bg-gray-50">&lsaquo;</a>
            : <span class="px-2 py-1 border rounded text-gray-300 cursor-default">&lsaquo;</span>}
          {winStart > 1 && <span class="px-1 text-gray-400">…</span>}
          {Array.from({ length: winEnd - winStart + 1 }, (_, i) => winStart + i).map((p) => (
            <a href={filterQS({ page: p })}
               class={`px-2 py-1 border rounded ${p === pageParam ? "bg-blue-600 text-white border-blue-600" : "hover:bg-gray-50"}`}>
              {p}
            </a>
          ))}
          {winEnd < totalPages && <span class="px-1 text-gray-400">…</span>}
          {pageParam < totalPages
            ? <a href={filterQS({ page: pageParam + 1 })} class="px-2 py-1 border rounded hover:bg-gray-50">&rsaquo;</a>
            : <span class="px-2 py-1 border rounded text-gray-300 cursor-default">&rsaquo;</span>}
        </div>
      </div>
    )}
  </div>
</AdminLayout>
