---
export const prerender = false;
import AdminLayout from "../../../../components/layout/AdminLayout.astro";
import ProductTabNav from "../../../../components/admin/ProductTabNav.astro";
import { getProductByIdAdmin } from "../../../../lib/queries/admin";
import {
  getProductFiles, addProductFile, updateProductFile, deleteProductFile,
  FILE_CATEGORIES,
} from "../../../../lib/queries/admin-product-tabs";
import * as fs from "node:fs/promises";
import * as path from "node:path";

const id = Number(Astro.params.id);
if (!id) return new Response(null, { status: 404 });

let error = "";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = form.get("action") as string;

  try {
    if (action === "delete") {
      await deleteProductFile(parseInt(form.get("file_id") as string));
    } else if (action === "update") {
      await updateProductFile(
        parseInt(form.get("file_id") as string),
        parseInt(form.get("category_id") as string) || 1,
        (form.get("description") as string)?.trim() || null,
        parseInt(form.get("priority") as string) || 1
      );
    } else if (action === "upload") {
      const file = form.get("upload_file") as File | null;
      if (!file || !file.name) throw new Error("Please select a file.");
      const uploadDir = path.join(process.cwd(), "public", "uploads", "products", String(id), "files");
      await fs.mkdir(uploadDir, { recursive: true });
      const filename = `${Date.now()}_${file.name.replace(/[^a-z0-9._-]/gi, "_")}`;
      const bytes = await file.arrayBuffer();
      await fs.writeFile(path.join(uploadDir, filename), Buffer.from(bytes));
      const webPath = `/uploads/products/${id}/files/${filename}`;
      await addProductFile(
        id, webPath,
        parseInt(form.get("category_id") as string) || 1,
        (form.get("description") as string)?.trim() || null,
        parseInt(form.get("priority") as string) || 1
      );
    }
    return Astro.redirect(`/admin/products/${id}/files`);
  } catch (e: unknown) {
    error = e instanceof Error ? e.message : String(e);
  }
}

const product = await getProductByIdAdmin(id);
if (!product) return new Response(null, { status: 404 });

const files = await getProductFiles(id);
const editFileId = parseInt(Astro.url.searchParams.get("edit") ?? "0") || 0;
const cats = Object.entries(FILE_CATEGORIES);
---

<AdminLayout title={`Files — ${product.Name}`}>
  <ProductTabNav productId={id} currentTab="files" productName={product.Name} />

  {error && <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>}

  <div class="space-y-6">

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100">
        <h2 class="font-semibold text-gray-800">Downloadable Files</h2>
        <p class="text-xs text-gray-400 mt-0.5">Priority 1 = default file. Categories: Download, Manual, Design Drawings, Spec Image, Price List.</p>
      </div>

      {files.length === 0 ? (
        <p class="px-5 py-8 text-center text-sm text-gray-400">No files attached.</p>
      ) : (
        <table class="w-full text-sm">
          <thead class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
            <tr>
              <th class="px-5 py-3 text-left">Filename</th>
              <th class="px-5 py-3 text-left">Category</th>
              <th class="px-5 py-3 text-left">Title</th>
              <th class="px-5 py-3 text-center w-20">Priority</th>
              <th class="px-5 py-3"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {files.map(f => (
              <tr class="hover:bg-gray-50">
                <td class="px-5 py-3 text-xs font-mono text-gray-600 truncate max-w-xs">
                  {f.filename ? (
                    <a href={f.filename} target="_blank" rel="noopener" class="text-blue-600 hover:underline">
                      {f.filename.split("/").pop()}
                    </a>
                  ) : "—"}
                </td>
                <td class="px-5 py-3 text-xs text-gray-500">{FILE_CATEGORIES[f.category_id] ?? f.category_id}</td>
                <td class="px-5 py-3 text-sm text-gray-700">{f.description ?? "—"}</td>
                <td class="px-5 py-3 text-center text-sm">{f.priority}</td>
                <td class="px-5 py-3 text-right whitespace-nowrap">
                  <a href={`?edit=${f.file_id}`} class="text-xs text-blue-600 hover:underline mr-3">Edit</a>
                  <form method="post" class="inline" onsubmit="return confirm('Delete this file record?')">
                    <input type="hidden" name="action" value="delete" />
                    <input type="hidden" name="file_id" value={f.file_id} />
                    <button type="submit" class="text-xs text-red-500 hover:underline">Delete</button>
                  </form>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}

      {editFileId > 0 && (() => {
        const f = files.find(x => x.file_id === editFileId);
        if (!f) return null;
        return (
          <div class="px-5 py-4 border-t border-gray-100 bg-blue-50">
            <p class="text-xs font-medium text-blue-800 mb-3">Editing file #{editFileId}</p>
            <form method="post" class="flex gap-4 items-end flex-wrap">
              <input type="hidden" name="action" value="update" />
              <input type="hidden" name="file_id" value={f.file_id} />
              <div>
                <label class="block text-xs text-gray-600 mb-1">Category</label>
                <select name="category_id" class="border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">
                  {cats.map(([catId, catName]) => (
                    <option value={catId} selected={f.category_id === parseInt(catId)}>{catName}</option>
                  ))}
                </select>
              </div>
              <div>
                <label class="block text-xs text-gray-600 mb-1">Title / Description</label>
                <input type="text" name="description" value={f.description ?? ""} maxlength="100"
                       class="border border-gray-300 rounded px-3 py-1.5 text-sm w-48 focus:outline-none focus:ring-1 focus:ring-blue-400" />
              </div>
              <div>
                <label class="block text-xs text-gray-600 mb-1">Priority</label>
                <input type="number" name="priority" value={f.priority} min="1"
                       class="border border-gray-300 rounded px-3 py-1.5 text-sm w-20 focus:outline-none focus:ring-1 focus:ring-blue-400" />
              </div>
              <button type="submit" class="bg-blue-600 text-white px-4 py-1.5 rounded text-sm hover:bg-blue-700">Save</button>
              <a href={`/admin/products/${id}/files`} class="px-4 py-1.5 rounded text-sm border border-gray-300 text-gray-600 hover:bg-gray-50">Cancel</a>
            </form>
          </div>
        );
      })()}
    </div>

    <!-- Upload -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100">
        <h2 class="font-semibold text-gray-800">Upload File</h2>
      </div>
      <form method="post" enctype="multipart/form-data" class="px-5 py-5">
        <input type="hidden" name="action" value="upload" />
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4">
          <div class="md:col-span-2">
            <label class="block text-xs text-gray-500 mb-1">File <span class="text-red-500">*</span></label>
            <input type="file" name="upload_file" required
                   class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm" />
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Category</label>
            <select name="category_id" class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">
              {cats.map(([catId, catName]) => <option value={catId}>{catName}</option>)}
            </select>
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Priority</label>
            <input type="number" name="priority" value={files.length + 1} min="1"
                   class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
          </div>
          <div class="md:col-span-4">
            <label class="block text-xs text-gray-500 mb-1">Title / Description</label>
            <input type="text" name="description" maxlength="100"
                   class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
          </div>
        </div>
        <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-blue-700">
          Upload File
        </button>
      </form>
    </div>

  </div>
</AdminLayout>
