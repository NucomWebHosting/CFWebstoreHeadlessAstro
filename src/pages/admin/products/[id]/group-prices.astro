---
export const prerender = false;
import AdminLayout from "../../../../components/layout/AdminLayout.astro";
import ProductTabNav from "../../../../components/admin/ProductTabNav.astro";
import { getProductByIdAdmin } from "../../../../lib/queries/admin";
import {
  getGroupPrices, getAvailableGroups,
  addGroupPrice, updateGroupPrice, deleteGroupPrice,
} from "../../../../lib/queries/admin-product-tabs";

const id = Number(Astro.params.id);
if (!id) return new Response(null, { status: 404 });

let error = "";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = form.get("action") as string;
  try {
    if (action === "add") {
      const groupId = parseInt(form.get("group_id") as string);
      const price   = parseFloat(form.get("price") as string);
      if (!groupId || isNaN(price)) throw new Error("Group and price are required.");
      await addGroupPrice(id, groupId, price);
    } else if (action === "update") {
      const grpPriceId = parseInt(form.get("grp_price_id") as string);
      const price      = parseFloat(form.get("price") as string);
      await updateGroupPrice(grpPriceId, price);
    } else if (action === "delete") {
      await deleteGroupPrice(parseInt(form.get("grp_price_id") as string));
    }
    return Astro.redirect(`/admin/products/${id}/group-prices`);
  } catch (e: unknown) {
    error = e instanceof Error ? e.message : String(e);
  }
}

const product = await getProductByIdAdmin(id);
if (!product) return new Response(null, { status: 404 });

const groupPrices     = await getGroupPrices(id);
const availableGroups = await getAvailableGroups(id);
const editId = parseInt(Astro.url.searchParams.get("edit") ?? "0") || 0;
---

<AdminLayout title={`Group Prices — ${product.Name}`}>
  <ProductTabNav productId={id} currentTab="group-prices" productName={product.Name} />

  {error && <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>}

  <div class="max-w-lg space-y-6">

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100">
        <h2 class="font-semibold text-gray-800">Group Prices</h2>
        <p class="text-xs text-gray-400 mt-0.5">Override the base price for specific customer groups.</p>
      </div>

      {groupPrices.length === 0 ? (
        <p class="px-5 py-8 text-center text-sm text-gray-400">No group prices set.</p>
      ) : (
        <table class="w-full text-sm">
          <thead class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
            <tr>
              <th class="px-5 py-3 text-left">Group</th>
              <th class="px-5 py-3 text-right">Price</th>
              <th class="px-5 py-3"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {groupPrices.map(gp => (
              <tr class="hover:bg-gray-50">
                <td class="px-5 py-3 font-medium text-gray-800">{gp.GroupName}</td>
                <td class="px-5 py-3 text-right font-mono text-sm">
                  {editId === gp.GrpPrice_ID ? (
                    <form method="post" class="flex justify-end gap-2">
                      <input type="hidden" name="action" value="update" />
                      <input type="hidden" name="grp_price_id" value={gp.GrpPrice_ID} />
                      <input type="number" name="price" step="0.01" min="0" value={gp.Price}
                             class="w-28 border border-gray-300 rounded px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
                      <button type="submit" class="px-3 py-1 bg-blue-600 text-white text-xs rounded hover:bg-blue-700">Save</button>
                      <a href={`/admin/products/${id}/group-prices`} class="px-3 py-1 border border-gray-300 text-gray-600 text-xs rounded hover:bg-gray-50">Cancel</a>
                    </form>
                  ) : (
                    `$${gp.Price.toFixed(2)}`
                  )}
                </td>
                <td class="px-5 py-3 text-right whitespace-nowrap">
                  {editId !== gp.GrpPrice_ID && (
                    <>
                      <a href={`?edit=${gp.GrpPrice_ID}`} class="text-xs text-blue-600 hover:underline mr-3">Edit</a>
                      <form method="post" class="inline" onsubmit="return confirm('Remove this group price?')">
                        <input type="hidden" name="action" value="delete" />
                        <input type="hidden" name="grp_price_id" value={gp.GrpPrice_ID} />
                        <button type="submit" class="text-xs text-red-500 hover:underline">Remove</button>
                      </form>
                    </>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}

      {availableGroups.length > 0 && (
        <div class="px-5 py-4 border-t border-gray-100">
          <p class="text-xs font-medium text-gray-600 mb-3">Add Group Price</p>
          <form method="post" class="flex gap-3 items-end flex-wrap">
            <input type="hidden" name="action" value="add" />
            <div>
              <label class="block text-xs text-gray-500 mb-1">Group</label>
              <select name="group_id" class="border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">
                {availableGroups.map(g => <option value={g.Group_ID}>{g.Name}</option>)}
              </select>
            </div>
            <div>
              <label class="block text-xs text-gray-500 mb-1">Price ($)</label>
              <input type="number" name="price" step="0.01" min="0" required
                     class="w-28 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
            </div>
            <button type="submit" class="bg-blue-600 text-white px-4 py-1.5 rounded text-sm hover:bg-blue-700">Add</button>
          </form>
        </div>
      )}
    </div>

  </div>
</AdminLayout>
