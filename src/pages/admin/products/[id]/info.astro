---
export const prerender = false;
import AdminLayout from "../../../../components/layout/AdminLayout.astro";
import ProductTabNav from "../../../../components/admin/ProductTabNav.astro";
import { getProductByIdAdmin } from "../../../../lib/queries/admin";
import {
  getInfoFields, saveInfoFields,
  getCustomFieldValues, saveCustomFieldValues,
  getProductTypeSpecs, saveSpecValues,
} from "../../../../lib/queries/admin-product-tabs";

const id = Number(Astro.params.id);
if (!id) return new Response(null, { status: 404 });

let error = "";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = form.get("action") as string;

  try {
    if (action === "save_google") {
      await saveInfoFields(id, form);
    } else if (action === "save_custom_fields") {
      const fieldIds = (form.get("custom_field_ids") as string ?? "").split(",").filter(Boolean);
      const values = fieldIds.map(cid => ({
        customId: parseInt(cid),
        value: ((form.get(`cf_${cid}`) as string) ?? "").trim(),
      }));
      await saveCustomFieldValues(id, values);
    } else if (action === "save_specs") {
      const specIds = (form.get("spec_ids") as string ?? "").split(",").filter(Boolean);
      const values = specIds.map(sid => ({
        specId: parseInt(sid),
        value: ((form.get(`spec_${sid}`) as string) ?? "").trim(),
      }));
      await saveSpecValues(id, values);
    }
    return Astro.redirect(`/admin/products/${id}/info?saved=${action}`);
  } catch (e: unknown) {
    error = e instanceof Error ? e.message : String(e);
  }
}

const product = await getProductByIdAdmin(id);
if (!product) return new Response(null, { status: 404 });

const [info, customFields, specs] = await Promise.all([
  getInfoFields(id),
  getCustomFieldValues(id),
  getProductTypeSpecs(id),
]);

const saved = Astro.url.searchParams.get("saved");
const successMsg = saved === "save_google" ? "Google fields saved."
  : saved === "save_custom_fields" ? "Custom fields saved."
  : saved === "save_specs" ? "Specifications saved."
  : "";
---

<AdminLayout title={`Info — ${product.Name}`}>
  <ProductTabNav productId={id} currentTab="info" productName={product.Name} />

  {error && <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>}
  {successMsg && <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">{successMsg}</div>}

  <div class="space-y-6 max-w-2xl">

    <!-- Google Shopping -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100">
        <h2 class="font-semibold text-gray-800">Google Shopping</h2>
      </div>
      <form method="post" class="p-6 space-y-4">
        <input type="hidden" name="action" value="save_google" />

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Google Product Category</label>
            <input type="text" name="google_category" value={info?.google_product_category ?? ""}
                   class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Brand / Manufacturer</label>
            <input type="text" name="google_brand" value={info?.google_brand ?? ""}
                   class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Condition</label>
          <div class="flex gap-4 text-sm">
            {["new", "used", "refurbished"].map(c => (
              <label class="flex items-center gap-1.5 cursor-pointer capitalize">
                <input type="radio" name="google_condition" value={c} checked={info?.google_condition === c} />
                {c}
              </label>
            ))}
          </div>
        </div>

        <div class="grid grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Gender</label>
            <div class="flex gap-4 text-sm flex-wrap">
              {[["", "N/A"], ["male", "Male"], ["female", "Female"]].map(([val, lbl]) => (
                <label class="flex items-center gap-1.5 cursor-pointer">
                  <input type="radio" name="google_gender" value={val} checked={info?.google_gender === val || (!info?.google_gender && val === "")} />
                  {lbl}
                </label>
              ))}
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Age Group</label>
            <div class="flex gap-4 text-sm flex-wrap">
              {[["", "N/A"], ["adult", "Adult"], ["kids", "Kids"], ["toddler", "Toddler"], ["infant", "Infant"], ["newborn", "Newborn"]].map(([val, lbl]) => (
                <label class="flex items-center gap-1.5 cursor-pointer">
                  <input type="radio" name="google_age_group" value={val} checked={info?.google_age === val || (!info?.google_age && val === "")} />
                  {lbl}
                </label>
              ))}
            </div>
          </div>
        </div>

        <button type="submit" class="bg-blue-600 text-white px-5 py-2 rounded-lg text-sm font-semibold hover:bg-blue-700">
          Save Google Fields
        </button>
      </form>
    </div>

    <!-- Custom Fields -->
    {customFields.length > 0 && (
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100">
          <h2 class="font-semibold text-gray-800">Custom Fields</h2>
        </div>
        <form method="post" class="p-6 space-y-4">
          <input type="hidden" name="action" value="save_custom_fields" />
          <input type="hidden" name="custom_field_ids" value={customFields.map(f => f.Custom_ID).join(",")} />
          {customFields.map(f => (
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">{f.Custom_Name ?? `Field ${f.Custom_ID}`}</label>
              <input type="text" name={`cf_${f.Custom_ID}`} value={f.CustomInfo ?? ""} maxlength="150"
                     class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
            </div>
          ))}
          <button type="submit" class="bg-blue-600 text-white px-5 py-2 rounded-lg text-sm font-semibold hover:bg-blue-700">
            Save Custom Fields
          </button>
        </form>
      </div>
    )}

    <!-- Product Type Specifications -->
    {specs.length > 0 && (
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100">
          <h2 class="font-semibold text-gray-800">Product Specifications</h2>
        </div>
        <form method="post" class="p-6 space-y-4">
          <input type="hidden" name="action" value="save_specs" />
          <input type="hidden" name="spec_ids" value={specs.filter(s => !s.IsTitle).map(s => s.ProdTypeSpec_ID).join(",")} />
          {specs.map(s => s.IsTitle ? (
            <h3 class="text-sm font-semibold text-gray-700 border-b border-gray-100 pb-1 mt-2">{s.Name}</h3>
          ) : (
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">{s.Name}</label>
              <input type="text" name={`spec_${s.ProdTypeSpec_ID}`} value={s.SpecValue ?? ""} maxlength="150"
                     class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
            </div>
          ))}
          <button type="submit" class="bg-blue-600 text-white px-5 py-2 rounded-lg text-sm font-semibold hover:bg-blue-700">
            Save Specifications
          </button>
        </form>
      </div>
    )}

    {customFields.length === 0 && specs.length === 0 && (
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm px-6 py-8 text-center text-sm text-gray-400">
        No custom fields or specifications are defined. Set up <a href="/admin/custom-fields" class="text-blue-600 hover:underline">Custom Fields</a>
        or assign a <a href="/admin/product-filters" class="text-blue-600 hover:underline">Product Filter type</a> to this product on the Display tab.
      </div>
    )}

  </div>
</AdminLayout>
