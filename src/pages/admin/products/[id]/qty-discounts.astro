---
export const prerender = false;
import AdminLayout from "../../../../components/layout/AdminLayout.astro";
import ProductTabNav from "../../../../components/admin/ProductTabNav.astro";
import { getProductByIdAdmin } from "../../../../lib/queries/admin";
import { getQtyDiscounts, addQtyDiscount, deleteQtyDiscount } from "../../../../lib/queries/admin-product-tabs";

const id = Number(Astro.params.id);
if (!id) return new Response(null, { status: 404 });

let error = "";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = form.get("action") as string;
  try {
    if (action === "add") {
      await addQtyDiscount(id, {
        wholesale:   form.get("wholesale")    === "1",
        quantFrom:   parseInt(form.get("quant_from")    as string) || 1,
        quantTo:     parseInt(form.get("quant_to")      as string) || 0,
        discountPer: parseFloat(form.get("discount_per") as string) || 0,
        display:     form.get("display")      === "1",
        type:        form.get("disc_type")    === "1",
      });
    } else if (action === "delete") {
      await deleteQtyDiscount(parseInt(form.get("disc_id") as string));
    }
    return Astro.redirect(`/admin/products/${id}/qty-discounts`);
  } catch (e: unknown) {
    error = e instanceof Error ? e.message : String(e);
  }
}

const product  = await getProductByIdAdmin(id);
if (!product) return new Response(null, { status: 404 });

const discounts   = await getQtyDiscounts(id);
const retail      = discounts.filter(d => !d.Wholesale);
const wholesale   = discounts.filter(d => d.Wholesale);
---

<AdminLayout title={`Qty Discounts — ${product.Name}`}>
  <ProductTabNav productId={id} currentTab="qty-discounts" productName={product.Name} />

  {error && <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>}

  <div class="max-w-2xl space-y-6">

    {[{ label: "Retail", rows: retail, wholesale: false }, { label: "Wholesale", rows: wholesale, wholesale: true }].map(({ label, rows, wholesale: ws }) => (
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-5 py-4 border-b border-gray-100">
          <h2 class="font-semibold text-gray-800">{label} Discounts</h2>
        </div>

        {rows.length === 0 ? (
          <p class="px-5 py-6 text-center text-sm text-gray-400">No {label.toLowerCase()} discounts.</p>
        ) : (
          <table class="w-full text-sm">
            <thead class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
              <tr>
                <th class="px-5 py-3 text-left">Qty From</th>
                <th class="px-5 py-3 text-left">Qty To</th>
                <th class="px-5 py-3 text-right">Amount</th>
                <th class="px-5 py-3 text-center">Type</th>
                <th class="px-5 py-3 text-center">Display</th>
                <th class="px-5 py-3"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {rows.map(d => (
                <tr class="hover:bg-gray-50">
                  <td class="px-5 py-3">{d.QuantFrom}</td>
                  <td class="px-5 py-3">{d.QuantTo === 0 ? "∞" : d.QuantTo}</td>
                  <td class="px-5 py-3 text-right font-mono">${d.DiscountPer.toFixed(2)}</td>
                  <td class="px-5 py-3 text-center text-xs text-gray-500">{d.Type ? "Price Per" : "Discount Per"}</td>
                  <td class="px-5 py-3 text-center">
                    {d.Display
                      ? <span class="inline-block px-2 py-0.5 rounded-full text-xs bg-green-100 text-green-700">Yes</span>
                      : <span class="inline-block px-2 py-0.5 rounded-full text-xs bg-gray-100 text-gray-500">No</span>
                    }
                  </td>
                  <td class="px-5 py-3 text-right">
                    <form method="post" class="inline" onsubmit="return confirm('Remove this discount tier?')">
                      <input type="hidden" name="action" value="delete" />
                      <input type="hidden" name="disc_id" value={d.ProdDisc_ID} />
                      <button type="submit" class="text-xs text-red-500 hover:underline">Remove</button>
                    </form>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}

        <div class="px-5 py-4 border-t border-gray-100">
          <p class="text-xs font-medium text-gray-600 mb-3">Add {label} Tier</p>
          <form method="post" class="grid grid-cols-2 gap-3">
            <input type="hidden" name="action" value="add" />
            <input type="hidden" name="wholesale" value={ws ? "1" : "0"} />
            <div>
              <label class="block text-xs text-gray-500 mb-1">Qty From</label>
              <input type="number" name="quant_from" min="1" required
                     class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
            </div>
            <div>
              <label class="block text-xs text-gray-500 mb-1">Qty To <span class="text-gray-400">(0 = unlimited)</span></label>
              <input type="number" name="quant_to" min="0" value="0"
                     class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
            </div>
            <div>
              <label class="block text-xs text-gray-500 mb-1">Amount ($)</label>
              <input type="number" name="discount_per" step="0.01" min="0" required
                     class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
            </div>
            <div>
              <label class="block text-xs text-gray-500 mb-1">Type</label>
              <select name="disc_type" class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">
                <option value="0">Discount Per Item</option>
                <option value="1">Price Per Item</option>
              </select>
            </div>
            <div>
              <label class="block text-xs text-gray-500 mb-1">Display?</label>
              <select name="display" class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">
                <option value="1">Yes</option>
                <option value="0">No</option>
              </select>
            </div>
            <div class="flex items-end">
              <button type="submit" class="bg-blue-600 text-white px-4 py-1.5 rounded text-sm hover:bg-blue-700">Add Tier</button>
            </div>
          </form>
        </div>
      </div>
    ))}

  </div>
</AdminLayout>
