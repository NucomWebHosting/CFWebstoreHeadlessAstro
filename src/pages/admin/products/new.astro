---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import ProductForm from "../../../components/admin/ProductForm.astro";
import { createProduct } from "../../../lib/queries/admin";
import {
  getCategoryPicklist,
  getManufacturers,
  getProductTypes,
  saveProductCategories,
} from "../../../lib/queries/admin-product-tabs";

let error = "";

if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  try {
    const newId = await createProduct(data);
    const catIds = data.getAll("CID_list").map(v => parseInt(v as string)).filter(Boolean);
    await saveProductCategories(newId, catIds);
    return Astro.redirect(`/admin/products/${newId}?saved=1`);
  } catch (e) {
    error = e instanceof Error ? e.message : "Failed to create product.";
  }
}

const [categories, manufacturers, productTypes] = await Promise.all([
  getCategoryPicklist(),
  getManufacturers(),
  getProductTypes(),
]);
---
<AdminLayout title="New Product">
  {error && (
    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
  )}
  <ProductForm
    action="/admin/products/new"
    cancelHref="/admin/products"
    categories={categories}
    selectedCatIds={[]}
    manufacturers={manufacturers}
    productTypes={productTypes}
  />
</AdminLayout>
