---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import {
  getSubscriptionSettings,
  saveSubscriptionSettings,
} from "../../../lib/queries/admin-subscriptions";

let saved = false;
let error = "";

if (Astro.request.method === "POST") {
  const d = await Astro.request.formData();
  try {
    await saveSubscriptionSettings({
      Free_shipping:     d.get("Free_shipping") === "1",
      flat_rate:         parseFloat(d.get("flat_rate") as string) || 0,
      shipping_type:     (d.get("shipping_type") as string) ?? "",
      shippingmethod_id: parseInt(d.get("shippingmethod_id") as string) || null,
    });
  } catch (e: unknown) {
    error = e instanceof Error ? e.message : String(e);
  }
  if (!error) return Astro.redirect("/admin/settings/subscriptions?saved=1");
}

saved = Astro.url.searchParams.get("saved") === "1";

const settings = await getSubscriptionSettings();
---

<AdminLayout title="Product Subscription Settings">

  <div class="mb-5">
    <a href="/admin/subscriptions" class="text-sm text-blue-600 hover:underline">← Product Subscriptions</a>
  </div>

  {saved && (
    <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">Saved.</div>
  )}
  {error && (
    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
  )}

  {!settings ? (
    <div class="rounded-lg bg-yellow-50 border border-yellow-200 px-4 py-3 text-sm text-yellow-700">
      No subscription settings record found (Subscription_Settings WHERE ID = 1).
    </div>
  ) : (
    <form method="post" class="max-w-xl space-y-6">

      <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-5 py-4 border-b border-gray-100">
          <h2 class="font-semibold text-gray-800">Shipping</h2>
        </div>
        <div class="px-5 py-5 space-y-5">

          <fieldset>
            <legend class="block text-sm font-medium text-gray-700 mb-2">Free Shipping on Subscriptions?</legend>
            <div class="flex gap-6 text-sm">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="Free_shipping" value="1"
                       checked={settings.Free_shipping}
                       class="accent-blue-600" /> Yes
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="Free_shipping" value="0"
                       checked={!settings.Free_shipping}
                       class="accent-blue-600" /> No
              </label>
            </div>
          </fieldset>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              Flat Rate Shipping Amount ($)
            </label>
            <input type="number" name="flat_rate" step="0.01" min="0"
                   value={Number(settings.flat_rate).toFixed(2)}
                   class="w-40 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
            <p class="text-xs text-gray-400 mt-1">Used when Free Shipping is off and no carrier rate is configured. Set to 0 to disable.</p>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Shipping Type</label>
            <select name="shipping_type"
                    class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">
              <option value=""     selected={!settings.shipping_type}>— None —</option>
              <option value="Easypost" selected={settings.shipping_type === "Easypost"}>Easypost</option>
              <option value="FlatRate" selected={settings.shipping_type === "FlatRate"}>Flat Rate</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Shipping Method ID</label>
            <input type="number" name="shippingmethod_id" min="0"
                   value={settings.shippingmethod_id ?? ""}
                   placeholder="Leave blank for default"
                   class="w-40 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
            <p class="text-xs text-gray-400 mt-1">Specific carrier method to use for subscription orders. Leave blank to use the default.</p>
          </div>

        </div>
      </div>

      <button type="submit"
              class="bg-blue-600 text-white px-5 py-2 rounded text-sm font-medium hover:bg-blue-700">
        Save Settings
      </button>

    </form>
  )}

</AdminLayout>
