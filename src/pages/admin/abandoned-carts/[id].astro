---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import { getCartDetail, updateCart, markAbandoned } from "../../../lib/queries/admin-abandoned-carts";

const id = Astro.params.id ?? "";
if (!id) return new Response(null, { status: 404 });

if (Astro.request.method === "POST") {
  const d = await Astro.request.formData();
  const action = (d.get("_action") as string) ?? "";

  if (action === "update") {
    await updateCart(id, {
      Contacted_by_phone: d.get("Contacted_by_phone") === "1",
      Notes: (d.get("Notes") as string ?? "").slice(0, 4000),
    });
  } else if (action === "mark-contacted") {
    await markAbandoned(id);
  }
  return Astro.redirect(`/admin/abandoned-carts/${id}?saved=1`);
}

const { customer: c, order: o, items, shipTo } = await getCartDetail(id);

if (!c) return new Response(`Cart ${id} not found.`, { status: 404, headers: { "content-type": "text/plain" } });

const saved = Astro.url.searchParams.get("saved") === "1";

function addrLines(r: { Firstname?: string|null; Lastname?: string|null; Company?: string|null;
  Address1?: string|null; Address2?: string|null; City?: string|null; State?: string|null;
  State2?: string|null; Zip?: string|null; Country?: string|null; Phone?: string|null; Email?: string|null }) {
  const lines: string[] = [];
  const name = [r.Firstname, r.Lastname].filter(Boolean).join(" ");
  if (name)        lines.push(name);
  if (r.Company)   lines.push(r.Company);
  if (r.Address1)  lines.push(r.Address1);
  if (r.Address2)  lines.push(r.Address2);
  const city = [r.City, [r.State !== "Unlisted" ? r.State : r.State2, r.Zip].filter(Boolean).join(" ")].filter(Boolean).join(", ");
  if (city) lines.push(city);
  if (r.Country && !r.Country.toLowerCase().includes("united states")) {
    lines.push(r.Country.split("^").pop() ?? r.Country);
  }
  if (r.Phone) lines.push(`Phone: ${r.Phone}`);
  if (r.Email) lines.push(r.Email);
  return lines;
}

const STEP_COLORS: Record<string, string> = {
  cart: "bg-gray-100 text-gray-600",
  checkin: "bg-blue-100 text-blue-700",
  terms: "bg-blue-100 text-blue-700",
  address: "bg-indigo-100 text-indigo-700",
  shipping: "bg-purple-100 text-purple-700",
  payment: "bg-amber-100 text-amber-700",
  paypal: "bg-amber-100 text-amber-700",
  reciept: "bg-green-100 text-green-700",
  error: "bg-red-100 text-red-700",
};
const stepColor = STEP_COLORS[c.step ?? ""] ?? "bg-gray-100 text-gray-600";
---

<AdminLayout title={`Abandoned Cart ${id}`}>

  <div class="flex items-center gap-3 mb-5">
    <a href="/admin/abandoned-carts" class="text-sm text-blue-600 hover:underline">← Back to Abandoned Carts</a>
  </div>

  {saved && (
    <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">Saved.</div>
  )}

  <!-- Header row -->
  <div class="flex items-center justify-between mb-5 flex-wrap gap-3">
    <div>
      <h2 class="text-lg font-semibold text-gray-800 font-mono">Cart #{id}</h2>
      <div class="text-sm text-gray-500 mt-0.5">
        {new Date(c.DateAdded).toLocaleString()}
        {c.step && <span class={`ml-2 text-xs px-1.5 py-0.5 rounded ${stepColor}`}>{c.step}</span>}
      </div>
    </div>
    <div class="flex gap-2 flex-wrap">
      {o?.User_ID && (
        <a href={`/admin/users/${o.User_ID}`}
           class="px-4 py-1.5 rounded text-sm border border-blue-300 text-blue-600 hover:bg-blue-50">
          User Summary
        </a>
      )}
      {c.Email && (
        <form method="post">
          <input type="hidden" name="_action" value="mark-contacted" />
          <button type="submit"
                  class="px-4 py-1.5 rounded text-sm border border-amber-300 text-amber-700 hover:bg-amber-50">
            Mark as Contacted
          </button>
        </form>
      )}
    </div>
  </div>

  <!-- Addresses -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-5">
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4">
      <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Bill To</h3>
      {addrLines(c).map(line => (
        line.includes("@")
          ? <p class="text-sm"><a href={`mailto:${line}`} class="text-blue-600 hover:underline">{line}</a></p>
          : <p class="text-sm text-gray-700">{line}</p>
      ))}
      {!c.Firstname && !c.Email && <p class="text-sm text-gray-400 italic">No billing info.</p>}
    </div>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4">
      <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Ship To</h3>
      {shipTo
        ? addrLines(shipTo).map(line => (
            line.includes("@")
              ? <p class="text-sm"><a href={`mailto:${line}`} class="text-blue-600 hover:underline">{line}</a></p>
              : <p class="text-sm text-gray-700">{line}</p>
          ))
        : <p class="text-sm text-gray-400 italic">No ship-to address.</p>
      }
    </div>
  </div>

  <!-- Order info -->
  {o && (o.ShipType || o.Comments || o.Giftcard || o.OrderTotal != null) && (
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 mb-5 grid grid-cols-2 md:grid-cols-4 gap-3 text-sm">
      {o.ShipType && (
        <div>
          <span class="text-xs text-gray-500">Ship By</span>
          <p class="text-gray-700">{o.ShipType}</p>
        </div>
      )}
      {o.OrderTotal != null && (
        <div>
          <span class="text-xs text-gray-500">Order Total</span>
          <p class="text-gray-700 font-semibold">${Number(o.OrderTotal).toFixed(2)}</p>
        </div>
      )}
      {o.Comments && (
        <div class="col-span-2">
          <span class="text-xs text-gray-500">Comments</span>
          <p class="text-gray-700">{o.Comments}</p>
        </div>
      )}
      {o.Giftcard && (
        <div>
          <span class="text-xs text-gray-500">Gift Card</span>
          <p class="text-gray-700">{o.Giftcard}</p>
        </div>
      )}
    </div>
  )}

  <!-- Cart items -->
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm mb-5 overflow-hidden">
    <div class="px-4 py-3 border-b border-gray-100">
      <h3 class="text-sm font-semibold text-gray-700">Cart Items ({items.length})</h3>
    </div>
    {items.length === 0 ? (
      <p class="px-4 py-6 text-sm text-gray-400 text-center">Cart is empty.</p>
    ) : (
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-100">
          <tr>
            <th class="px-4 py-2 text-left font-medium text-gray-500">Product</th>
            <th class="px-4 py-2 text-center font-medium text-gray-500">Qty</th>
            <th class="px-4 py-2 text-right font-medium text-gray-500">Unit Price</th>
            <th class="px-4 py-2 text-right font-medium text-gray-500">Ext</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          {items.map(item => {
            const unit = item.Price + item.OptPrice - item.QuantDisc;
            const ext  = unit * item.Quantity;
            return (
              <tr>
                <td class="px-4 py-2.5">
                  <p class="font-medium text-gray-800">{item.ProductName ?? `Product #${item.Product_ID}`}</p>
                  {item.SKU && <p class="text-xs text-gray-400">SKU: {item.SKU}</p>}
                  {item.Options && <p class="text-xs text-gray-500 italic">{item.Options.split(":").pop()}</p>}
                  {item.Addons  && <p class="text-xs text-gray-500">{item.Addons}</p>}
                </td>
                <td class="px-4 py-2.5 text-center">{item.Quantity}</td>
                <td class="px-4 py-2.5 text-right">${unit.toFixed(2)}</td>
                <td class="px-4 py-2.5 text-right font-medium">${ext.toFixed(2)}</td>
              </tr>
            );
          })}
        </tbody>
        {o?.OrderTotal != null && (
          <tfoot class="border-t border-gray-200 bg-gray-50">
            <tr>
              <td colspan="3" class="px-4 py-2 text-right text-sm font-semibold text-gray-700">Order Total</td>
              <td class="px-4 py-2 text-right text-sm font-semibold text-gray-800">${Number(o.OrderTotal).toFixed(2)}</td>
            </tr>
          </tfoot>
        )}
      </table>
    )}
  </div>

  <!-- Admin update form -->
  <form method="post" class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 space-y-4 max-w-2xl">
    <input type="hidden" name="_action" value="update" />
    <h3 class="text-sm font-semibold text-gray-700 border-b border-gray-100 pb-2">Admin Notes</h3>

    <div class="grid grid-cols-3 gap-3 items-start">
      <span class="text-sm text-gray-600 font-medium text-right pt-1">Contacted by Phone</span>
      <div class="col-span-2 flex gap-4 pt-1">
        <label class="flex items-center gap-2 text-sm">
          <input type="radio" name="Contacted_by_phone" value="1" checked={c.Contacted_by_phone} /> Yes
        </label>
        <label class="flex items-center gap-2 text-sm">
          <input type="radio" name="Contacted_by_phone" value="0" checked={!c.Contacted_by_phone} /> No
        </label>
      </div>
    </div>

    <div class="grid grid-cols-3 gap-3 items-start">
      <label class="text-sm text-gray-600 font-medium text-right pt-1">Admin Notes</label>
      <textarea name="Notes" rows={5}
                class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">{c.Notes ?? ""}</textarea>
    </div>

    <div class="flex items-center gap-3">
      <button type="submit" class="bg-blue-600 text-white px-5 py-2 rounded text-sm hover:bg-blue-700">
        Update Cart
      </button>
      <div class="flex gap-3 text-xs text-gray-400 ml-2">
        <span>Abandoned: <strong class={c.Abandoned ? "text-amber-600" : "text-gray-600"}>{c.Abandoned ? "Yes" : "No"}</strong></span>
        <span>Contacted: <strong class={c.Contacted_by_phone ? "text-blue-600" : "text-gray-600"}>{c.Contacted_by_phone ? "Yes" : "No"}</strong></span>
      </div>
    </div>
  </form>

</AdminLayout>
