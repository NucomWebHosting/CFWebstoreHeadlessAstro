---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import { getDealerSettings, saveDealerSettings } from "../../../lib/queries/admin-dealers";

let error = "";

if (Astro.request.method === "POST") {
  const d = await Astro.request.formData();
  const g = (k: string) => (d.get(k) as string ?? "").trim();
  const bit = (k: string) => g(k) === "1";

  try {
    await saveDealerSettings({
      GoogleAPIKey:        g("GoogleAPIKey"),
      show_country_search: bit("show_country_search"),
      Show_Category:       bit("Show_Category"),
      Show_Google:         bit("Show_Google"),
      Show_AllPoints:      bit("Show_AllPoints"),
    });
    return Astro.redirect("/admin/dealers/settings?saved=1");
  } catch (e: unknown) {
    error = e instanceof Error ? e.message : String(e);
  }
}

const saved = Astro.url.searchParams.get("saved") === "1";
const s = await getDealerSettings();
---

<AdminLayout title="Dealer Settings">
  <div class="flex items-center gap-3 mb-5">
    <a href="/admin/dealers" class="text-sm text-blue-600 hover:underline">← Back to Dealers</a>
  </div>

  <!-- Sub-nav -->
  <div class="flex gap-2 mb-5 text-sm">
    <a href="/admin/dealers" class="px-3 py-1.5 rounded text-slate-400 hover:bg-slate-800 hover:text-white">Dealers</a>
    <a href="/admin/dealers/categories" class="px-3 py-1.5 rounded text-slate-400 hover:bg-slate-800 hover:text-white">Categories</a>
    <a href="/admin/dealers/settings" class="px-3 py-1.5 rounded bg-slate-700 text-white font-medium">Settings</a>
  </div>

  {saved && (
    <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">Saved.</div>
  )}
  {error && (
    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
  )}

  <form method="post" class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-5 max-w-2xl">

    <h2 class="text-sm font-semibold text-gray-700 border-b border-gray-100 pb-2">Google Maps</h2>

    <div class="grid grid-cols-3 gap-3 items-start">
      <label class="text-sm text-gray-600 font-medium text-right pt-1">Google API Key</label>
      <div class="col-span-2">
        <input type="text" name="GoogleAPIKey" value={s?.GoogleAPIKey ?? ""} maxlength="100"
               class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
        <p class="text-xs text-gray-400 mt-1">
          Required for geocoding and the dealer map. Sign up at
          <a href="https://developers.google.com/maps/documentation/geocoding/get-api-key"
             target="_blank" rel="noopener" class="text-blue-500 hover:underline">
            Google Maps Platform
          </a>.
        </p>
      </div>
    </div>

    {[
      { name: "show_country_search", label: "Show Countries", desc: "Used if you have foreign dealers.", val: s?.show_country_search ?? false },
      { name: "Show_Category",       label: "Show Category",  desc: "Show dealer categories as part of the search form.", val: s?.Show_Category ?? false },
      { name: "Show_Google",         label: "Show Google Maps", desc: "Show search results on a small Google Map.", val: s?.Show_Google ?? false },
      { name: "Show_AllPoints",      label: "Show Big Google Map", desc: "Show all map points on a large Google Map.", val: s?.Show_AllPoints ?? false },
    ].map(({ name, label, desc, val }) => (
      <div class="grid grid-cols-3 gap-3 items-start">
        <span class="text-sm text-gray-600 font-medium text-right pt-1">{label}</span>
        <div class="col-span-2">
          <div class="flex gap-4">
            <label class="flex items-center gap-2 text-sm">
              <input type="radio" name={name} value="1" checked={val} /> Yes
            </label>
            <label class="flex items-center gap-2 text-sm">
              <input type="radio" name={name} value="0" checked={!val} /> No
            </label>
          </div>
          <p class="text-xs text-gray-400 mt-0.5">{desc}</p>
        </div>
      </div>
    ))}

    <div class="pt-2">
      <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded text-sm hover:bg-blue-700">
        Save Settings
      </button>
    </div>
  </form>
</AdminLayout>
