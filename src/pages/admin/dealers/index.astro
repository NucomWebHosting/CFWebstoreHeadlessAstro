---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import { getDealers, PAGE_SIZE } from "../../../lib/queries/admin-dealers";
import { getStates } from "../../../lib/queries/admin-customers";

const p = Astro.url.searchParams;

const opts = {
  name:    p.get("name")    ?? "",
  contact: p.get("contact") ?? "",
  state:   p.get("state")   ?? "",
  page:    parseInt(p.get("page") ?? "1") || 1,
};

const deleted = p.get("deleted") === "1";
const [{ rows, total }, states] = await Promise.all([
  getDealers(opts),
  getStates(),
]);
const totalPages = Math.ceil(total / PAGE_SIZE);

function filterQS(overrides: Record<string, string | number>) {
  const base = { ...opts, ...overrides };
  return Object.entries(base)
    .filter(([, v]) => String(v).length > 0)
    .map(([k, v]) => `${k}=${encodeURIComponent(v)}`)
    .join("&");
}
function pageUrl(pg: number) { return `/admin/dealers?${filterQS({ page: pg })}`; }

const windowSize = 5;
const halfW = Math.floor(windowSize / 2);
let winStart = Math.max(1, opts.page - halfW);
let winEnd   = Math.min(totalPages, winStart + windowSize - 1);
if (winEnd - winStart < windowSize - 1) winStart = Math.max(1, winEnd - windowSize + 1);
---

<AdminLayout title="Dealers">

  {deleted && (
    <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">Dealer deleted.</div>
  )}

  <!-- Sub-nav -->
  <div class="flex gap-2 mb-5 text-sm">
    <a href="/admin/dealers" class="px-3 py-1.5 rounded bg-slate-700 text-white font-medium">Dealers</a>
    <a href="/admin/dealers/categories" class="px-3 py-1.5 rounded text-slate-400 hover:bg-slate-800 hover:text-white">Categories</a>
    <a href="/admin/dealers/settings" class="px-3 py-1.5 rounded text-slate-400 hover:bg-slate-800 hover:text-white">Settings</a>
  </div>

  <!-- Filters -->
  <form method="get" action="/admin/dealers" class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 mb-5">
    <div class="flex flex-wrap gap-3 items-end">
      <div>
        <label class="block text-xs text-gray-500 mb-1">Dealer Name</label>
        <input type="text" name="name" value={opts.name} maxlength="50"
               class="w-40 border border-gray-300 rounded px-2 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Contact</label>
        <input type="text" name="contact" value={opts.contact} maxlength="50"
               class="w-36 border border-gray-300 rounded px-2 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">State</label>
        <select name="state"
                class="border border-gray-300 rounded px-2 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">
          <option value="">All</option>
          <option value="Unlisted" selected={opts.state === "Unlisted"}>Unlisted/None</option>
          {states.map(s => (
            <option value={s.Abb} selected={opts.state === s.Abb}>{s.Name} ({s.Abb})</option>
          ))}
        </select>
      </div>
      <button type="submit" class="bg-blue-600 text-white px-4 py-1.5 rounded text-sm hover:bg-blue-700">Search</button>
      <a href="/admin/dealers" class="text-xs text-blue-600 hover:underline self-end pb-2">All</a>
    </div>
  </form>

  <!-- Count + New + Pagination -->
  <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
    <div class="flex items-center gap-4">
      <span class="text-sm text-gray-500">{total.toLocaleString()} dealer{total !== 1 ? "s" : ""}</span>
      <a href="/admin/dealers/new" class="bg-blue-600 text-white px-4 py-1.5 rounded text-sm hover:bg-blue-700">
        + New Dealer
      </a>
    </div>
    {totalPages > 1 && (
      <div class="flex gap-1 text-sm">
        {opts.page > 1 && <a href={pageUrl(opts.page - 1)} class="px-2 py-1 rounded border border-gray-200 hover:bg-gray-50">‹</a>}
        {winStart > 1 && <span class="px-2 py-1 text-gray-400">…</span>}
        {Array.from({length: winEnd - winStart + 1}, (_, i) => winStart + i).map(pg => (
          <a href={pageUrl(pg)}
             class={`px-2 py-1 rounded border ${pg === opts.page ? "bg-blue-600 text-white border-blue-600" : "border-gray-200 hover:bg-gray-50"}`}>
            {pg}
          </a>
        ))}
        {winEnd < totalPages && <span class="px-2 py-1 text-gray-400">…</span>}
        {opts.page < totalPages && <a href={pageUrl(opts.page + 1)} class="px-2 py-1 rounded border border-gray-200 hover:bg-gray-50">›</a>}
      </div>
    )}
  </div>

  <!-- Table -->
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-x-auto">
    <table class="w-full text-sm whitespace-nowrap">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="px-4 py-2.5 text-left font-medium text-gray-600">ID</th>
          <th class="px-4 py-2.5 text-left font-medium text-gray-600">Dealer</th>
          <th class="px-4 py-2.5 text-left font-medium text-gray-600">Acct</th>
          <th class="px-4 py-2.5 text-left font-medium text-gray-600">Contact</th>
          <th class="px-4 py-2.5 text-left font-medium text-gray-600">Phone</th>
          <th class="px-4 py-2.5 text-left font-medium text-gray-600">Email</th>
          <th class="px-4 py-2.5 text-left font-medium text-gray-600">Website</th>
          <th class="px-4 py-2.5 text-left font-medium text-gray-600">State</th>
          <th class="px-4 py-2.5 text-center font-medium text-gray-600">Geocoded</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {rows.length === 0 && (
          <tr><td colspan="9" class="px-4 py-8 text-center text-gray-400">No records found.</td></tr>
        )}
        {rows.map(r => (
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-2.5">
              <a href={`/admin/dealers/${r.dealer_ID}`}
                 class="text-blue-600 hover:underline text-xs font-mono">
                Edit {r.dealer_ID}
              </a>
            </td>
            <td class="px-4 py-2.5 font-medium text-gray-800">{r.name}</td>
            <td class="px-4 py-2.5 text-gray-500 text-xs">{r.account_id || "—"}</td>
            <td class="px-4 py-2.5 text-gray-600">{r.contact ?? "—"}</td>
            <td class="px-4 py-2.5 text-gray-600 text-xs">{r.phone ?? "—"}</td>
            <td class="px-4 py-2.5 text-xs">
              {r.email
                ? <a href={`mailto:${r.email}`} class="text-blue-500 hover:underline">{r.email}</a>
                : "—"}
            </td>
            <td class="px-4 py-2.5 text-xs">
              {r.website
                ? <a href={`https://${r.website}/`} target="_blank" rel="noopener" class="text-blue-500 hover:underline">{r.website}</a>
                : "—"}
            </td>
            <td class="px-4 py-2.5 text-gray-500 text-xs">{r.state ?? "—"}</td>
            <td class="px-4 py-2.5 text-center">
              {r.dealer_latitude
                ? <span class="text-xs text-green-600">✓</span>
                : <span class="text-xs text-red-500 font-bold" title="Missing geocoordinates">!</span>}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  {totalPages > 1 && (
    <div class="flex justify-end mt-3 gap-1 text-sm">
      {opts.page > 1 && <a href={pageUrl(opts.page - 1)} class="px-2 py-1 rounded border border-gray-200 hover:bg-gray-50">‹</a>}
      {winStart > 1 && <span class="px-2 py-1 text-gray-400">…</span>}
      {Array.from({length: winEnd - winStart + 1}, (_, i) => winStart + i).map(pg => (
        <a href={pageUrl(pg)}
           class={`px-2 py-1 rounded border ${pg === opts.page ? "bg-blue-600 text-white border-blue-600" : "border-gray-200 hover:bg-gray-50"}`}>
          {pg}
        </a>
      ))}
      {winEnd < totalPages && <span class="px-2 py-1 text-gray-400">…</span>}
      {opts.page < totalPages && <a href={pageUrl(opts.page + 1)} class="px-2 py-1 rounded border border-gray-200 hover:bg-gray-50">›</a>}
    </div>
  )}

</AdminLayout>
