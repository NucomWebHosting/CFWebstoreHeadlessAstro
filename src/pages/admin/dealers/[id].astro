---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import {
  getDealer, updateDealer, deleteDealer,
  getDealerSettings, getDealerCategories,
  geocodeAddress, normalizeWebsite, normalizePriority, displayPriority,
} from "../../../lib/queries/admin-dealers";
import { getStates, getCountries } from "../../../lib/queries/admin-customers";

const id = parseInt(Astro.params.id ?? "0") || 0;
if (!id) return new Response(null, { status: 404 });

let error = "";
let geoWarn = "";

if (Astro.request.method === "POST") {
  const d = await Astro.request.formData();
  const g = (k: string) => (d.get(k) as string ?? "").trim();
  const bit = (k: string) => g(k) === "1";
  const action = g("_action");

  if (action === "delete") {
    await deleteDealer(id);
    return Astro.redirect("/admin/dealers?deleted=1");
  } else {
    const address1 = g("address1"), city = g("city"),
          state = g("state"), zip = g("zip");

    let lat = g("dealer_latitude_existing");
    let lng = g("dealer_longitude_existing");

    const settings = await getDealerSettings();
    const apiKey = settings?.GoogleAPIKey ?? "";
    if (apiKey) {
      const geo = await geocodeAddress(address1, city, state, zip, apiKey);
      lat = geo.lat; lng = geo.lng;
      if (geo.error) geoWarn = geo.error;
    }

    try {
      await updateDealer(id, {
        name:        g("name"),
        logo:        g("logo"),
        website:     normalizeWebsite(g("website")),
        priority:    normalizePriority(g("priority")),
        contact:     g("contact"),
        address1,
        address2:    g("address2"),
        city,
        state,
        zip,
        country:     g("country"),
        phone:       g("phone"),
        fax:         g("fax"),
        email:       g("email"),
        category_id: parseInt(g("category_id")) || 0,
        short_desc:  g("short_desc"),
        display:     bit("display"),
        account_id:  parseInt(g("account_id")) || 0,
        dealer_latitude:  lat,
        dealer_longitude: lng,
      });
      return Astro.redirect(`/admin/dealers/${id}?saved=1${geoWarn ? "&geowarn=1" : ""}`);
    } catch (e: unknown) {
      error = e instanceof Error ? e.message : String(e);
    }
  }
}

const saved    = Astro.url.searchParams.get("saved") === "1";
const geowarn  = Astro.url.searchParams.get("geowarn") === "1";

const [dealer, settings, categories, states, countries] = await Promise.all([
  getDealer(id),
  getDealerSettings(),
  getDealerCategories(),
  getStates(),
  getCountries(),
]);

if (!dealer) return new Response(`Dealer ${id} not found.`, { status: 404, headers: { "content-type": "text/plain" } });

const websiteDisplay = dealer.website
  ? (dealer.website.startsWith("http") ? dealer.website : `http://${dealer.website}`)
  : "http://";
---

<AdminLayout title={`Dealer ${id}`}>
  <div class="flex items-center gap-3 mb-5">
    <a href="/admin/dealers" class="text-sm text-blue-600 hover:underline">← Back to Dealers</a>
  </div>

  {saved && (
    <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">
      Saved.
      {geowarn && <span class="ml-2 text-amber-600">Warning: geocoding failed — coordinates may be outdated.</span>}
    </div>
  )}
  {error && (
    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
  )}

  <form method="post" class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-4 max-w-2xl">
    <input type="hidden" name="_action" value="update" />
    <input type="hidden" name="dealer_latitude_existing" value={dealer.dealer_latitude ?? ""} />
    <input type="hidden" name="dealer_longitude_existing" value={dealer.dealer_longitude ?? ""} />

    <div class="flex items-center justify-between border-b border-gray-100 pb-2">
      <h2 class="text-sm font-semibold text-gray-700">Dealer #{id}</h2>
      {dealer.account_id ? (
        <a href={`/admin/accounts/${dealer.account_id}`} class="text-xs text-blue-500 hover:underline">
          Account #{dealer.account_id}
        </a>
      ) : null}
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Company Name <span class="text-red-500">*</span></label>
      <input type="text" name="name" value={dealer.name} required
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Logo filename</label>
      <input type="text" name="logo" value={dealer.logo ?? ""} maxlength="100"
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Priority</label>
      <div class="col-span-2">
        <input type="number" name="priority" value={displayPriority(dealer.priority)} min="0" max="9999"
               class="w-24 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
        <span class="ml-2 text-xs text-gray-400">1 = highest, 0 = none</span>
      </div>
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Contact</label>
      <input type="text" name="contact" value={dealer.contact ?? ""} maxlength="150"
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Address <span class="text-red-500">*</span></label>
      <input type="text" name="address1" value={dealer.address1 ?? ""} required
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Apt / Suite</label>
      <input type="text" name="address2" value={dealer.address2 ?? ""}
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">City <span class="text-red-500">*</span></label>
      <input type="text" name="city" value={dealer.city ?? ""} required
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">State <span class="text-red-500">*</span></label>
      <select name="state" required
              class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400 w-64">
        <option value="Unlisted" selected={dealer.state === "Unlisted"}>Unlisted / None</option>
        {states.map(s => (
          <option value={s.Abb} selected={dealer.state === s.Abb}>{s.Name} ({s.Abb})</option>
        ))}
      </select>
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Zip <span class="text-red-500">*</span></label>
      <input type="text" name="zip" value={dealer.zip ?? ""} required
             class="col-span-2 w-36 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Country</label>
      <select name="country"
              class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400 w-64">
        <option value="US^United States" selected={dealer.country === "US^United States" || !dealer.country}>United States</option>
        <option value="US^United States">───────────────</option>
        {countries.map(c => {
          const val = `${c.Abbrev}^${c.Country}`;
          return <option value={val} selected={dealer.country === val}>{c.Country}</option>;
        })}
      </select>
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Phone</label>
      <input type="tel" name="phone" value={dealer.phone ?? ""} maxlength="150"
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Fax</label>
      <input type="tel" name="fax" value={dealer.fax ?? ""} maxlength="150"
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Email</label>
      <input type="email" name="email" value={dealer.email ?? ""} maxlength="150"
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Website</label>
      <input type="text" name="website" value={websiteDisplay} maxlength="150"
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Category</label>
      <select name="category_id"
              class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400 w-56">
        <option value="0" selected={!dealer.category_id}>none</option>
        {categories.map(c => (
          <option value={c.category_ID} selected={dealer.category_id === c.category_ID}>{c.name}</option>
        ))}
      </select>
    </div>

    <div class="grid grid-cols-3 gap-3 items-start">
      <label class="text-sm text-gray-600 font-medium text-right pt-1">Short Description</label>
      <textarea name="short_desc" rows={4}
                class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">{dealer.short_desc ?? ""}</textarea>
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <span class="text-sm text-gray-600 font-medium text-right">Display</span>
      <div class="col-span-2 flex gap-4">
        <label class="flex items-center gap-2 text-sm">
          <input type="radio" name="display" value="1" checked={dealer.display} /> Yes
        </label>
        <label class="flex items-center gap-2 text-sm">
          <input type="radio" name="display" value="0" checked={!dealer.display} /> No
        </label>
      </div>
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Account ID</label>
      <input type="number" name="account_id" value={dealer.account_id ?? 0} min="0"
             class="col-span-2 w-32 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <span class="text-sm text-gray-600 font-medium text-right">Geocoordinates</span>
      <div class="col-span-2 text-xs text-gray-500 font-mono">
        {dealer.dealer_latitude && dealer.dealer_longitude
          ? `${dealer.dealer_latitude}, ${dealer.dealer_longitude}`
          : <span class="text-amber-600">Not geocoded</span>}
      </div>
    </div>

    {!settings?.GoogleAPIKey && (
      <div class="col-span-3 text-xs text-amber-600 bg-amber-50 border border-amber-200 rounded px-3 py-2">
        No Google API key configured — geocoordinates will not be updated. Add a key in <a href="/admin/dealers/settings" class="underline">Dealer Settings</a>.
      </div>
    )}

    {dealer.start_date && (
      <div class="grid grid-cols-3 gap-3 items-center">
        <span class="text-sm text-gray-600 font-medium text-right">Start Date</span>
        <span class="col-span-2 text-xs text-gray-500">{new Date(dealer.start_date).toLocaleDateString()}</span>
      </div>
    )}

    <div class="pt-2">
      <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded text-sm hover:bg-blue-700">
        Update Dealer
      </button>
    </div>
  </form>

  <!-- Delete -->
  <div class="mt-5 max-w-2xl">
    <form method="post"
          onsubmit={`return confirm('Delete Dealer ${id}? This cannot be undone.')`}>
      <input type="hidden" name="_action" value="delete" />
      <button type="submit" class="px-4 py-2 rounded text-sm border border-red-300 text-red-600 hover:bg-red-50">
        Delete Dealer
      </button>
    </form>
  </div>

</AdminLayout>
