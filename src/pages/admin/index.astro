---
export const prerender = false;
import AdminLayout from "../../components/layout/AdminLayout.astro";
import { getDashboardStats, getRecentContacts } from "../../lib/queries/admin";

const defaultStats = { totalProducts: 0, totalCategories: 0, totalPages: 0, unreadContacts: 0 };
let stats = defaultStats;
let contacts: Awaited<ReturnType<typeof getRecentContacts>> = [];
let dbError = "";

try {
  [stats, contacts] = await Promise.all([
    getDashboardStats(),
    getRecentContacts(8),
  ]);
} catch (e) {
  dbError = e instanceof Error ? e.message : "Database error loading dashboard.";
}
---
<AdminLayout title="Dashboard">
  {dbError && (
    <div class="mb-6 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
      Dashboard data unavailable: {dbError}
    </div>
  )}
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    {[
      { label: "Products",          value: stats.totalProducts,    href: "/admin/products"   },
      { label: "Categories",        value: stats.totalCategories,  href: "/admin/categories" },
      { label: "Pages",             value: stats.totalPages,       href: "/admin/pages"      },
      { label: "Unread Inquiries",  value: stats.unreadContacts,   href: null                },
    ].map(({ label, value, href }) => (
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
        <div class="text-3xl font-bold text-gray-900">{value}</div>
        <div class="text-sm text-gray-500 mt-1">{label}</div>
        {href && (
          <a href={href} class="text-xs text-blue-600 hover:underline mt-2 inline-block">Manage →</a>
        )}
      </div>
    ))}
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200">
    <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
      <h2 class="font-semibold text-gray-800">Recent Contact Inquiries</h2>
    </div>
    {contacts.length === 0 ? (
      <p class="px-5 py-8 text-sm text-gray-400 text-center">No inquiries yet.</p>
    ) : (
      <table class="w-full text-sm">
        <thead class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
          <tr>
            <th class="px-5 py-3 text-left">Name</th>
            <th class="px-5 py-3 text-left">Email</th>
            <th class="px-5 py-3 text-left">Subject</th>
            <th class="px-5 py-3 text-left">Date</th>
            <th class="px-5 py-3 text-left">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {contacts.map((c) => (
            <tr class="hover:bg-gray-50">
              <td class="px-5 py-3 text-gray-800">
                {[c.FirstName, c.LastName].filter(Boolean).join(" ") || "—"}
              </td>
              <td class="px-5 py-3 text-gray-600">{c.FromEmail ?? "—"}</td>
              <td class="px-5 py-3 text-gray-600 max-w-xs truncate">{c.Subject ?? "—"}</td>
              <td class="px-5 py-3 text-gray-500">
                {c.DateCreated ? new Date(c.DateCreated).toLocaleDateString() : "—"}
              </td>
              <td class="px-5 py-3">
                {c.ReadStatus === 0
                  ? <span class="text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full font-medium">New</span>
                  : <span class="text-xs text-gray-400">Read</span>
                }
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
</AdminLayout>
