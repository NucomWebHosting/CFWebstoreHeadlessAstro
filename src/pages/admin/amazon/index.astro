---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import { getAmazonSettings, saveRefreshToken } from "../../../lib/queries/admin-amazon";
import { getMarketplaceParticipations } from "../../../lib/amazon/spapi";
import type { MarketplaceParticipation } from "../../../lib/amazon/spapi";

let settings = await getAmazonSettings();
let participations: MarketplaceParticipation[] = [];
let error = "";
let successMsg = "";
let tested = false;

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = form.get("action");

  if (action === "save_token") {
    const token = (form.get("refresh_token") as string ?? "").trim();
    if (!token) {
      error = "Refresh token cannot be empty.";
    } else {
      try {
        await saveRefreshToken(token);
        successMsg = "Refresh token saved.";
        settings = await getAmazonSettings();
      } catch (e: unknown) {
        error = e instanceof Error ? e.message : String(e);
      }
    }
  } else if (action === "test") {
    tested = true;
    try {
      participations = await getMarketplaceParticipations();
    } catch (e: unknown) {
      error = e instanceof Error ? e.message : String(e);
    }
  }
}

const CRED_FIELDS = [
  { key: "lws_client_id",    label: "LWA Client ID"     },
  { key: "lws_client_secret", label: "LWA Client Secret" },
  { key: "Refresh_Token",    label: "Refresh Token"      },
  { key: "AWS_Key",          label: "AWS Access Key"     },
  { key: "Secret_Key",       label: "AWS Secret Key"     },
  { key: "Seller_ID",        label: "Seller ID"          },
  { key: "Marketplace_ID",   label: "Marketplace ID"     },
] as const;

type CredKey = typeof CRED_FIELDS[number]["key"];

function maskValue(val: string | null | undefined): string {
  if (!val) return "—";
  if (val.length <= 8) return "●".repeat(val.length);
  return val.slice(0, 4) + "●".repeat(Math.min(val.length - 8, 16)) + val.slice(-4);
}

const allSet = CRED_FIELDS.every(f => !!settings?.[f.key as CredKey]);
---

<AdminLayout title="Amazon Marketplace">

  <div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-semibold text-gray-800">Amazon Marketplace</h1>
    {tested && !error && (
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-green-100 text-green-700">
        <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
        Connected
      </span>
    )}
    {tested && error && (
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-red-100 text-red-700">
        <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
        Connection failed
      </span>
    )}
    {!tested && (
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-500">
        <span class="w-1.5 h-1.5 rounded-full bg-gray-400"></span>
        Not tested
      </span>
    )}
  </div>

  <div class="max-w-2xl space-y-6">

    {error && (
      <div class="rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700 break-all">
        <strong class="font-medium">Error:</strong> {error}
      </div>
    )}
    {successMsg && (
      <div class="rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">
        {successMsg}
      </div>
    )}

    {/* Credentials from DB */}
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100">
        <h2 class="font-semibold text-gray-800">Credentials</h2>
        <p class="text-xs text-gray-400 mt-0.5">Stored in <code class="bg-gray-100 px-1 rounded">amazon_settings</code> (ID&nbsp;=&nbsp;1). Edit in the database or use the form below.</p>
      </div>
      <table class="w-full text-sm">
        <thead class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
          <tr>
            <th class="px-5 py-2.5 text-left">Field</th>
            <th class="px-5 py-2.5 text-center w-16">Set</th>
            <th class="px-5 py-2.5 text-left font-mono">Value</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {CRED_FIELDS.map(f => {
            const val = settings?.[f.key as CredKey];
            return (
              <tr>
                <td class="px-5 py-2.5 text-gray-700">{f.label}</td>
                <td class="px-5 py-2.5 text-center">
                  {val
                    ? <span class="text-green-600 font-bold">✓</span>
                    : <span class="text-red-500 font-bold">✗</span>
                  }
                </td>
                <td class="px-5 py-2.5 font-mono text-xs text-gray-400">{maskValue(val)}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
      <div class="px-5 py-3 border-t border-gray-100">
        <form method="post">
          <input type="hidden" name="action" value="test" />
          <button
            type="submit"
            disabled={!allSet}
            class="bg-blue-600 text-white px-5 py-2 rounded text-sm font-medium hover:bg-blue-700 disabled:opacity-40 disabled:cursor-not-allowed"
          >
            Test Connection
          </button>
          {!allSet && (
            <span class="ml-3 text-xs text-gray-400">One or more credentials are missing.</span>
          )}
        </form>
      </div>
    </div>

    {/* Save refresh token */}
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100">
        <h2 class="font-semibold text-gray-800">Refresh Token</h2>
        <p class="text-xs text-gray-400 mt-0.5">Paste the LWA refresh token obtained from Amazon Seller Central.</p>
      </div>
      <form method="post" class="px-5 py-4 space-y-3">
        <input type="hidden" name="action" value="save_token" />
        <div>
          <label class="block text-xs text-gray-500 mb-1">Refresh Token</label>
          <input
            type="text"
            name="refresh_token"
            placeholder={settings?.Refresh_Token ? "●●●●●●●● (already set — paste to replace)" : "Amo|..."}
            class="w-full border border-gray-300 rounded px-3 py-2 text-sm font-mono focus:outline-none focus:ring-1 focus:ring-blue-400"
          />
        </div>
        <button type="submit" class="bg-slate-700 text-white px-4 py-2 rounded text-sm font-medium hover:bg-slate-800">
          Save Token
        </button>
      </form>
    </div>

    {/* DB migration note */}
    {!settings?.Refresh_Token && settings && (
      <div class="rounded-lg bg-amber-50 border border-amber-200 px-4 py-3 text-sm text-amber-800">
        <strong class="font-medium">Note:</strong> If saving fails, the <code class="bg-amber-100 px-1 rounded">Refresh_Token</code> column may not exist yet. Run this SQL once:
        <pre class="mt-2 text-xs bg-amber-100 rounded p-2 overflow-x-auto">ALTER TABLE amazon_settings ADD Refresh_Token VARCHAR(1000) NULL;</pre>
      </div>
    )}

    {/* Test results */}
    {tested && !error && (
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-5 py-4 border-b border-gray-100">
          <h2 class="font-semibold text-gray-800">Marketplace Participations</h2>
          <p class="text-xs text-gray-400 mt-0.5">{participations.length} marketplace{participations.length !== 1 ? "s" : ""} returned by SP-API</p>
        </div>
        {participations.length === 0 ? (
          <p class="px-5 py-8 text-sm text-center text-gray-400">No marketplaces returned.</p>
        ) : (
          <table class="w-full text-sm">
            <thead class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
              <tr>
                <th class="px-5 py-2.5 text-left">Marketplace</th>
                <th class="px-5 py-2.5 text-left">ID</th>
                <th class="px-5 py-2.5 text-center">Country</th>
                <th class="px-5 py-2.5 text-center">Currency</th>
                <th class="px-5 py-2.5 text-center">Participating</th>
                <th class="px-5 py-2.5 text-center">Suspended Listings</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {participations.map(p => (
                <tr class="hover:bg-gray-50">
                  <td class="px-5 py-3 font-medium text-gray-800">{p.marketplace.name}</td>
                  <td class="px-5 py-3 font-mono text-xs text-gray-500">{p.marketplace.id}</td>
                  <td class="px-5 py-3 text-center text-gray-600">{p.marketplace.countryCode}</td>
                  <td class="px-5 py-3 text-center text-gray-600">{p.marketplace.defaultCurrencyCode}</td>
                  <td class="px-5 py-3 text-center">
                    {p.participation.isParticipating
                      ? <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">Yes</span>
                      : <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500">No</span>
                    }
                  </td>
                  <td class="px-5 py-3 text-center">
                    {p.participation.hasSuspendedListings
                      ? <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700">Yes</span>
                      : <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500">No</span>
                    }
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </div>
    )}

  </div>

</AdminLayout>
