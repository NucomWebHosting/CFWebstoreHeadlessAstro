---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import { createBlankQuote } from "../../../lib/queries/admin-quotes";

let error = "";

if (Astro.request.method === "POST") {
  const d = await Astro.request.formData();
  const customerId = parseInt(d.get("customer_id") as string) || 0;
  if (!customerId) {
    error = "Please select a customer.";
  } else {
    try {
      const newOrderNo = await createBlankQuote(customerId);
      return Astro.redirect(`/admin/quotes/${newOrderNo}/edit`);
    } catch (e: unknown) {
      error = e instanceof Error ? e.message : String(e);
    }
  }
}
---

<AdminLayout title="New Quote">
  <div class="mb-4">
    <a href="/admin/quotes" class="text-sm text-blue-600 hover:underline">← Quotes</a>
  </div>

  <h1 class="text-xl font-semibold text-gray-800 mb-6">New Quote</h1>

  {error && (
    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
  )}

  <!-- Customer Search -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 mb-6 max-w-2xl">
    <h3 class="text-sm font-semibold text-gray-700 mb-3">Select Customer</h3>
    <div class="relative mb-2">
      <input
        id="customer-search"
        type="text"
        placeholder="Search by name, email, or company…"
        autocomplete="off"
        autofocus
        class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400"
      />
      <div id="search-spinner" class="absolute right-3 top-2.5 hidden">
        <svg class="animate-spin h-4 w-4 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
        </svg>
      </div>
    </div>
    <p class="text-xs text-gray-400 mb-3">Type at least 2 characters to search.</p>

    <!-- Dropdown results -->
    <ul id="customer-results" class="hidden border border-gray-200 rounded-lg overflow-hidden divide-y divide-gray-100 mb-4 max-h-72 overflow-y-auto"></ul>

    <!-- Selected customer card -->
    <div id="selected-card" class="hidden rounded-lg bg-blue-50 border border-blue-200 px-4 py-3 text-sm text-blue-900 flex items-center justify-between">
      <div>
        <span class="font-medium" id="selected-name"></span>
        <span class="ml-2 text-blue-600 text-xs" id="selected-email"></span>
      </div>
      <button type="button" id="clear-customer" class="text-blue-400 hover:text-blue-600 text-lg leading-none">&times;</button>
    </div>
  </div>

  <!-- Create button (hidden until customer selected) -->
  <form method="post" id="create-form">
    <input type="hidden" name="customer_id" id="f-customer_id" />
    <button type="submit" id="create-btn" disabled
            class="px-5 py-2 bg-green-600 text-white text-sm font-semibold rounded hover:bg-green-700 disabled:opacity-40 disabled:cursor-not-allowed">
      Create Quote
    </button>
    <a href="/admin/quotes"
       class="ml-3 px-5 py-2 bg-gray-100 text-gray-700 text-sm font-semibold rounded hover:bg-gray-200">
      Cancel
    </a>
  </form>

  <script>
    const searchInput  = document.getElementById("customer-search");
    const spinner      = document.getElementById("search-spinner");
    const resultsList  = document.getElementById("customer-results");
    const selectedCard = document.getElementById("selected-card");
    const selectedName = document.getElementById("selected-name");
    const selectedEmail= document.getElementById("selected-email");
    const clearBtn     = document.getElementById("clear-customer");
    const hiddenId     = document.getElementById("f-customer_id");
    const createBtn    = document.getElementById("create-btn");

    let debounceTimer = null;

    searchInput.addEventListener("input", () => {
      clearTimeout(debounceTimer);
      const q = searchInput.value.trim();
      if (q.length < 2) { resultsList.classList.add("hidden"); return; }
      debounceTimer = setTimeout(() => fetchCustomers(q), 250);
    });

    async function fetchCustomers(q) {
      spinner.classList.remove("hidden");
      try {
        const res = await fetch(`/api/admin/customers/search?q=${encodeURIComponent(q)}`);
        const customers = await res.json();
        renderResults(customers);
      } catch(e) {
        console.error(e);
      } finally {
        spinner.classList.add("hidden");
      }
    }

    function renderResults(customers) {
      resultsList.innerHTML = "";
      if (customers.length === 0) {
        resultsList.innerHTML = `<li class="px-4 py-3 text-sm text-gray-400">No customers found.</li>`;
      } else {
        customers.forEach(c => {
          const li = document.createElement("li");
          li.className = "px-4 py-2.5 hover:bg-gray-50 cursor-pointer";
          const name = `${esc(c.Firstname)} ${esc(c.LastName)}`;
          const company = c.Company ? ` <span class="text-gray-400 text-xs">${esc(c.Company)}</span>` : "";
          const email = c.Email ? ` <span class="text-gray-400 text-xs">${esc(c.Email)}</span>` : "";
          li.innerHTML = `<span class="text-sm font-medium text-gray-800">${name}</span>${company}${email}`;
          li.addEventListener("click", () => selectCustomer(c));
          resultsList.appendChild(li);
        });
      }
      resultsList.classList.remove("hidden");
    }

    function selectCustomer(c) {
      hiddenId.value = c.Customer_ID;
      selectedName.textContent = `${c.Firstname} ${c.LastName}`;
      selectedEmail.textContent = c.Email ?? "";
      selectedCard.classList.remove("hidden");
      resultsList.classList.add("hidden");
      searchInput.value = "";
      createBtn.disabled = false;
    }

    clearBtn.addEventListener("click", () => {
      hiddenId.value = "";
      selectedCard.classList.add("hidden");
      createBtn.disabled = true;
      searchInput.focus();
    });

    function esc(str) {
      return String(str ?? "").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");
    }
  </script>
</AdminLayout>
