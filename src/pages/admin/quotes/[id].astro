---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import {
  getQuote,
  getQuoteItems,
  updateQuoteNotes,
  updateQuoteTotals,
  deleteQuote,
  convertQuoteToPending,
} from "../../../lib/queries/admin-quotes";

const { id } = Astro.params;
const orderNo = parseInt(id ?? "0") || 0;

if (!orderNo) return Astro.redirect("/admin/quotes");

let saved  = false;
let error  = "";
let notice = "";

if (Astro.request.method === "POST") {
  const d      = await Astro.request.formData();
  const action = (d.get("_action") as string) ?? "";

  try {
    if (action === "updatenotes") {
      const notes = (d.get("notes") as string) ?? "";
      await updateQuoteNotes(orderNo, notes);
      saved = true;
    } else if (action === "edit") {
      const shipping        = parseFloat(d.get("shipping") as string)        || 0;
      const tax             = parseFloat(d.get("tax") as string)             || 0;
      const adminCredit     = parseFloat(d.get("adminCredit") as string)     || 0;
      const adminCreditText = (d.get("adminCreditText") as string)           ?? "";
      await updateQuoteTotals(orderNo, { shipping, tax, adminCredit, adminCreditText });
      saved = true;
    } else if (action === "delete") {
      await deleteQuote(orderNo);
      return Astro.redirect("/admin/quotes");
    } else if (action === "convert") {
      const newOrderNo = await convertQuoteToPending(orderNo);
      notice = `Quote #${orderNo} converted to Order #${newOrderNo}.`;
    }
  } catch (e: unknown) {
    error = e instanceof Error ? e.message : String(e);
  }

  if (!error && action !== "convert") {
    return Astro.redirect(`/admin/quotes/${orderNo}?saved=1`);
  }
}

saved = saved || Astro.url.searchParams.get("saved") === "1";

const quote = await getQuote(orderNo);
if (!quote) return Astro.redirect("/admin/quotes");

const items = await getQuoteItems(orderNo);

function money(n: number | string) {
  return `$${Number(n).toFixed(2)}`;
}
function fmt(d: Date) {
  return new Date(d).toLocaleDateString("en-US", { month: "2-digit", day: "2-digit", year: "2-digit" });
}
---

<AdminLayout title={`Quote #${orderNo}`}>

  <div class="mb-5 flex items-center gap-3">
    <a href="/admin/quotes" class="text-sm text-blue-600 hover:underline">← Quotes</a>
    <span class="text-gray-300">|</span>
    <h1 class="text-xl font-semibold text-gray-800">Quote #{orderNo}</h1>
    <span class="text-xs text-gray-400">{fmt(quote.DateOrdered)}</span>
    {quote.Process && (
      <span class="px-2 py-0.5 rounded-full text-xs bg-gray-100 text-gray-500 font-medium">Converted</span>
    )}
  </div>

  {saved && (
    <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">Saved.</div>
  )}
  {notice && (
    <div class="mb-4 rounded-lg bg-blue-50 border border-blue-200 px-4 py-3 text-sm text-blue-700">{notice}</div>
  )}
  {error && (
    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
  )}

  <div class="max-w-4xl space-y-6">

    {/* ── Basket ── */}
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
        <h2 class="font-semibold text-gray-800">Items</h2>
        <div class="flex items-center gap-2">
          <a href={`/admin/quotes/${orderNo}/add-product`}
             class="px-3 py-1 text-xs font-medium bg-green-600 text-white rounded hover:bg-green-700">
            + Add Product
          </a>
          <a href={`/admin/quotes/${orderNo}/edit`}
             class="px-3 py-1 text-xs font-medium bg-amber-500 text-white rounded hover:bg-amber-600">
            Edit Quote
          </a>
        </div>
      </div>
      {items.length === 0 ? (
        <p class="px-5 py-8 text-sm text-gray-400 text-center">No items.</p>
      ) : (
        <table class="w-full text-sm">
          <thead class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
            <tr>
              <th class="px-5 py-3 text-left">Product</th>
              <th class="px-5 py-3 text-left">SKU</th>
              <th class="px-5 py-3 text-left">Options</th>
              <th class="px-5 py-3 text-center">Qty</th>
              <th class="px-5 py-3 text-right">Price</th>
              <th class="px-5 py-3 text-right">Subtotal</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {items.map(item => (
              <tr>
                <td class="px-5 py-3 text-gray-800">{item.Name}</td>
                <td class="px-5 py-3 font-mono text-xs text-gray-500">{item.SKU}</td>
                <td class="px-5 py-3 text-gray-500 text-xs">{item.Options}</td>
                <td class="px-5 py-3 text-center text-gray-700">{item.Quantity}</td>
                <td class="px-5 py-3 text-right text-gray-700">{money(item.Price)}</td>
                <td class="px-5 py-3 text-right font-medium text-gray-800">{money(item.Price * item.Quantity)}</td>
              </tr>
            ))}
          </tbody>
          <tfoot class="bg-gray-50 border-t border-gray-200 text-sm">
            <tr>
              <td colspan="5" class="px-5 py-2 text-right text-gray-500">Shipping</td>
              <td class="px-5 py-2 text-right text-gray-700">{money(quote.Shipping)}</td>
            </tr>
            <tr>
              <td colspan="5" class="px-5 py-2 text-right text-gray-500">Tax</td>
              <td class="px-5 py-2 text-right text-gray-700">{money(quote.Tax)}</td>
            </tr>
            {Number(quote.AdminCredit) > 0 && (
              <tr>
                <td colspan="5" class="px-5 py-2 text-right text-gray-500">
                  Discount {quote.AdminCreditText ? `(${quote.AdminCreditText})` : ""}
                </td>
                <td class="px-5 py-2 text-right text-red-600">-{money(quote.AdminCredit)}</td>
              </tr>
            )}
            <tr class="font-semibold">
              <td colspan="5" class="px-5 py-3 text-right text-gray-800">Total</td>
              <td class="px-5 py-3 text-right text-gray-900">{money(quote.OrderTotal)}</td>
            </tr>
          </tfoot>
        </table>
      )}
    </div>

    {/* ── Customer ── */}
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100">
        <h2 class="font-semibold text-gray-800">Customer</h2>
      </div>
      <div class="px-5 py-4 grid grid-cols-2 gap-6 text-sm">
        <div>
          <p class="text-xs text-gray-500 mb-1 font-medium uppercase tracking-wide">Bill To</p>
          <p class="text-gray-800 font-medium">{quote.FirstName} {quote.LastName}</p>
          {quote.Email && <p class="text-gray-600">{quote.Email}</p>}
          {quote.Phone && <p class="text-gray-600">{quote.Phone}</p>}
          {quote.Address1 && <p class="text-gray-600 mt-1">{quote.Address1}{quote.Address2 ? `, ${quote.Address2}` : ""}</p>}
          {quote.City && <p class="text-gray-600">{quote.City}, {quote.State} {quote.Zip}</p>}
          {quote.Country && <p class="text-gray-500 text-xs">{quote.Country}</p>}
        </div>
        <div>
          <p class="text-xs text-gray-500 mb-1 font-medium uppercase tracking-wide">Ship Type</p>
          <p class="text-gray-700">{quote.ShipType || "—"}</p>
          {quote.InvoiceNum && (
            <div class="mt-3">
              <p class="text-xs text-gray-500 mb-1 font-medium uppercase tracking-wide">Invoice #</p>
              <p class="text-gray-700 font-mono text-xs">{quote.InvoiceNum}</p>
            </div>
          )}
          {quote.Comments && (
            <div class="mt-3">
              <p class="text-xs text-gray-500 mb-1 font-medium uppercase tracking-wide">Comments</p>
              <p class="text-gray-700">{quote.Comments}</p>
            </div>
          )}
        </div>
      </div>
    </div>

    {/* ── Edit Totals ── */}
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100">
        <h2 class="font-semibold text-gray-800">Edit Totals</h2>
      </div>
      <form method="post" class="px-5 py-4 space-y-4">
        <input type="hidden" name="_action" value="edit" />
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs text-gray-500 mb-1">Shipping ($)</label>
            <input type="number" name="shipping" step="0.01" min="0" value={Number(quote.Shipping).toFixed(2)}
                   class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Tax ($)</label>
            <input type="number" name="tax" step="0.01" min="0" value={Number(quote.Tax).toFixed(2)}
                   class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Admin Discount ($)</label>
            <input type="number" name="adminCredit" step="0.01" min="0" value={Number(quote.AdminCredit).toFixed(2)}
                   class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Discount Note</label>
            <input type="text" name="adminCreditText" value={quote.AdminCreditText}
                   class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
          </div>
        </div>
        <button type="submit"
                class="bg-blue-600 text-white px-4 py-1.5 rounded text-sm hover:bg-blue-700">
          Save Totals
        </button>
      </form>
    </div>

    {/* ── Notes ── */}
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100">
        <h2 class="font-semibold text-gray-800">Notes</h2>
      </div>
      <form method="post" class="px-5 py-4 space-y-3">
        <input type="hidden" name="_action" value="updatenotes" />
        <textarea name="notes" rows="5"
                  class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400"
        >{quote.Notes}</textarea>
        <button type="submit"
                class="bg-blue-600 text-white px-4 py-1.5 rounded text-sm hover:bg-blue-700">
          Save Notes
        </button>
      </form>
    </div>

    {/* ── Actions ── */}
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100">
        <h2 class="font-semibold text-gray-800">Actions</h2>
      </div>
      <div class="px-5 py-4 flex gap-3">
        {!quote.Process && (
          <form method="post"
                onsubmit="return confirm('Convert this quote to a pending order? This cannot be undone.')">
            <input type="hidden" name="_action" value="convert" />
            <button type="submit"
                    class="px-4 py-2 rounded bg-green-600 text-white text-sm hover:bg-green-700">
              Move to Pending Order
            </button>
          </form>
        )}
        <form method="post"
              onsubmit="return confirm('Delete this quote permanently?')">
          <input type="hidden" name="_action" value="delete" />
          <button type="submit"
                  class="px-4 py-2 rounded border border-red-200 text-red-600 text-sm hover:bg-red-50">
            Delete Quote
          </button>
        </form>
      </div>
    </div>

  </div>
</AdminLayout>
