---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import { getSmsTexts } from "../../../lib/queries/admin-sms";

const templates = await getSmsTexts();
---

<AdminLayout title="SMS Templates">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-semibold text-gray-800">SMS Templates</h1>
    <a
      href="/admin/sms/templates/new"
      class="inline-flex items-center gap-1.5 bg-green-600 hover:bg-green-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
      </svg>
      Add SMS Template
    </a>
  </div>

  <p class="text-sm text-gray-500 mb-5 max-w-2xl">
    Create and edit standard messages here to avoid rewriting the same SMS repeatedly.
    These messages can be copied into the SMS form when sending.
  </p>

  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden max-w-3xl">
    {templates.length === 0 ? (
      <p class="px-6 py-10 text-center text-sm text-gray-400">No SMS templates yet.</p>
    ) : (
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 border-b border-gray-200">
            <th class="text-left px-4 py-2.5 font-medium text-gray-600 w-24">Actions</th>
            <th class="text-left px-4 py-2.5 font-medium text-gray-600">Message Name</th>
            <th class="text-left px-4 py-2.5 font-medium text-gray-600 w-24">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {templates.map(t => (
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-4 py-2.5">
                <a
                  href={`/admin/sms/templates/${t.SMSText_ID}`}
                  class="text-blue-600 hover:text-blue-800 font-medium"
                >
                  Edit
                </a>
              </td>
              <td class="px-4 py-2.5 text-gray-800">{t.SMSText_Name}</td>
              <td class="px-4 py-2.5">
                {t.Subscribe_SMS ? (
                  <span class="inline-block bg-green-100 text-green-700 text-xs font-medium px-2 py-0.5 rounded">Active</span>
                ) : (
                  <span class="inline-block bg-gray-100 text-gray-500 text-xs font-medium px-2 py-0.5 rounded">Inactive</span>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
</AdminLayout>
