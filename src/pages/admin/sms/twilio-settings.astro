---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import { getTwilioSettings, saveTwilioSettings } from "../../../lib/queries/admin-sms";

let settings = await getTwilioSettings();
let error = "";
let success = "";

let posted = {
  PhoneNumber: settings?.PhoneNumber ?? "",
  Account_SID: settings?.Account_SID ?? "",
  Auth_token:  settings?.Auth_token  ?? "",
};

if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  const g = (k: string) => (data.get(k) as string ?? "").trim();

  posted = {
    PhoneNumber: g("PhoneNumber"),
    Account_SID: g("Account_SID"),
    Auth_token:  g("Auth_token"),
  };

  if (!posted.Account_SID || !posted.Auth_token) {
    error = "Account SID and Authorization Token are required.";
  } else {
    await saveTwilioSettings(posted);
    success = "Settings saved.";
  }
}
---

<AdminLayout title="Twilio Settings">
  <h1 class="text-xl font-semibold text-gray-800 mb-6">Twilio Settings</h1>

  {success && (
    <div class="mb-5 max-w-xl bg-green-50 border border-green-200 text-green-700 text-sm px-4 py-3 rounded-lg">
      {success}
    </div>
  )}
  {error && (
    <div class="mb-5 max-w-xl bg-red-50 border border-red-200 text-red-700 text-sm px-4 py-3 rounded-lg">
      {error}
    </div>
  )}

  <form method="post" class="max-w-xl">
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm px-5 py-5 space-y-4">

      <div class="grid grid-cols-3 items-center gap-3">
        <label class="text-sm font-medium text-gray-700 text-right" for="PhoneNumber">
          Twilio Phone Number:
        </label>
        <div class="col-span-2">
          <input id="PhoneNumber" name="PhoneNumber" type="text" value={posted.PhoneNumber}
            maxlength="50" placeholder="1XXXXXXXXXX"
            class="w-full border border-gray-300 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
          <p class="mt-1 text-xs text-gray-400">Numeric characters only.</p>
        </div>
      </div>

      <div class="grid grid-cols-3 items-center gap-3">
        <label class="text-sm font-medium text-gray-700 text-right" for="Account_SID">
          Account SID <span class="text-red-500">*</span>
        </label>
        <div class="col-span-2">
          <input id="Account_SID" name="Account_SID" type="text" value={posted.Account_SID}
            maxlength="50" required
            class="w-full border border-gray-300 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>
      </div>

      <div class="grid grid-cols-3 items-center gap-3">
        <label class="text-sm font-medium text-gray-700 text-right" for="Auth_token">
          Auth Token <span class="text-red-500">*</span>
        </label>
        <div class="col-span-2">
          <input id="Auth_token" name="Auth_token" type="text" value={posted.Auth_token}
            maxlength="50" required
            class="w-full border border-gray-300 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>
      </div>

    </div>

    <div class="flex gap-3 mt-5">
      <button type="submit"
        class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-5 py-2 rounded-lg transition-colors">
        Save Changes
      </button>
      <a href="/admin"
        class="bg-gray-200 hover:bg-gray-300 text-gray-700 text-sm font-medium px-5 py-2 rounded-lg transition-colors">
        Cancel
      </a>
    </div>
  </form>
</AdminLayout>
