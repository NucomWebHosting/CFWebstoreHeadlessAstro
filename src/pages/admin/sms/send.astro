---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import { getTwilioSettings, sendSms } from "../../../lib/queries/admin-sms";

let error = "";
let success = "";
let postedPhone = "";
let postedText = "";

if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  const g = (k: string) => (data.get(k) as string ?? "").trim();

  postedPhone = g("Phone");
  postedText  = g("Text");

  if (!postedPhone) {
    error = "Phone number is required.";
  } else if (!postedText) {
    error = "Message text is required.";
  } else {
    const settings = await getTwilioSettings();
    if (!settings?.Account_SID || !settings?.nucomServicesURL) {
      error = "Twilio is not configured. Please check Twilio Settings.";
    } else {
      try {
        const errMsg = await sendSms(postedPhone, postedText, settings);
        if (errMsg) {
          error = errMsg;
        } else {
          success = "Your message has been sent.";
          postedPhone = "";
          postedText  = "";
        }
      } catch (e: unknown) {
        error = e instanceof Error ? e.message : "Failed to send SMS.";
      }
    }
  }
}
---

<AdminLayout title="Send SMS">
  <h1 class="text-xl font-semibold text-gray-800 mb-6">Send SMS</h1>

  {success && (
    <div class="mb-5 max-w-lg bg-green-50 border border-green-200 text-green-700 text-sm px-4 py-3 rounded-lg">
      {success}
    </div>
  )}
  {error && (
    <div class="mb-5 max-w-lg bg-red-50 border border-red-200 text-red-700 text-sm px-4 py-3 rounded-lg">
      {error}
    </div>
  )}

  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 max-w-lg">
    <form method="post" class="space-y-5">

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="Phone">
          Phone Number <span class="text-red-500">*</span>
        </label>
        <input
          id="Phone"
          name="Phone"
          type="tel"
          value={postedPhone}
          maxlength="50"
          placeholder="1XXXXXXXXXX"
          required
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
        />
        <p class="mt-1 text-xs text-gray-400">Numeric characters only.</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="Text">
          Message <span class="text-red-500">*</span>
        </label>
        <textarea
          id="Text"
          name="Text"
          rows={6}
          required
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
        >{postedText}</textarea>
      </div>

      <div class="pt-1">
        <button
          type="submit"
          class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-5 py-2 rounded-lg transition-colors"
        >
          Send
        </button>
      </div>
    </form>
  </div>
</AdminLayout>
