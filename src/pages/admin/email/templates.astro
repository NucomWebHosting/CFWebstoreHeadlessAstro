---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import { getMailTexts } from "../../../lib/queries/admin-email-templates";

const templates = await getMailTexts();
const systemTemplates = templates.filter(t => t.System);
const customTemplates = templates.filter(t => !t.System);
---

<AdminLayout title="Standard Email Text">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-semibold text-gray-800">Standard Email Text</h1>
    <a
      href="/admin/email/templates/new"
      class="inline-flex items-center gap-1.5 bg-green-600 hover:bg-green-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
      </svg>
      Add Email Template
    </a>
  </div>

  <!-- System Emails -->
  <div class="mb-8">
    <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">System Emails</h2>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      {systemTemplates.length === 0 ? (
        <p class="px-6 py-8 text-center text-sm text-gray-400">No system email templates found.</p>
      ) : (
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 border-b border-gray-200">
              <th class="text-left px-4 py-2.5 font-medium text-gray-600 w-24">Actions</th>
              <th class="text-left px-4 py-2.5 font-medium text-gray-600">Email Name</th>
              <th class="text-left px-4 py-2.5 font-medium text-gray-600">Mail Action</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {systemTemplates.map(t => (
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-4 py-2.5">
                  <a
                    href={`/admin/email/templates/${t.MailText_ID}`}
                    class="text-blue-600 hover:text-blue-800 font-medium"
                  >
                    Edit
                  </a>
                </td>
                <td class="px-4 py-2.5 text-gray-800">{t.MailText_Name}</td>
                <td class="px-4 py-2.5">
                  <span class="inline-block bg-amber-100 text-amber-700 text-xs font-medium px-2 py-0.5 rounded">
                    {t.MailAction}
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>
  </div>

  <!-- Custom Emails -->
  <div>
    <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">Custom Emails</h2>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      {customTemplates.length === 0 ? (
        <p class="px-6 py-8 text-center text-sm text-gray-400">No custom email templates yet.</p>
      ) : (
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 border-b border-gray-200">
              <th class="text-left px-4 py-2.5 font-medium text-gray-600 w-24">Actions</th>
              <th class="text-left px-4 py-2.5 font-medium text-gray-600">Email Name</th>
              <th class="text-left px-4 py-2.5 font-medium text-gray-600">Mail Action</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {customTemplates.map(t => (
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-4 py-2.5">
                  <a
                    href={`/admin/email/templates/${t.MailText_ID}`}
                    class="text-blue-600 hover:text-blue-800 font-medium"
                  >
                    Edit
                  </a>
                </td>
                <td class="px-4 py-2.5 text-gray-800">{t.MailText_Name}</td>
                <td class="px-4 py-2.5 text-gray-600">{t.MailAction}</td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>
  </div>
</AdminLayout>
