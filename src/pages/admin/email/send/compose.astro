---
export const prerender = false;
import AdminLayout from "../../../../components/layout/AdminLayout.astro";
import {
  getEmailRecipients,
  sendBulkEmails,
  type EmailFilters,
} from "../../../../lib/queries/admin-email-send";
import { getMailTexts } from "../../../../lib/queries/admin-email-templates";
import { getSettings } from "../../../../lib/queries/admin-settings";

// Pull filter params from query string (passed from step 1)
const q = Astro.url.searchParams;
const filters: EmailFilters = {
  verified:       q.get("verified")       ?? "",
  subscribe:      q.get("subscribe")      ?? "",
  un:             q.get("un")             ?? "",
  gid:            q.get("gid")            ?? "",
  affiliate:      q.get("affiliate")      ?? "",
  acct:           q.get("acct")           ?? "",
  lastLogin:      q.get("lastLogin")      ?? "",
  lastLogin_is:   q.get("lastLogin_is")   ?? "after",
  created:        q.get("created")        ?? "",
  created_is:     q.get("created_is")     ?? "after",
  member:         q.get("member")         ?? "0",
  product_id:     q.get("product_id")     ?? "",
  sku:            q.get("sku")            ?? "",
  dateOrdered:    q.get("dateOrdered")    ?? "",
  dateOrdered_is: q.get("dateOrdered_is") ?? "after",
  dateFilled:     q.get("dateFilled")     ?? "",
  dateFilled_is:  q.get("dateFilled_is")  ?? "after",
};

const [templates, settings] = await Promise.all([getMailTexts(), getSettings()]);
const recipients = await getEmailRecipients(filters);

let error = "";
let successMsg = "";
let postedSubject = "";
let postedBody = "";
let postedMailtextId = "";

if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  const g = (k: string) => (data.get(k) as string ?? "").trim();

  postedSubject    = g("subject");
  postedBody       = (data.get("body") as string ?? "");
  postedMailtextId = g("mailtext_id");

  if (!postedSubject) {
    error = "Subject is required.";
  } else if (!postedBody.trim()) {
    error = "Message is required.";
  } else {
    const siteName    = settings?.SiteName    ?? "Admin";
    const fromEmail   = settings?.MerchantEmail ?? "";

    try {
      const { sent, failed } = await sendBulkEmails(
        recipients,
        postedSubject,
        postedBody,
        settings,
        siteName,
        fromEmail
      );
      successMsg = `Email sent to ${sent} recipient${sent !== 1 ? "s" : ""}${failed > 0 ? ` (${failed} skipped — invalid address)` : ""}.`;
    } catch (e: unknown) {
      error = e instanceof Error ? e.message : "Failed to send email.";
    }
  }
}

// Build the filter query string to preserve "Back" link state
const filterQS = q.toString();
---

<AdminLayout title="Send Email">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-semibold text-gray-800">Send Email</h1>
    <a href={`/admin/email/send?${filterQS}`}
      class="text-sm text-gray-500 hover:text-gray-800 transition-colors">
      &larr; Change Recipients
    </a>
  </div>

  {successMsg && (
    <div class="mb-5 bg-green-50 border border-green-200 text-green-700 text-sm px-4 py-3 rounded-lg">
      {successMsg}
    </div>
  )}

  {error && (
    <div class="mb-5 bg-red-50 border border-red-200 text-red-700 text-sm px-4 py-3 rounded-lg">
      {error}
    </div>
  )}

  <!-- Recipient count -->
  <div class="mb-5 bg-white rounded-xl border border-gray-200 shadow-sm px-5 py-3 flex items-center gap-3 max-w-2xl">
    <svg class="w-5 h-5 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
    </svg>
    <span class="text-sm text-gray-700">
      <strong class={recipients.length === 0 ? "text-red-600" : "text-gray-900"}>{recipients.length}</strong>
      {" "}email address{recipients.length !== 1 ? "es" : ""} selected
    </span>
  </div>

  <div class="max-w-2xl space-y-5">

    <!-- Standard text selector -->
    {templates.length > 0 && (
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm px-5 py-4">
        <label class="block text-sm font-medium text-gray-700 mb-2" for="template-select">
          Standard Text:
        </label>
        <select id="template-select"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="">— select a template —</option>
          {templates.map(t => (
            <option value={String(t.MailText_ID)}
              data-subject={t.MailText_Subject}
              data-body={t.MailText_Message}>
              {t.MailText_Name}
            </option>
          ))}
        </select>
      </div>
    )}

    <!-- Compose form -->
    <form method="post" class="bg-white rounded-xl border border-gray-200 shadow-sm px-5 py-5 space-y-5">
      <!-- Pass filter params forward as hidden fields -->
      {Array.from(q.entries()).map(([k, val]) => (
        <input type="hidden" name={k} value={val} />
      ))}
      <input type="hidden" name="mailtext_id" id="f-mailtext-id" value={postedMailtextId} />

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="subject">
          Subject <span class="text-red-500">*</span>
        </label>
        <input
          id="subject"
          name="subject"
          type="text"
          value={postedSubject}
          required
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
        />
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="body">
          Message <span class="text-red-500">*</span>
        </label>
        <textarea
          id="body"
          name="body"
          rows={16}
          required
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-blue-500"
        >{postedBody}</textarea>
      </div>

      <div class="flex items-center gap-3 pt-2">
        <button
          type="submit"
          disabled={recipients.length === 0}
          class="bg-blue-600 hover:bg-blue-700 disabled:opacity-40 disabled:cursor-not-allowed text-white text-sm font-medium px-5 py-2 rounded-lg transition-colors"
        >
          Send Message
        </button>
        <a href={`/admin/email/send?${filterQS}`}
          class="bg-gray-200 hover:bg-gray-300 text-gray-700 text-sm font-medium px-5 py-2 rounded-lg transition-colors">
          Reselect Emails
        </a>
        <a href="/admin"
          class="text-sm text-gray-500 hover:text-gray-800 transition-colors px-2">
          Cancel
        </a>
      </div>

    </form>
  </div>
</AdminLayout>

<script>
  // Populate subject + body from selected template
  const sel = document.getElementById("template-select") as HTMLSelectElement | null;
  const subjectInput = document.getElementById("subject") as HTMLInputElement | null;
  const bodyTA = document.getElementById("body") as HTMLTextAreaElement | null;
  const mailtextId = document.getElementById("f-mailtext-id") as HTMLInputElement | null;

  sel?.addEventListener("change", () => {
    const opt = sel.options[sel.selectedIndex];
    if (!opt.value) return;
    if (subjectInput) subjectInput.value = opt.dataset.subject ?? "";
    if (bodyTA)       bodyTA.value       = opt.dataset.body    ?? "";
    if (mailtextId)   mailtextId.value   = opt.value;
  });
</script>
