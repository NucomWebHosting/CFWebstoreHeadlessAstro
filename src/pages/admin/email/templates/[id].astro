---
export const prerender = false;
import AdminLayout from "../../../../components/layout/AdminLayout.astro";
import { getMailText, updateMailText, deleteMailText } from "../../../../lib/queries/admin-email-templates";

const id = Number(Astro.params.id);
if (!id) return Astro.redirect("/admin/email/templates");

let template = await getMailText(id);
if (!template) return Astro.redirect("/admin/email/templates");

let error = "";
let posted = {
  MailText_Name: template.MailText_Name,
  MailText_Subject: template.MailText_Subject,
  MailText_Message: template.MailText_Message,
  MailAction: template.MailAction,
};

if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  const action = (data.get("_action") as string ?? "").trim();

  if (action === "delete") {
    if (!template.System) {
      await deleteMailText(id);
      return Astro.redirect("/admin/email/templates");
    }
  } else {
    posted.MailText_Name    = (data.get("MailText_Name")    as string ?? "").trim();
    posted.MailText_Subject = (data.get("MailText_Subject") as string ?? "").trim();
    posted.MailText_Message = (data.get("MailText_Message") as string ?? "").trim();
    posted.MailAction       = (data.get("MailAction")       as string ?? "").trim();

    if (!posted.MailText_Name) {
      error = "Message Name is required.";
    } else {
      await updateMailText(id, posted);
      return Astro.redirect("/admin/email/templates");
    }
  }
}
---

<AdminLayout title="Edit Email Template">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-semibold text-gray-800">Edit Email Template</h1>
    <a href="/admin/email/templates" class="text-sm text-gray-500 hover:text-gray-800 transition-colors">
      &larr; Back to Templates
    </a>
  </div>

  {error && (
    <div class="mb-4 bg-red-50 border border-red-200 text-red-700 text-sm px-4 py-3 rounded-lg">
      {error}
    </div>
  )}

  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 max-w-2xl">
    <form method="post">
      <input type="hidden" name="_action" value="save" />

      <div class="space-y-5">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="MailText_Name">
            Message Name
          </label>
          <input
            id="MailText_Name"
            name="MailText_Name"
            type="text"
            value={posted.MailText_Name}
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
            required
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="MailAction">
            System Name {template.System && <span class="text-xs text-gray-400">(read-only)</span>}
          </label>
          {template.System ? (
            <>
              <input type="hidden" name="MailAction" value={posted.MailAction} />
              <input
                id="MailAction"
                type="text"
                value={posted.MailAction}
                class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm bg-gray-50 text-gray-500 cursor-not-allowed"
                disabled
              />
            </>
          ) : (
            <input
              id="MailAction"
              name="MailAction"
              type="text"
              value={posted.MailAction}
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
            />
          )}
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="MailText_Subject">
            Subject
          </label>
          <input
            id="MailText_Subject"
            name="MailText_Subject"
            type="text"
            value={posted.MailText_Subject}
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="MailText_Message">
            Message
          </label>
          <textarea
            id="MailText_Message"
            name="MailText_Message"
            rows={16}
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-blue-500"
          >{posted.MailText_Message}</textarea>
        </div>
      </div>

      <div class="flex items-center justify-between mt-6 pt-4 border-t border-gray-100">
        <button
          type="submit"
          class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-5 py-2 rounded-lg transition-colors"
        >
          Save
        </button>

        {!template.System && (
          <button
            type="submit"
            name="_action"
            value="delete"
            class="text-sm text-red-600 hover:text-red-800 transition-colors"
            onclick="return confirm('Delete this email template?')"
          >
            Delete
          </button>
        )}
      </div>
    </form>
  </div>
</AdminLayout>
