---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import {
  getProductFilter, updateProductFilter, deleteProductFilter,
  getSpecs, saveSpecs,
  getParams,
} from "../../../lib/queries/admin-product-filters";
import type { SpecRow } from "../../../lib/queries/admin-product-filters";

const id = parseInt(Astro.params.id ?? "0");
let error = "";
let successMsg = "";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = form.get("action") as string;

  if (action === "delete_type") {
    try {
      await deleteProductFilter(id);
      return Astro.redirect("/admin/product-filters");
    } catch (e: unknown) {
      error = e instanceof Error ? e.message : String(e);
    }
  } else if (action === "update_name") {
    const name = ((form.get("type_name") as string) ?? "").trim();
    if (!name) {
      error = "Type name is required.";
    } else {
      try {
        await updateProductFilter(id, name);
        return Astro.redirect(`/admin/product-filters/${id}?saved=name`);
      } catch (e: unknown) {
        error = e instanceof Error ? e.message : String(e);
      }
    }
  } else if (action === "save_specs") {
    const rowCount = parseInt(form.get("spec_row_count") as string) || 0;
    const rows: SpecRow[] = [];
    for (let i = 0; i < rowCount; i++) {
      const name = ((form.get(`spec_name_${i}`) as string) ?? "").trim();
      const specId = parseInt(form.get(`spec_id_${i}`) as string) || undefined;
      const del = form.get(`spec_delete_${i}`) === "1";
      if (!del && !name) continue;
      rows.push({
        id: specId,
        name,
        isTitle: form.get(`spec_istitle_${i}`) === "1",
        priority: parseInt(form.get(`spec_priority_${i}`) as string) || 0,
        delete: del,
      });
    }
    try {
      await saveSpecs(id, rows);
      return Astro.redirect(`/admin/product-filters/${id}?saved=specs`);
    } catch (e: unknown) {
      error = e instanceof Error ? e.message : String(e);
    }
  }
}

const filter = await getProductFilter(id);
if (!filter) return Astro.redirect("/admin/product-filters");

const specs  = await getSpecs(id);
const params = await getParams(id);

const saved = Astro.url.searchParams.get("saved");
if (saved === "name")  successMsg = "Type name saved.";
if (saved === "specs") successMsg = "Specifications saved.";
---

<AdminLayout title={`Edit: ${filter.TypeName}`}>
  <div class="mb-5">
    <a href="/admin/product-filters" class="text-sm text-blue-600 hover:underline">← Product Filters</a>
  </div>

  {error && (
    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
  )}
  {successMsg && (
    <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">{successMsg}</div>
  )}

  <div class="space-y-6 max-w-4xl">

    <!-- Section 1: Type Name -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100">
        <h2 class="font-semibold text-gray-800">Filter Type</h2>
      </div>
      <form method="post" class="px-5 py-5 flex gap-4 items-end">
        <input type="hidden" name="action" value="update_name" />
        <div class="flex-1">
          <label class="block text-xs text-gray-500 mb-1">Type Name <span class="text-red-500">*</span></label>
          <input type="text" name="type_name" value={filter.TypeName} maxlength="100" required
                 class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
        </div>
        <button type="submit"
                class="bg-blue-600 text-white px-5 py-2 rounded text-sm font-medium hover:bg-blue-700 shrink-0">
          Save Name
        </button>
      </form>
    </div>

    <!-- Section 2: Custom Specifications (inline editor) -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100">
        <h2 class="font-semibold text-gray-800">Custom Specifications</h2>
        <p class="text-xs text-gray-400 mt-0.5">Product attributes shown on product pages (e.g. Material, Dimensions).</p>
      </div>

      <form method="post">
        <input type="hidden" name="action" value="save_specs" />
        <input type="hidden" name="spec_row_count" id="spec_row_count" value={specs.length} />

        <table class="w-full text-sm" id="specs-table">
          <thead class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
            <tr>
              <th class="px-5 py-3 text-left">Name</th>
              <th class="px-5 py-3 text-center w-24">Priority</th>
              <th class="px-5 py-3 text-center w-36">Section Heading</th>
              <th class="px-5 py-3 w-16"></th>
            </tr>
          </thead>
          <tbody id="specs-tbody">
            {specs.map((s, i) => (
              <tr class="spec-row border-t border-gray-100 hover:bg-gray-50" id={`spec-row-${i}`}>
                <td class="px-5 py-3">
                  <input type="hidden" name={`spec_id_${i}`} value={s.ProdTypeSpec_ID} />
                  <input type="hidden" name={`spec_delete_${i}`} value="0" class="spec-delete-flag" />
                  <input type="text" name={`spec_name_${i}`} value={s.Name} maxlength="100" required
                         class="w-full border border-gray-300 rounded px-2 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
                </td>
                <td class="px-5 py-3 text-center">
                  <input type="number" name={`spec_priority_${i}`} value={s.Priority} min="0"
                         class="w-16 border border-gray-300 rounded px-2 py-1.5 text-sm text-center focus:outline-none focus:ring-1 focus:ring-blue-400" />
                </td>
                <td class="px-5 py-3 text-center">
                  <input type="checkbox" name={`spec_istitle_${i}`} value="1" checked={s.IsTitle}
                         class="w-4 h-4 rounded border-gray-300 text-blue-600 focus:ring-blue-400" />
                </td>
                <td class="px-5 py-3 text-center">
                  <button type="button" onclick={`deleteSpecRow(${i})`}
                          class="text-xs text-red-500 hover:text-red-700 hover:underline">
                    Delete
                  </button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>

        <div class="px-5 py-3 border-t border-gray-100 flex items-center justify-between">
          <button type="button" id="add-spec-btn" class="text-sm text-blue-600 hover:underline">
            + Add Spec
          </button>
          <button type="submit"
                  class="bg-blue-600 text-white px-4 py-1.5 rounded text-sm font-medium hover:bg-blue-700">
            Save Specs
          </button>
        </div>
      </form>
    </div>

    <!-- Section 3: Search Parameters (list, link to edit pages) -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
        <div>
          <h2 class="font-semibold text-gray-800">Search Parameters</h2>
          <p class="text-xs text-gray-400 mt-0.5">Filterable options shown to customers (with answer choices).</p>
        </div>
        <a href={`/admin/product-filters/${id}/params/new`}
           class="bg-blue-600 text-white px-3 py-1.5 rounded text-xs font-medium hover:bg-blue-700">
          + Add Parameter
        </a>
      </div>

      {params.length === 0 ? (
        <p class="px-5 py-8 text-center text-sm text-gray-400">No search parameters yet.</p>
      ) : (
        <table class="w-full text-sm">
          <thead class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
            <tr>
              <th class="px-5 py-3 text-left">Name</th>
              <th class="px-5 py-3 text-left">Question</th>
              <th class="px-5 py-3 text-center w-20">Priority</th>
              <th class="px-5 py-3 text-center w-24">Display</th>
              <th class="px-5 py-3 text-center w-20">Answers</th>
              <th class="px-5 py-3 w-16"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {params.map(p => (
              <tr class="hover:bg-gray-50">
                <td class="px-5 py-3">
                  <p class="font-medium text-gray-800">{p.Name}</p>
                  {p.ParentName && (
                    <p class="text-xs text-gray-400 mt-0.5">
                      child of: {p.ParentName}{p.ParentAnswerText ? ` → ${p.ParentAnswerText}` : ""}
                    </p>
                  )}
                </td>
                <td class="px-5 py-3 text-gray-600">{p.Question}</td>
                <td class="px-5 py-3 text-center text-xs text-gray-500">{p.Priority}</td>
                <td class="px-5 py-3 text-center">
                  {p.display
                    ? <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">Yes</span>
                    : <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500">No</span>
                  }
                </td>
                <td class="px-5 py-3 text-center text-xs text-gray-500">{p.AnswerCount}</td>
                <td class="px-5 py-3 text-right">
                  <a href={`/admin/product-filters/${id}/params/${p.ProdTypeParam_ID}`}
                     class="px-3 py-1 text-xs rounded bg-slate-100 text-slate-700 hover:bg-slate-200">
                    Edit
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>

    <!-- Danger Zone -->
    <div class="bg-white rounded-xl border border-red-200 shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-red-100">
        <h2 class="font-semibold text-red-700">Danger Zone</h2>
        <p class="text-xs text-red-400 mt-0.5">Deletes this filter type and all its specs and parameters.</p>
      </div>
      <div class="px-5 py-4">
        <form method="post"
              onsubmit="return confirm('Delete this filter type and all its specs and parameters? This cannot be undone.')">
          <input type="hidden" name="action" value="delete_type" />
          <button type="submit"
                  class="bg-red-600 text-white px-4 py-2 rounded text-sm font-medium hover:bg-red-700">
            Delete Filter Type
          </button>
        </form>
      </div>
    </div>

  </div>
</AdminLayout>

<script>
  let specRowCount = parseInt((document.getElementById("spec_row_count") as HTMLInputElement).value);

  document.getElementById("add-spec-btn")!.addEventListener("click", () => {
    const i = specRowCount;
    const tbody = document.getElementById("specs-tbody")!;
    const tr = document.createElement("tr");
    tr.className = "spec-row border-t border-gray-100 hover:bg-gray-50";
    tr.id = `spec-row-${i}`;
    tr.innerHTML = `
      <td class="px-5 py-3">
        <input type="hidden" name="spec_id_${i}" value="" />
        <input type="hidden" name="spec_delete_${i}" value="0" class="spec-delete-flag" />
        <input type="text" name="spec_name_${i}" maxlength="100" required placeholder="Spec name"
               class="w-full border border-gray-300 rounded px-2 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
      </td>
      <td class="px-5 py-3 text-center">
        <input type="number" name="spec_priority_${i}" value="0" min="0"
               class="w-16 border border-gray-300 rounded px-2 py-1.5 text-sm text-center focus:outline-none focus:ring-1 focus:ring-blue-400" />
      </td>
      <td class="px-5 py-3 text-center">
        <input type="checkbox" name="spec_istitle_${i}" value="1"
               class="w-4 h-4 rounded border-gray-300 text-blue-600 focus:ring-blue-400" />
      </td>
      <td class="px-5 py-3 text-center">
        <button type="button" onclick="deleteSpecRow(${i})"
                class="text-xs text-red-500 hover:text-red-700 hover:underline">Delete</button>
      </td>
    `;
    tbody.appendChild(tr);
    specRowCount++;
    (document.getElementById("spec_row_count") as HTMLInputElement).value = String(specRowCount);
    tr.querySelector("input[type=text]")?.focus();
  });

  (window as any).deleteSpecRow = function(i: number) {
    const row = document.getElementById(`spec-row-${i}`);
    if (!row) return;
    const idInput = row.querySelector<HTMLInputElement>(`input[name="spec_id_${i}"]`);
    if (idInput && idInput.value) {
      if (!confirm("Delete this spec? This will remove it from all products.")) return;
      const flag = row.querySelector<HTMLInputElement>(".spec-delete-flag");
      if (flag) flag.value = "1";
      row.style.opacity = "0.3";
      row.querySelectorAll("input:not([type=hidden]), button").forEach(el => (el as HTMLElement).setAttribute("disabled", "true"));
    } else {
      row.remove();
    }
  };
</script>
