---
export const prerender = false;
import AdminLayout from "../../components/layout/AdminLayout.astro";
import { getAbandonedCarts, PAGE_SIZE } from "../../lib/queries/admin-abandoned-carts";

const p = Astro.url.searchParams;

const opts = {
  startDate:          p.get("startDate")          ?? "",
  toDate:             p.get("toDate")             ?? "",
  basketnum:          p.get("basketnum")           ?? "",
  customer:           p.get("customer")            ?? "",
  step:               p.get("step")                ?? "",
  abandoned:          p.get("abandoned")           ?? "0",
  contacted_by_phone: p.get("contacted_by_phone")  ?? "2",
  prodid:             p.get("prodid")              ?? "",
  affiliate:          p.get("affiliate")           ?? "",
  page:               parseInt(p.get("page") ?? "1") || 1,
};

// default date range: first of current month → today
function defaultStart() {
  const d = new Date();
  return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,"0")}-01`;
}
function defaultToday() {
  const d = new Date();
  return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,"0")}-${String(d.getDate()).padStart(2,"0")}`;
}

if (!opts.startDate) opts.startDate = defaultStart();
if (!opts.toDate)    opts.toDate    = defaultToday();

const { rows, total } = await getAbandonedCarts(opts);

const totalPages = Math.ceil(total / PAGE_SIZE);

function filterQS(overrides: Record<string, string | number>) {
  const base = { ...opts, ...overrides };
  return Object.entries(base)
    .filter(([, v]) => String(v).length > 0)
    .map(([k, v]) => `${k}=${encodeURIComponent(v)}`)
    .join("&");
}

function pageUrl(pg: number) { return `/admin/abandoned-carts?${filterQS({ page: pg })}`; }

const STEPS = ["","all","cart","checkin","terms","address","shipping","payment","paypal","reciept","empty","register","error"];
const STEP_LABELS: Record<string, string> = {
  "": "has email", all:"all", cart:"cart", checkin:"checkin", terms:"terms",
  address:"address", shipping:"shipping", payment:"payment", paypal:"paypal",
  reciept:"receipt", empty:"empty", register:"register", error:"error",
};

// Sliding window pagination
const windowSize = 5;
const halfW = Math.floor(windowSize / 2);
let winStart = Math.max(1, opts.page - halfW);
let winEnd   = Math.min(totalPages, winStart + windowSize - 1);
if (winEnd - winStart < windowSize - 1) winStart = Math.max(1, winEnd - windowSize + 1);

function countryLabel(country: string | null) {
  if (!country) return "";
  const parts = country.split("^");
  return parts[0] ?? "";
}
---

<AdminLayout title="Abandoned Carts">

  <!-- Filters -->
  <form method="get" action="/admin/abandoned-carts" class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 mb-5 space-y-3">

    <div class="flex flex-wrap gap-3 items-end">
      <div>
        <label class="block text-xs text-gray-500 mb-1">Date From</label>
        <input type="date" name="startDate" value={opts.startDate}
               class="border border-gray-300 rounded px-2 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Date To</label>
        <input type="date" name="toDate" value={opts.toDate}
               class="border border-gray-300 rounded px-2 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Cart #</label>
        <input type="text" name="basketnum" value={opts.basketnum} maxlength="50"
               class="w-28 border border-gray-300 rounded px-2 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Customer</label>
        <input type="text" name="customer" value={opts.customer} maxlength="50"
               class="w-40 border border-gray-300 rounded px-2 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Step</label>
        <select name="step"
                class="border border-gray-300 rounded px-2 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">
          {STEPS.map(s => (
            <option value={s} selected={opts.step === s}>{STEP_LABELS[s]}</option>
          ))}
        </select>
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Contacted</label>
        <select name="abandoned"
                class="border border-gray-300 rounded px-2 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">
          <option value="2" selected={opts.abandoned === "2"}>all</option>
          <option value="0" selected={opts.abandoned === "0"}>no</option>
          <option value="1" selected={opts.abandoned === "1"}>yes</option>
        </select>
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">By Phone</label>
        <select name="contacted_by_phone"
                class="border border-gray-300 rounded px-2 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">
          <option value="2" selected={opts.contacted_by_phone === "2"}>all</option>
          <option value="0" selected={opts.contacted_by_phone === "0"}>no</option>
          <option value="1" selected={opts.contacted_by_phone === "1"}>yes</option>
        </select>
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Product ID</label>
        <input type="text" name="prodid" value={opts.prodid} maxlength="12"
               class="w-24 border border-gray-300 rounded px-2 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Affiliate</label>
        <input type="text" name="affiliate" value={opts.affiliate} maxlength="12"
               class="w-24 border border-gray-300 rounded px-2 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
      </div>
      <button type="submit" class="bg-blue-600 text-white px-4 py-1.5 rounded text-sm hover:bg-blue-700">Search</button>
      <a href="/admin/abandoned-carts?step=all&abandoned=2&contacted_by_phone=2"
         class="text-xs text-blue-600 hover:underline self-end pb-2">Show All</a>
    </div>
  </form>

  <!-- Results count + pagination -->
  <div class="flex items-center justify-between mb-3">
    <span class="text-sm text-gray-500">{total.toLocaleString()} cart{total !== 1 ? "s" : ""}</span>
    {totalPages > 1 && (
      <div class="flex gap-1 text-sm">
        {opts.page > 1 && <a href={pageUrl(opts.page - 1)} class="px-2 py-1 rounded border border-gray-200 hover:bg-gray-50">‹</a>}
        {winStart > 1 && <span class="px-2 py-1 text-gray-400">…</span>}
        {Array.from({length: winEnd - winStart + 1}, (_, i) => winStart + i).map(pg => (
          <a href={pageUrl(pg)}
             class={`px-2 py-1 rounded border ${pg === opts.page ? "bg-blue-600 text-white border-blue-600" : "border-gray-200 hover:bg-gray-50"}`}>
            {pg}
          </a>
        ))}
        {winEnd < totalPages && <span class="px-2 py-1 text-gray-400">…</span>}
        {opts.page < totalPages && <a href={pageUrl(opts.page + 1)} class="px-2 py-1 rounded border border-gray-200 hover:bg-gray-50">›</a>}
      </div>
    )}
  </div>

  <!-- Table -->
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="px-4 py-2.5 text-left font-medium text-gray-600">Cart #</th>
          <th class="px-4 py-2.5 text-left font-medium text-gray-600">Date</th>
          <th class="px-4 py-2.5 text-left font-medium text-gray-600">Customer</th>
          <th class="px-4 py-2.5 text-left font-medium text-gray-600">Step</th>
          <th class="px-4 py-2.5 text-center font-medium text-gray-600">Contacted</th>
          <th class="px-4 py-2.5 text-center font-medium text-gray-600">By Phone</th>
          <th class="px-4 py-2.5 text-center font-medium text-gray-600">Items</th>
          <th class="px-4 py-2.5 text-right font-medium text-gray-600">Total</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {rows.length === 0 && (
          <tr><td colspan="8" class="px-4 py-8 text-center text-gray-400">No records found.</td></tr>
        )}
        {rows.map(r => {
          const name = [r.Firstname, r.Lastname].filter(Boolean).join(" ") || r.Company || "—";
          const country = countryLabel(r.Country);
          const isUS = !country || country.toLowerCase().startsWith("us") || country.toLowerCase() === "united states";
          return (
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-2.5">
                <a href={`/admin/abandoned-carts/${r.BasketNum}`} class="text-blue-600 hover:underline font-mono text-xs">
                  {r.BasketNum}
                </a>
              </td>
              <td class="px-4 py-2.5 text-gray-600 whitespace-nowrap">
                {new Date(r.DateAdded).toLocaleDateString()}
              </td>
              <td class="px-4 py-2.5">
                {name}
                {!isUS && country && <span class="ml-1 text-xs text-gray-400">({country})</span>}
              </td>
              <td class="px-4 py-2.5 text-gray-500 text-xs">{r.step ?? "—"}</td>
              <td class="px-4 py-2.5 text-center">
                {r.Abandoned
                  ? <span class="text-xs bg-amber-100 text-amber-700 px-1.5 py-0.5 rounded">Yes</span>
                  : <span class="text-xs text-gray-400">No</span>}
              </td>
              <td class="px-4 py-2.5 text-center">
                {r.Contacted_by_phone
                  ? <span class="text-xs bg-blue-100 text-blue-700 px-1.5 py-0.5 rounded">Yes</span>
                  : <span class="text-xs text-gray-400">No</span>}
              </td>
              <td class="px-4 py-2.5 text-center text-xs text-gray-500">
                {r.TotalProds > 0 ? `${r.TotalProds} prod${r.TotalProds !== 1 ? "s" : ""} (${r.TotalItems})` : "—"}
              </td>
              <td class="px-4 py-2.5 text-right text-gray-700">
                {r.OrderTotal != null ? `$${Number(r.OrderTotal).toFixed(2)}` : "—"}
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>

  {totalPages > 1 && (
    <div class="flex justify-end mt-3 gap-1 text-sm">
      {opts.page > 1 && <a href={pageUrl(opts.page - 1)} class="px-2 py-1 rounded border border-gray-200 hover:bg-gray-50">‹</a>}
      {winStart > 1 && <span class="px-2 py-1 text-gray-400">…</span>}
      {Array.from({length: winEnd - winStart + 1}, (_, i) => winStart + i).map(pg => (
        <a href={pageUrl(pg)}
           class={`px-2 py-1 rounded border ${pg === opts.page ? "bg-blue-600 text-white border-blue-600" : "border-gray-200 hover:bg-gray-50"}`}>
          {pg}
        </a>
      ))}
      {winEnd < totalPages && <span class="px-2 py-1 text-gray-400">…</span>}
      {opts.page < totalPages && <a href={pageUrl(opts.page + 1)} class="px-2 py-1 rounded border border-gray-200 hover:bg-gray-50">›</a>}
    </div>
  )}
</AdminLayout>
