---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import {
  getAvataxSettings, getAvataxStates,
  saveAvataxKeys, saveNucomKeys, saveAvataxStates,
  fetchNucomToken,
} from "../../../lib/queries/admin-avatax";

let error = "";
let nucomWarn = "";

if (Astro.request.method === "POST") {
  const d = await Astro.request.formData();
  const g = (k: string) => (d.get(k) as string ?? "").trim();
  const bit = (k: string) => g(k) === "1";

  // Always save Avatax keys
  try {
    await saveAvataxKeys({
      AccountID:    g("AccountID"),
      APIkey:       g("APIkey"),
      CompanyCode:  g("CompanyCode"),
      CustomerCode: g("CustomerCode"),
      APIURL:       g("APIURL"),
      TaxShipping:  bit("TaxShipping"),
      TaxAddress:   g("TaxAddress"),
    });
  } catch (e: unknown) {
    error = e instanceof Error ? e.message : String(e);
  }

  // Try to exchange Nucom credentials for a token; only save Nucom keys if successful
  if (!error) {
    const nucomServicesURL  = g("nucomServicesURL");
    const nucomClientKey    = g("NucomClientKey");
    const nucomClientSecret = g("NucomClientSecret");
    const nucomAPIKey       = g("NucomAPIKey");
    const cfWebstoreURL     = g("CFWebstoreURL");

    if (nucomServicesURL && nucomClientKey && nucomClientSecret) {
      const token = await fetchNucomToken(
        nucomServicesURL, nucomClientKey, nucomClientSecret, nucomAPIKey, cfWebstoreURL
      );
      if (token) {
        await saveNucomKeys({
          nucomServicesURL,
          NucomClientKey:    nucomClientKey,
          NucomClientSecret: nucomClientSecret,
          NucomAPIKey:       nucomAPIKey,
          CFWebstoreURL:     cfWebstoreURL,
          NucomAccessToken:  token,
        });
      } else {
        nucomWarn = "Could not generate a valid Nucom access token — Nucom keys were not saved.";
      }
    }

    // Save active states
    const stateCodes = d.getAll("statecode") as string[];
    await saveAvataxStates(stateCodes);

    if (!nucomWarn) {
      return Astro.redirect("/admin/tax/avatax?saved=1");
    } else {
      return Astro.redirect("/admin/tax/avatax?saved=1&nucomwarn=1");
    }
  }
}

const saved     = Astro.url.searchParams.get("saved") === "1";
const nucomwarn = Astro.url.searchParams.get("nucomwarn") === "1";

const [s, states] = await Promise.all([
  getAvataxSettings(),
  getAvataxStates(),
]);
---

<AdminLayout title="Avatax Manager">
  <div class="flex items-center gap-3 mb-5">
    <a href="/admin/tax" class="text-sm text-blue-600 hover:underline">← Back to Tax</a>
  </div>

  {saved && (
    <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">
      Settings saved.
      {nucomwarn && (
        <span class="ml-2 text-amber-600">Warning: Could not generate a valid Nucom access token — Nucom keys were not saved.</span>
      )}
    </div>
  )}
  {error && (
    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
  )}

  {!s?.NucomAPIKey && (
    <div class="mb-5 rounded-lg bg-blue-50 border border-blue-200 px-4 py-3 text-sm text-blue-800">
      <strong>Avatax</strong> provides up-to-date sales tax rates across multiple states and handles remittance automatically.
      You will need an account with <a href="https://www.avalara.com" target="_blank" rel="noopener" class="underline">Avalara</a>
      and the Avatax API from Nucom Web Hosting.
    </div>
  )}

  <form method="post" class="space-y-8 max-w-2xl">

    <!-- Avatax Keys -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-4">
      <h2 class="text-sm font-semibold text-gray-700 border-b border-gray-100 pb-2">Avatax Keys</h2>

      <div class="grid grid-cols-3 gap-3 items-center">
        <label class="text-sm text-gray-600 font-medium text-right">Account ID</label>
        <input type="text" name="AccountID" value={s?.AccountID ?? ""} maxlength="100"
               class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
      </div>

      <div class="grid grid-cols-3 gap-3 items-center">
        <label class="text-sm text-gray-600 font-medium text-right">License Key <span class="text-red-500">*</span></label>
        <input type="text" name="APIkey" value={s?.APIkey ?? ""} maxlength="100" required
               class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
      </div>

      <div class="grid grid-cols-3 gap-3 items-center">
        <label class="text-sm text-gray-600 font-medium text-right">Company Code</label>
        <input type="text" name="CompanyCode" value={s?.CompanyCode ?? ""} maxlength="100"
               class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
      </div>

      <div class="grid grid-cols-3 gap-3 items-center">
        <label class="text-sm text-gray-600 font-medium text-right">Customer Code</label>
        <input type="text" name="CustomerCode" value={s?.CustomerCode ?? ""} maxlength="100"
               class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
      </div>

      <div class="grid grid-cols-3 gap-3 items-start">
        <label class="text-sm text-gray-600 font-medium text-right pt-1">API URL</label>
        <div class="col-span-2">
          <input type="text" name="APIURL" value={s?.APIURL ?? ""} maxlength="100"
                 class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
          <p class="text-xs text-gray-400 mt-0.5">
            See Avalara documentation for the correct service URL for your account type.
          </p>
        </div>
      </div>
    </div>

    <!-- Nucom Keys -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-4">
      <h2 class="text-sm font-semibold text-gray-700 border-b border-gray-100 pb-2">Nucom Keys</h2>

      {s?.NucomAccessToken && (
        <div class="text-xs text-green-700 bg-green-50 border border-green-200 rounded px-3 py-2">
          Access token is set. Saving new credentials will attempt to refresh it.
        </div>
      )}

      <div class="grid grid-cols-3 gap-3 items-center">
        <label class="text-sm text-gray-600 font-medium text-right">Nucom Services URL</label>
        <input type="url" name="nucomServicesURL" value={s?.nucomServicesURL ?? ""} maxlength="250"
               placeholder="https://www.nucomwebhosting.com"
               class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
      </div>

      <div class="grid grid-cols-3 gap-3 items-center">
        <label class="text-sm text-gray-600 font-medium text-right">Client Key</label>
        <input type="text" name="NucomClientKey" value={s?.NucomClientKey ?? ""} maxlength="100"
               class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
      </div>

      <div class="grid grid-cols-3 gap-3 items-center">
        <label class="text-sm text-gray-600 font-medium text-right">Client Secret</label>
        <input type="text" name="NucomClientSecret" value={s?.NucomClientSecret ?? ""} maxlength="100"
               class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
      </div>

      <div class="grid grid-cols-3 gap-3 items-center">
        <label class="text-sm text-gray-600 font-medium text-right">Nucom API Key</label>
        <input type="text" name="NucomAPIKey" value={s?.NucomAPIKey ?? ""} maxlength="100"
               class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
      </div>

      <div class="grid grid-cols-3 gap-3 items-center">
        <label class="text-sm text-gray-600 font-medium text-right">CFWebstore URL</label>
        <input type="url" name="CFWebstoreURL" value={s?.CFWebstoreURL ?? ""} maxlength="100"
               placeholder="https://www.mydomain.com"
               class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
      </div>
    </div>

    <!-- Avatax Settings -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-4">
      <h2 class="text-sm font-semibold text-gray-700 border-b border-gray-100 pb-2">Avatax Settings</h2>

      <div class="grid grid-cols-3 gap-3 items-center">
        <span class="text-sm text-gray-600 font-medium text-right">Tax Shipping? <span class="text-red-500">*</span></span>
        <div class="col-span-2 flex gap-4">
          <label class="flex items-center gap-2 text-sm">
            <input type="radio" name="TaxShipping" value="1" required checked={s?.TaxShipping} /> Yes
          </label>
          <label class="flex items-center gap-2 text-sm">
            <input type="radio" name="TaxShipping" value="0" checked={!s?.TaxShipping} /> No
          </label>
        </div>
      </div>

      <div class="grid grid-cols-3 gap-3 items-center">
        <label class="text-sm text-gray-600 font-medium text-right">Address used for Tax <span class="text-red-500">*</span></label>
        <select name="TaxAddress" required
                class="col-span-2 w-48 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">
          <option value="Billing"  selected={s?.TaxAddress === "Billing"  || !s?.TaxAddress}>Billing Address</option>
          <option value="Shipping" selected={s?.TaxAddress === "Shipping"}>Shipping Address</option>
        </select>
      </div>
    </div>

    <!-- States -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
      <h2 class="text-sm font-semibold text-gray-700 border-b border-gray-100 pb-2 mb-4">Active States</h2>
      <p class="text-xs text-gray-500 mb-4">Check each state where Avatax should calculate and record sales tax.</p>

      <div class="grid grid-cols-2 gap-x-8 gap-y-2 sm:grid-cols-3">
        {states.map(st => (
          <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
            <input type="checkbox" name="statecode" value={st.Abb} checked={st.active}
                   class="rounded border-gray-300 text-blue-600 focus:ring-blue-400" />
            <span class="font-mono text-xs text-gray-500 w-7">{st.Abb}</span>
            {st.Name}
          </label>
        ))}
      </div>
    </div>

    <div>
      <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded text-sm hover:bg-blue-700">
        Save Settings
      </button>
    </div>

  </form>
</AdminLayout>
