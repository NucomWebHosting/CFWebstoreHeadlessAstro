---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import {
  getAvataxSettings, getAvataxStates,
  saveAvataxSettings, saveAvataxStates,
} from "../../../lib/queries/admin-avatax";

let error = "";

if (Astro.request.method === "POST") {
  const d = await Astro.request.formData();
  const g = (k: string) => (d.get(k) as string ?? "").trim();

  try {
    await saveAvataxSettings({
      AccountID:    g("AccountID"),
      APIkey:       g("APIkey"),
      CompanyCode:  g("CompanyCode"),
      CustomerCode: g("CustomerCode"),
      APIURL:       g("APIURL"),
      TaxShipping:  g("TaxShipping") === "1",
      TaxAddress:   g("TaxAddress"),
    });

    const stateCodes = d.getAll("statecode") as string[];
    await saveAvataxStates(stateCodes);

    return Astro.redirect("/admin/tax/avatax?saved=1");
  } catch (e: unknown) {
    error = e instanceof Error ? e.message : String(e);
  }
}

const saved = Astro.url.searchParams.get("saved") === "1";

const [s, states] = await Promise.all([
  getAvataxSettings(),
  getAvataxStates(),
]);
---

<AdminLayout title="Avatax Settings">
  <h1 class="text-xl font-semibold text-gray-800 mb-6">Avatax Settings</h1>

  {saved && (
    <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">
      Settings saved.
    </div>
  )}
  {error && (
    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
  )}

  <form method="post" class="space-y-6 max-w-2xl">

    <!-- Avatax Keys -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-5 py-3 bg-gray-50 border-b border-gray-200 flex items-center gap-3">
        <span class="text-sm font-semibold text-gray-700">Avatax Keys</span>
        <div class="flex-1 border-t border-gray-200"></div>
      </div>
      <div class="px-5 py-4 space-y-4">

        <div class="grid grid-cols-3 gap-3 items-center">
          <label class="text-sm font-medium text-gray-700 text-right">Account ID</label>
          <input type="text" name="AccountID" value={s?.AccountID ?? ""} maxlength="100"
            class="col-span-2 border border-gray-300 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>

        <div class="grid grid-cols-3 gap-3 items-center">
          <label class="text-sm font-medium text-gray-700 text-right">
            License Key <span class="text-red-500">*</span>
          </label>
          <input type="text" name="APIkey" value={s?.APIkey ?? ""} maxlength="100" required
            class="col-span-2 border border-gray-300 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>

        <div class="grid grid-cols-3 gap-3 items-center">
          <label class="text-sm font-medium text-gray-700 text-right">Company Code</label>
          <input type="text" name="CompanyCode" value={s?.CompanyCode ?? ""} maxlength="100"
            class="col-span-2 border border-gray-300 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>

        <div class="grid grid-cols-3 gap-3 items-center">
          <label class="text-sm font-medium text-gray-700 text-right">Customer Code</label>
          <input type="text" name="CustomerCode" value={s?.CustomerCode ?? ""} maxlength="100"
            class="col-span-2 border border-gray-300 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>

        <div class="grid grid-cols-3 gap-3 items-start">
          <label class="text-sm font-medium text-gray-700 text-right pt-2">API URL</label>
          <div class="col-span-2">
            <input type="text" name="APIURL" value={s?.APIURL ?? ""} maxlength="100"
              class="w-full border border-gray-300 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
            <p class="text-xs text-gray-400 mt-1">
              See <a href="https://developer.avalara.com/avatax/sandbox-vs-production/" target="_blank" rel="noopener" class="underline">Avalara documentation</a> for the correct service URL.
            </p>
          </div>
        </div>

      </div>
    </div>

    <!-- Avatax Settings -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-5 py-3 bg-gray-50 border-b border-gray-200 flex items-center gap-3">
        <span class="text-sm font-semibold text-gray-700">Avatax Settings</span>
        <div class="flex-1 border-t border-gray-200"></div>
      </div>
      <div class="px-5 py-4 space-y-4">

        <div class="grid grid-cols-3 gap-3 items-center">
          <span class="text-sm font-medium text-gray-700 text-right">
            Tax Shipping? <span class="text-red-500">*</span>
          </span>
          <div class="col-span-2 flex gap-5">
            <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
              <input type="radio" name="TaxShipping" value="1" required checked={s?.TaxShipping === true} /> Yes
            </label>
            <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
              <input type="radio" name="TaxShipping" value="0" checked={!s?.TaxShipping} /> No
            </label>
          </div>
        </div>

        <div class="grid grid-cols-3 gap-3 items-center">
          <label class="text-sm font-medium text-gray-700 text-right">
            Address for Tax <span class="text-red-500">*</span>
          </label>
          <select name="TaxAddress" required
            class="col-span-2 w-48 border border-gray-300 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            <option value="Billing"  selected={s?.TaxAddress === "Billing"  || !s?.TaxAddress}>Billing Address</option>
            <option value="Shipping" selected={s?.TaxAddress === "Shipping"}>Shipping Address</option>
          </select>
        </div>

      </div>
    </div>

    <!-- Active States -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-5 py-3 bg-gray-50 border-b border-gray-200 flex items-center gap-3">
        <span class="text-sm font-semibold text-gray-700">Active States</span>
        <div class="flex-1 border-t border-gray-200"></div>
      </div>
      <div class="px-5 py-4">
        <p class="text-xs text-gray-500 mb-4">Check each state where Avatax should calculate and record sales tax.</p>
        <div class="grid grid-cols-2 gap-x-8 gap-y-2 sm:grid-cols-3">
          {states.map(st => (
            <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
              <input type="checkbox" name="statecode" value={st.Abb} checked={st.active}
                class="rounded border-gray-300 text-blue-600 focus:ring-blue-400" />
              <span class="font-mono text-xs text-gray-500 w-7">{st.Abb}</span>
              {st.Name}
            </label>
          ))}
        </div>
      </div>
    </div>

    <div>
      <button type="submit"
        class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-5 py-2 rounded-lg transition-colors">
        Save Settings
      </button>
    </div>

  </form>
</AdminLayout>
