---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import { getTaxCodes, updateCalcOrders } from "../../../lib/queries/admin-tax";

// ── POST: bulk-update CalcOrder + Cumulative ──────────────────────────────────
if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  const ids = (data.get("code_ids") as string ?? "").split(",").map(Number).filter(Boolean);
  await updateCalcOrders(
    ids.map(id => ({
      codeId: id,
      calcOrder: parseInt(data.get(`CalcOrder_${id}`) as string) || 0,
      cumulative: data.get(`Cumulative_${id}`) === "1",
    }))
  );
  return Astro.redirect("/admin/tax?saved=1");
}

const codes = await getTaxCodes();
const saved = Astro.url.searchParams.get("saved") === "1";
---

<AdminLayout title="Tax Manager">

  {saved && (
    <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">
      Saved successfully.
    </div>
  )}

  <div class="flex items-center justify-between mb-4">
    <p class="text-sm text-gray-500">
      {codes.length} tax code{codes.length !== 1 ? "s" : ""}. Taxes are calculated in CalcOrder sequence (lowest first).
    </p>
    <a href="/admin/tax/new"
       class="bg-blue-600 text-white px-4 py-1.5 rounded text-sm hover:bg-blue-700">
      + New Tax Code
    </a>
  </div>

  {codes.length === 0 ? (
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-10 text-center text-gray-400 text-sm">
      No tax codes defined.
    </div>
  ) : (
    <form method="post">
      <input type="hidden" name="code_ids" value={codes.map(c => c.Code_ID).join(",")} />

      <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
            <tr>
              <th class="px-4 py-2.5 text-left">Name</th>
              <th class="px-4 py-2.5 text-left">Display Name</th>
              <th class="px-4 py-2.5 text-center w-20">Tax All</th>
              <th class="px-4 py-2.5 text-center w-20">Show on Prods</th>
              <th class="px-4 py-2.5 text-center w-20">Rate</th>
              <th class="px-4 py-2.5 text-center w-20">Tax Ship</th>
              <th class="px-4 py-2.5 text-center w-20">Address</th>
              <th class="px-4 py-2.5 text-center w-24">Calc Order</th>
              <th class="px-4 py-2.5 text-center w-20">Cumulative</th>
              <th class="px-4 py-2.5 text-left w-32">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {codes.map(c => (
              <tr class="hover:bg-gray-50">
                <td class="px-4 py-2.5 font-medium text-gray-800">{c.CodeName}</td>
                <td class="px-4 py-2.5 text-gray-600">{c.DisplayName}</td>
                <td class="px-4 py-2.5 text-center">
                  {c.TaxAll
                    ? <span class="text-xs text-green-600 font-medium">Yes</span>
                    : <span class="text-xs text-gray-300">No</span>}
                </td>
                <td class="px-4 py-2.5 text-center">
                  {c.ShowonProds
                    ? <span class="text-xs text-green-600 font-medium">Yes</span>
                    : <span class="text-xs text-gray-300">No</span>}
                </td>
                <td class="px-4 py-2.5 text-center text-xs">
                  {c.TaxAll || c.ShowonProds ? `${(c.TaxRate * 100).toFixed(4).replace(/\.?0+$/, "")}%` : "—"}
                </td>
                <td class="px-4 py-2.5 text-center">
                  {c.TaxShipping
                    ? <span class="text-xs text-green-600 font-medium">Yes</span>
                    : <span class="text-xs text-gray-300">No</span>}
                </td>
                <td class="px-4 py-2.5 text-center text-xs text-gray-500">
                  {c.TaxAll ? "—" : c.TaxAddress}
                </td>
                <td class="px-4 py-2.5 text-center">
                  <input type="number" name={`CalcOrder_${c.Code_ID}`} value={c.CalcOrder}
                         min="0" max="99"
                         class="w-14 border border-gray-300 rounded px-1.5 py-0.5 text-xs text-center focus:outline-none focus:ring-1 focus:ring-blue-400" />
                </td>
                <td class="px-4 py-2.5 text-center">
                  <input type="checkbox" name={`Cumulative_${c.Code_ID}`} value="1"
                         checked={c.Cumulative}
                         class="rounded" />
                </td>
                <td class="px-4 py-2.5">
                  <div class="flex gap-1.5">
                    <a href={`/admin/tax/${c.Code_ID}`}
                       class="text-xs text-blue-600 hover:underline">Edit</a>
                    {!c.TaxAll && (
                      <a href={`/admin/tax/${c.Code_ID}/rates`}
                         class="text-xs text-gray-500 hover:underline">Rates</a>
                    )}
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="mt-3 flex justify-end">
        <button type="submit"
                class="bg-blue-600 text-white px-4 py-1.5 rounded text-sm hover:bg-blue-700">
          Save Order &amp; Cumulative
        </button>
      </div>
    </form>
  )}

  <!-- Notes -->
  <div class="mt-6 bg-gray-50 rounded-xl border border-gray-200 p-4 text-xs text-gray-500 space-y-2 max-w-2xl">
    <p><strong class="text-gray-700">Tax All</strong> — applies to all customers regardless of location. Set the rate and shipping option on the code itself.</p>
    <p><strong class="text-gray-700">Show on Products</strong> — displays price with tax included/excluded (VAT). Product prices should be entered without VAT.</p>
    <p><strong class="text-gray-700">Calc Order</strong> — taxes calculated lowest-to-highest. First code is the default applied to all products.</p>
    <p><strong class="text-gray-700">Cumulative</strong> — includes previously calculated taxes in this tax's base.</p>
  </div>

</AdminLayout>
