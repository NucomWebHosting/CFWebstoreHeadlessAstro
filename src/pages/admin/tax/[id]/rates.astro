---
export const prerender = false;
import AdminLayout from "../../../../components/layout/AdminLayout.astro";
import {
  getTaxCode,
  getStateTaxes, saveStateTax, deleteStateTax,
  getCountyTaxes, saveCountyTax, deleteCountyTax,
  getLocalTaxes,  saveLocalTax,  deleteLocalTax,
  getCountryTaxes, saveCountryTax, deleteCountryTax,
  getAllCountries,
} from "../../../../lib/queries/admin-tax";

const id = Number(Astro.params.id);
if (!id) return new Response(null, { status: 404 });

const tab = Astro.url.searchParams.get("tab") ?? "state";

// ── POST ───────────────────────────────────────────────────────────────────────
if (Astro.request.method === "POST") {
  const d = await Astro.request.formData();
  const g  = (k: string) => (d.get(k) as string) ?? "";
  const action = g("_action");

  try {
    if (action === "save_state") {
      await saveStateTax(
        parseInt(g("Tax_ID")) || 0, id,
        g("State"),
        (parseFloat(g("TaxRate")) || 0) / 100,
        g("TaxShip") === "1"
      );
    } else if (action === "delete_state") {
      await deleteStateTax(parseInt(g("Tax_ID")));
    } else if (action === "save_county") {
      await saveCountyTax(
        parseInt(g("County_ID")) || 0, id,
        g("State"), g("Name"),
        (parseFloat(g("TaxRate")) || 0) / 100,
        g("TaxShip") === "1"
      );
    } else if (action === "delete_county") {
      await deleteCountyTax(parseInt(g("County_ID")));
    } else if (action === "save_local") {
      await saveLocalTax(
        parseInt(g("Tax_ID")) || 0, id,
        g("ZipCode"), g("EndZip"),
        (parseFloat(g("Tax")) || 0) / 100,
        g("TaxShip") === "1"
      );
    } else if (action === "delete_local") {
      await deleteLocalTax(parseInt(g("Tax_ID")));
    } else if (action === "save_country") {
      await saveCountryTax(
        parseInt(g("Tax_ID")) || 0, id,
        parseInt(g("Country_ID")) || 0,
        (parseFloat(g("TaxRate")) || 0) / 100,
        g("TaxShip") === "1"
      );
    } else if (action === "delete_country") {
      await deleteCountryTax(parseInt(g("Tax_ID")));
    }
  } catch (e) {
    const msg = e instanceof Error ? e.message : String(e);
    return new Response(`Error: ${msg}`, { status: 500, headers: { "content-type": "text/plain" } });
  }
  return Astro.redirect(`/admin/tax/${id}/rates?tab=${tab}&saved=1`);
}

// ── Fetch ──────────────────────────────────────────────────────────────────────
const [code, countries] = await Promise.all([
  getTaxCode(id),
  getAllCountries(),
]);
if (!code) return new Response(`Tax code ${id} not found.`, { status: 404, headers: { "content-type": "text/plain" } });

const [stateTaxes, countyTaxes, localTaxes, countryTaxes] = await Promise.all([
  getStateTaxes(id),
  getCountyTaxes(id),
  getLocalTaxes(id),
  getCountryTaxes(id),
]);

const saved = Astro.url.searchParams.get("saved") === "1";

function fmtRate(r: number) {
  return parseFloat((r * 100).toPrecision(10)).toString();
}

// US States list
const US_STATES = [
  ["AL","Alabama"],["AK","Alaska"],["AZ","Arizona"],["AR","Arkansas"],["CA","California"],
  ["CO","Colorado"],["CT","Connecticut"],["DE","Delaware"],["FL","Florida"],["GA","Georgia"],
  ["HI","Hawaii"],["ID","Idaho"],["IL","Illinois"],["IN","Indiana"],["IA","Iowa"],
  ["KS","Kansas"],["KY","Kentucky"],["LA","Louisiana"],["ME","Maine"],["MD","Maryland"],
  ["MA","Massachusetts"],["MI","Michigan"],["MN","Minnesota"],["MS","Mississippi"],["MO","Missouri"],
  ["MT","Montana"],["NE","Nebraska"],["NV","Nevada"],["NH","New Hampshire"],["NJ","New Jersey"],
  ["NM","New Mexico"],["NY","New York"],["NC","North Carolina"],["ND","North Dakota"],["OH","Ohio"],
  ["OK","Oklahoma"],["OR","Oregon"],["PA","Pennsylvania"],["RI","Rhode Island"],["SC","South Carolina"],
  ["SD","South Dakota"],["TN","Tennessee"],["TX","Texas"],["UT","Utah"],["VT","Vermont"],
  ["VA","Virginia"],["WA","Washington"],["WV","West Virginia"],["WI","Wisconsin"],["WY","Wyoming"],
  ["DC","District of Columbia"],
];

const tabs = [
  { key: "state",   label: `State (${stateTaxes.length})`   },
  { key: "county",  label: `County (${countyTaxes.length})`  },
  { key: "local",   label: `Zip/Local (${localTaxes.length})`},
  { key: "country", label: `Country (${countryTaxes.length})`},
];

// Inline form helpers
const fmShared = "border border-gray-300 rounded px-2 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400";
---

<AdminLayout title={`Rates: ${code.CodeName}`}>

  <div class="flex items-center gap-3 mb-5">
    <a href="/admin/tax" class="text-sm text-blue-600 hover:underline">← Tax Codes</a>
    <span class="text-gray-300">|</span>
    <a href={`/admin/tax/${id}`} class="text-sm text-blue-600 hover:underline">Edit Code</a>
    <span class="text-gray-300">|</span>
    <span class="text-sm text-gray-500">{code.CodeName}</span>
  </div>

  {saved && (
    <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">Saved.</div>
  )}

  <!-- Tabs -->
  <div class="flex gap-1 mb-5 border-b border-gray-200">
    {tabs.map(t => (
      <a href={`/admin/tax/${id}/rates?tab=${t.key}`}
         class={`px-4 py-2 text-sm font-medium border-b-2 -mb-px transition-colors ${
           tab === t.key
             ? "border-blue-600 text-blue-600"
             : "border-transparent text-gray-500 hover:text-gray-700"
         }`}>
        {t.label}
      </a>
    ))}
  </div>

  <!-- ── STATE ─────────────────────────────────────────────────────────────── -->
  {tab === "state" && (
    <div class="space-y-5">
      <!-- Add/Edit form -->
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 max-w-lg">
        <h3 class="text-sm font-semibold text-gray-700 mb-3">Add State Rate</h3>
        <form method="post" class="flex flex-wrap gap-3 items-end">
          <input type="hidden" name="_action" value="save_state" />
          <input type="hidden" name="Tax_ID" value="0" />
          <div>
            <label class="block text-xs text-gray-500 mb-1">State</label>
            <select name="State" required class={fmShared}>
              <option value="">— select —</option>
              {US_STATES.map(([abb, name]) => <option value={abb}>{name} ({abb})</option>)}
            </select>
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Tax Rate</label>
            <div class="flex items-center gap-1">
              <input type="number" name="TaxRate" step="any" min="0" max="99" required
                     class={`w-20 ${fmShared}`} />
              <span class="text-sm text-gray-400">%</span>
            </div>
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Tax Shipping</label>
            <select name="TaxShip" class={fmShared}>
              <option value="0">No</option>
              <option value="1">Yes</option>
            </select>
          </div>
          <button type="submit" class="bg-blue-600 text-white px-3 py-1.5 rounded text-sm hover:bg-blue-700">
            Add
          </button>
        </form>
      </div>

      <!-- List -->
      {stateTaxes.length === 0 ? (
        <p class="text-sm text-gray-400">No state rates defined.</p>
      ) : (
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
          <table class="w-full text-sm">
            <thead class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
              <tr>
                <th class="px-4 py-2.5 text-left">State</th>
                <th class="px-4 py-2.5 text-right w-24">Rate</th>
                <th class="px-4 py-2.5 text-center w-24">Tax Ship</th>
                <th class="px-4 py-2.5 text-left w-32">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {stateTaxes.map(r => (
                <tr class="hover:bg-gray-50">
                  <td class="px-4 py-2 font-medium">{r.State}</td>
                  <td class="px-4 py-2 text-right text-xs">{fmtRate(r.TaxRate)}%</td>
                  <td class="px-4 py-2 text-center text-xs">{r.TaxShip ? "Yes" : "No"}</td>
                  <td class="px-4 py-2">
                    <form method="post" class="inline"
                          onsubmit="return confirm('Delete this state rate?')">
                      <input type="hidden" name="_action" value="delete_state" />
                      <input type="hidden" name="Tax_ID" value={String(r.Tax_ID)} />
                      <button type="submit" class="text-xs text-red-500 hover:underline">Delete</button>
                    </form>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  )}

  <!-- ── COUNTY ────────────────────────────────────────────────────────────── -->
  {tab === "county" && (
    <div class="space-y-5">
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 max-w-xl">
        <h3 class="text-sm font-semibold text-gray-700 mb-3">Add County Rate</h3>
        <form method="post" class="flex flex-wrap gap-3 items-end">
          <input type="hidden" name="_action" value="save_county" />
          <input type="hidden" name="County_ID" value="0" />
          <div>
            <label class="block text-xs text-gray-500 mb-1">State</label>
            <select name="State" required class={fmShared}>
              <option value="">— select —</option>
              {US_STATES.map(([abb, name]) => <option value={abb}>{abb}</option>)}
            </select>
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">County Name</label>
            <input type="text" name="Name" required maxlength="100" class={fmShared} />
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Tax Rate</label>
            <div class="flex items-center gap-1">
              <input type="number" name="TaxRate" step="any" min="0" max="99" required
                     class={`w-20 ${fmShared}`} />
              <span class="text-sm text-gray-400">%</span>
            </div>
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Tax Shipping</label>
            <select name="TaxShip" class={fmShared}>
              <option value="0">No</option>
              <option value="1">Yes</option>
            </select>
          </div>
          <button type="submit" class="bg-blue-600 text-white px-3 py-1.5 rounded text-sm hover:bg-blue-700">
            Add
          </button>
        </form>
      </div>

      {countyTaxes.length === 0 ? (
        <p class="text-sm text-gray-400">No county rates defined.</p>
      ) : (
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
          <table class="w-full text-sm">
            <thead class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
              <tr>
                <th class="px-4 py-2.5 text-left w-16">State</th>
                <th class="px-4 py-2.5 text-left">County</th>
                <th class="px-4 py-2.5 text-right w-24">Rate</th>
                <th class="px-4 py-2.5 text-center w-24">Tax Ship</th>
                <th class="px-4 py-2.5 w-24"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {countyTaxes.map(r => (
                <tr class="hover:bg-gray-50">
                  <td class="px-4 py-2 text-xs text-gray-500">{r.State}</td>
                  <td class="px-4 py-2 font-medium">{r.Name}</td>
                  <td class="px-4 py-2 text-right text-xs">{fmtRate(r.TaxRate)}%</td>
                  <td class="px-4 py-2 text-center text-xs">{r.TaxShip ? "Yes" : "No"}</td>
                  <td class="px-4 py-2">
                    <form method="post" class="inline"
                          onsubmit="return confirm('Delete this county rate?')">
                      <input type="hidden" name="_action" value="delete_county" />
                      <input type="hidden" name="County_ID" value={String(r.County_ID)} />
                      <button type="submit" class="text-xs text-red-500 hover:underline">Delete</button>
                    </form>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  )}

  <!-- ── LOCAL / ZIP ───────────────────────────────────────────────────────── -->
  {tab === "local" && (
    <div class="space-y-5">
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 max-w-xl">
        <h3 class="text-sm font-semibold text-gray-700 mb-3">Add Zip Code Rate</h3>
        <form method="post" class="flex flex-wrap gap-3 items-end">
          <input type="hidden" name="_action" value="save_local" />
          <input type="hidden" name="Tax_ID" value="0" />
          <div>
            <label class="block text-xs text-gray-500 mb-1">Start Zip</label>
            <input type="text" name="ZipCode" required maxlength="10" class={`w-24 ${fmShared}`} />
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">End Zip (optional)</label>
            <input type="text" name="EndZip" maxlength="10" class={`w-24 ${fmShared}`} />
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Tax Rate</label>
            <div class="flex items-center gap-1">
              <input type="number" name="Tax" step="any" min="0" max="99" required
                     class={`w-20 ${fmShared}`} />
              <span class="text-sm text-gray-400">%</span>
            </div>
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Tax Shipping</label>
            <select name="TaxShip" class={fmShared}>
              <option value="0">No</option>
              <option value="1">Yes</option>
            </select>
          </div>
          <button type="submit" class="bg-blue-600 text-white px-3 py-1.5 rounded text-sm hover:bg-blue-700">
            Add
          </button>
        </form>
      </div>

      {localTaxes.length === 0 ? (
        <p class="text-sm text-gray-400">No zip code rates defined.</p>
      ) : (
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
          <table class="w-full text-sm">
            <thead class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
              <tr>
                <th class="px-4 py-2.5 text-left">Start Zip</th>
                <th class="px-4 py-2.5 text-left">End Zip</th>
                <th class="px-4 py-2.5 text-right w-24">Rate</th>
                <th class="px-4 py-2.5 text-center w-24">Tax Ship</th>
                <th class="px-4 py-2.5 w-24"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {localTaxes.map(r => (
                <tr class="hover:bg-gray-50">
                  <td class="px-4 py-2 font-mono text-xs">{r.ZipCode}</td>
                  <td class="px-4 py-2 font-mono text-xs text-gray-500">{r.EndZip || "—"}</td>
                  <td class="px-4 py-2 text-right text-xs">{fmtRate(r.Tax)}%</td>
                  <td class="px-4 py-2 text-center text-xs">{r.TaxShip ? "Yes" : "No"}</td>
                  <td class="px-4 py-2">
                    <form method="post" class="inline"
                          onsubmit="return confirm('Delete this zip rate?')">
                      <input type="hidden" name="_action" value="delete_local" />
                      <input type="hidden" name="Tax_ID" value={String(r.Tax_ID)} />
                      <button type="submit" class="text-xs text-red-500 hover:underline">Delete</button>
                    </form>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  )}

  <!-- ── COUNTRY ───────────────────────────────────────────────────────────── -->
  {tab === "country" && (
    <div class="space-y-5">
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 max-w-xl">
        <h3 class="text-sm font-semibold text-gray-700 mb-3">Add Country Rate</h3>
        <form method="post" class="flex flex-wrap gap-3 items-end">
          <input type="hidden" name="_action" value="save_country" />
          <input type="hidden" name="Tax_ID" value="0" />
          <div>
            <label class="block text-xs text-gray-500 mb-1">Country</label>
            <select name="Country_ID" required class={fmShared}>
              <option value="">— select —</option>
              {countries.map(c => <option value={String(c.ID)}>{c.Name}</option>)}
            </select>
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Tax Rate</label>
            <div class="flex items-center gap-1">
              <input type="number" name="TaxRate" step="any" min="0" max="99" required
                     class={`w-20 ${fmShared}`} />
              <span class="text-sm text-gray-400">%</span>
            </div>
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Tax Shipping</label>
            <select name="TaxShip" class={fmShared}>
              <option value="0">No</option>
              <option value="1">Yes</option>
            </select>
          </div>
          <button type="submit" class="bg-blue-600 text-white px-3 py-1.5 rounded text-sm hover:bg-blue-700">
            Add
          </button>
        </form>
      </div>

      {countryTaxes.length === 0 ? (
        <p class="text-sm text-gray-400">No country rates defined.</p>
      ) : (
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
          <table class="w-full text-sm">
            <thead class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
              <tr>
                <th class="px-4 py-2.5 text-left">Country</th>
                <th class="px-4 py-2.5 text-right w-24">Rate</th>
                <th class="px-4 py-2.5 text-center w-24">Tax Ship</th>
                <th class="px-4 py-2.5 w-24"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {countryTaxes.map(r => (
                <tr class="hover:bg-gray-50">
                  <td class="px-4 py-2 font-medium">{r.Name}</td>
                  <td class="px-4 py-2 text-right text-xs">{fmtRate(r.TaxRate)}%</td>
                  <td class="px-4 py-2 text-center text-xs">{r.TaxShip ? "Yes" : "No"}</td>
                  <td class="px-4 py-2">
                    <form method="post" class="inline"
                          onsubmit="return confirm('Delete this country rate?')">
                      <input type="hidden" name="_action" value="delete_country" />
                      <input type="hidden" name="Tax_ID" value={String(r.Tax_ID)} />
                      <button type="submit" class="text-xs text-red-500 hover:underline">Delete</button>
                    </form>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  )}

</AdminLayout>
