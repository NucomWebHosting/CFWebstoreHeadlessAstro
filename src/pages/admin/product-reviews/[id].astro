---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import {
  getReview,
  updateReview,
  deleteReview,
  findUserByUsername,
} from "../../../lib/queries/admin-reviews";

const id = parseInt(Astro.params.id ?? "0") || 0;
if (!id) return new Response(null, { status: 404 });

let error = "";

if (Astro.request.method === "POST") {
  const d = await Astro.request.formData();
  const g  = (k: string) => (d.get(k) as string ?? "").trim();
  const action = g("_action");

  if (action === "delete") {
    await deleteReview(id);
    return Astro.redirect("/admin/product-reviews?deleted=1");
  } else {
    // Resolve username → User_ID
    const uname = g("Username");
    let userId: number | null = null;
    if (uname) {
      userId = await findUserByUsername(uname);
      if (userId === null) {
        error = `Username "${uname}" not found.`;
      }
    }

    if (!error) {
      try {
        await updateReview(id, {
          User_ID:       userId,
          Anonymous:     g("Anonymous") === "1" ? 1 : 0,
          Anon_Name:     g("Anon_Name"),
          Anon_Loc:      g("Anon_Loc"),
          Anon_Email:    g("Anon_Email"),
          Title:         g("Title"),
          Comment:       g("Comment"),
          Rating:        parseInt(g("Rating")) || null,
          Posted:        g("Posted") || new Date().toISOString(),
          Updated:       new Date().toISOString(),
          Approved:      g("Approved") === "1" ? 1 : 0,
          NeedsCheck:    g("NeedsCheck") === "1" ? 1 : 0,
          Helpful_Yes:   parseInt(g("Helpful_Yes"))   || 0,
          Helpful_Total: parseInt(g("Helpful_Total")) || 0,
        });
        return Astro.redirect(`/admin/product-reviews/${id}?saved=1`);
      } catch (e: unknown) {
        error = e instanceof Error ? e.message : String(e);
      }
    }
  }
}

const saved = Astro.url.searchParams.get("saved") === "1";
const rev = await getReview(id);
if (!rev) return new Response(`Review ${id} not found.`, { status: 404, headers: { "content-type": "text/plain" } });

function fmt(d: Date | null) {
  if (!d) return "";
  const dt = new Date(d);
  return dt.toISOString().substring(0, 10);
}
---

<AdminLayout title={`Review ${id}`}>
  <div class="flex items-center gap-3 mb-5">
    <a href="/admin/product-reviews" class="text-sm text-blue-600 hover:underline">← Product Reviews</a>
  </div>

  {saved && (
    <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">Saved.</div>
  )}
  {error && (
    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
  )}

  <!-- Product info header -->
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm px-5 py-3 mb-4 text-sm text-gray-600">
    Product: <span class="font-medium text-gray-800">{rev.Product_Name}</span>
    <span class="text-gray-400 ml-2">(#{rev.Product_ID})</span>
  </div>

  <form method="post" class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-4 max-w-2xl">
    <input type="hidden" name="_action" value="update" />

    <!-- Review ID -->
    <div class="grid grid-cols-3 gap-3 items-center">
      <span class="text-sm text-gray-600 font-medium text-right">Review ID</span>
      <span class="col-span-2 text-sm font-mono text-gray-500">{rev.Review_ID}</span>
    </div>

    <!-- Username -->
    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Username</label>
      <input type="text" name="Username" value={rev.Username ?? ""} maxlength="50"
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <!-- Anonymous -->
    <div class="grid grid-cols-3 gap-3 items-center">
      <span class="text-sm text-gray-600 font-medium text-right">Anonymous</span>
      <div class="col-span-2 flex gap-4">
        <label class="flex items-center gap-2 text-sm">
          <input type="radio" name="Anonymous" value="1" checked={rev.Anonymous} /> Yes
        </label>
        <label class="flex items-center gap-2 text-sm">
          <input type="radio" name="Anonymous" value="0" checked={!rev.Anonymous} /> No
        </label>
      </div>
    </div>

    <!-- Display Name -->
    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Display Name</label>
      <input type="text" name="Anon_Name" value={rev.Anon_Name ?? ""} maxlength="100"
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <!-- Location -->
    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Location</label>
      <input type="text" name="Anon_Loc" value={rev.Anon_Loc ?? ""}
             placeholder="e.g. Los Angeles, CA USA"
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <!-- Anon Email -->
    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Anon Email</label>
      <div class="col-span-2">
        <input type="text" name="Anon_Email" value={rev.Anon_Email ?? ""}
               class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
        <p class="text-xs text-gray-400 mt-0.5">Not displayed publicly.</p>
      </div>
    </div>

    <div class="border-t border-gray-100 pt-2">
      <span class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Review</span>
    </div>

    <!-- Title -->
    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Title <span class="text-red-500">*</span></label>
      <input type="text" name="Title" value={rev.Title} maxlength="50" required
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <!-- Comment -->
    <div class="grid grid-cols-3 gap-3 items-start">
      <label class="text-sm text-gray-600 font-medium text-right pt-1">Comment</label>
      <textarea name="Comment" rows={6}
                class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">{rev.Comment ?? ""}</textarea>
    </div>

    <!-- Rating -->
    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Rating</label>
      <select name="Rating" class="col-span-2 border border-gray-300 rounded px-2 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400 w-auto">
        <option value="5" selected={rev.Rating === 5}>5 Stars — Excellent</option>
        <option value="4" selected={rev.Rating === 4}>4 Stars — Very Good</option>
        <option value="3" selected={rev.Rating === 3}>3 Stars — Average</option>
        <option value="2" selected={rev.Rating === 2}>2 Stars — Below Average</option>
        <option value="1" selected={rev.Rating === 1}>1 Star — Avoid It</option>
      </select>
    </div>

    <div class="border-t border-gray-100 pt-2">
      <span class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Other</span>
    </div>

    <!-- Posted -->
    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Posted</label>
      <input type="date" name="Posted" value={fmt(rev.Posted)}
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400 w-auto" />
    </div>

    <!-- Helpful -->
    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Helpful</label>
      <div class="col-span-2 flex items-center gap-2 text-sm text-gray-600">
        <input type="number" name="Helpful_Yes" value={rev.Helpful_Yes} min="0"
               class="w-20 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
        <span>users of</span>
        <input type="number" name="Helpful_Total" value={rev.Helpful_Total} min="0"
               class="w-20 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
        <span>found this helpful</span>
      </div>
    </div>

    <!-- Approved -->
    <div class="grid grid-cols-3 gap-3 items-center">
      <span class="text-sm text-gray-600 font-medium text-right">Approved <span class="text-red-500">*</span></span>
      <div class="col-span-2 flex gap-4">
        <label class="flex items-center gap-2 text-sm">
          <input type="radio" name="Approved" value="1" checked={rev.Approved} required /> Yes
        </label>
        <label class="flex items-center gap-2 text-sm">
          <input type="radio" name="Approved" value="0" checked={!rev.Approved} /> No
        </label>
      </div>
    </div>

    <!-- Needs Check -->
    <div class="grid grid-cols-3 gap-3 items-center">
      <span class="text-sm text-gray-600 font-medium text-right">Needs Check <span class="text-red-500">*</span></span>
      <div class="col-span-2 flex gap-4">
        <label class="flex items-center gap-2 text-sm">
          <input type="radio" name="NeedsCheck" value="1" checked={rev.NeedsCheck} required /> Yes
        </label>
        <label class="flex items-center gap-2 text-sm">
          <input type="radio" name="NeedsCheck" value="0" checked={!rev.NeedsCheck} /> No
        </label>
      </div>
    </div>

    <div class="flex items-center gap-3 pt-2">
      <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded text-sm hover:bg-blue-700">
        Update Review
      </button>
      <a href="/admin/product-reviews" class="px-4 py-2 rounded text-sm border border-gray-300 text-gray-600 hover:bg-gray-50">
        Cancel
      </a>
    </div>
  </form>

  <!-- Delete -->
  <div class="mt-5 max-w-2xl">
    <form method="post"
          onsubmit={`return confirm('Delete review #${id}?')`}>
      <input type="hidden" name="_action" value="delete" />
      <button type="submit" class="px-4 py-2 rounded text-sm border border-red-300 text-red-600 hover:bg-red-50">
        Delete Review
      </button>
    </form>
  </div>

</AdminLayout>
