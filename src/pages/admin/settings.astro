---
export const prerender = false;
import AdminLayout from "../../components/layout/AdminLayout.astro";
import { updateSettings } from "../../lib/queries/admin";
import { getSettings } from "../../lib/queries/settings";

let error = "";

if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  try {
    await updateSettings(data);
    // Bust settings cache by clearing module-level variable via restart — but we can't
    // do that directly. For now, just redirect. The cache resets on next PM2 restart.
    return Astro.redirect("/admin/settings?saved=1");
  } catch (e) {
    error = e instanceof Error ? e.message : "Failed to save settings.";
  }
}

const settings = await getSettings();
const saved = Astro.url.searchParams.get("saved") === "1";
const v = (field: keyof NonNullable<typeof settings>) => settings?.[field] ?? "";
---
<AdminLayout title="Settings">
  {saved && (
    <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">
      Settings saved. Changes will be visible after the next server restart (pm2 restart) due to caching.
    </div>
  )}
  {error && <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>}

  <form method="post" class="space-y-6">

    <!-- Site Identity -->
    <section class="bg-white rounded-xl border border-gray-200 shadow-sm">
      <div class="px-6 py-4 border-b border-gray-100">
        <h2 class="font-semibold text-gray-800">Site Identity</h2>
      </div>
      <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Site Name</label>
          <input type="text" name="site_name" value={String(v("SiteName"))}
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Site Abbreviation</label>
          <input type="text" name="site_name_ab" value={String(v("SiteNameAB"))}
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Domain Name</label>
          <input type="text" name="domain_name" value={String(v("DomainName"))} placeholder="https://example.com"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Default Images Path</label>
          <input type="text" name="default_images" value={String(v("DefaultImages"))} placeholder="/images"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Desktop Logo (filename)</label>
          <input type="text" name="logo_desktop" value={String(v("Logo_desktop"))}
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Mobile Logo (filename)</label>
          <input type="text" name="logo_mobile" value={String(v("Logo_mobile"))}
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>
      </div>
    </section>

    <!-- Contact Info -->
    <section class="bg-white rounded-xl border border-gray-200 shadow-sm">
      <div class="px-6 py-4 border-b border-gray-100">
        <h2 class="font-semibold text-gray-800">Contact Information</h2>
      </div>
      <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Phone (Order Desk)</label>
          <input type="text" name="phone" value={String(v("Phone"))}
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Phone 2 (International)</label>
          <input type="text" name="phone2" value={String(v("Phone2"))}
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Phone 3 (Fax)</label>
          <input type="text" name="phone3" value={String(v("Phone3"))}
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Phone 4 (Tech Support)</label>
          <input type="text" name="phone4" value={String(v("Phone4"))}
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Address Line 1</label>
          <input type="text" name="address1" value={String(v("Address1"))}
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Address Line 2</label>
          <input type="text" name="address2" value={String(v("Address2"))}
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">City</label>
          <input type="text" name="city" value={String(v("City"))}
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">State</label>
            <input type="text" name="state" value={String(v("State"))}
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">ZIP</label>
            <input type="text" name="postalcode" value={String(v("Postalcode"))}
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
          <input type="email" name="email" value={String(v("Email"))}
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Merchant Email (receives orders)</label>
          <input type="email" name="merchant_email" value={String(v("MerchantEmail"))}
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>
        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-gray-700 mb-1">Google Map Embed (iframe HTML)</label>
          <textarea name="google_map_embed" rows="3"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-blue-500"
          >{String(v("GoogleMapEmbed"))}</textarea>
        </div>
      </div>
    </section>

    <!-- SMTP -->
    <section class="bg-white rounded-xl border border-gray-200 shadow-sm">
      <div class="px-6 py-4 border-b border-gray-100">
        <h2 class="font-semibold text-gray-800">SMTP Email</h2>
      </div>
      <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">SMTP Server</label>
          <input type="text" name="email_server" value={String(v("Email_Server"))}
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Port</label>
          <input type="number" name="email_port" value={String(v("Email_Port") || 587)}
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">SMTP Username</label>
          <input type="text" name="email_user" value={String(v("Email_User"))} autocomplete="username"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">SMTP Password</label>
          <input type="password" name="email_pass" value={String(v("Email_Pass"))} autocomplete="current-password"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>
        <div class="flex gap-6">
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="checkbox" name="email_use_ssl" checked={!!settings?.Email_useSSL} class="rounded" />
            Use SSL
          </label>
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="checkbox" name="email_use_tls" checked={!!settings?.Email_useTLS} class="rounded" />
            Use TLS (STARTTLS)
          </label>
        </div>
      </div>
    </section>

    <div class="flex gap-3">
      <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded-lg text-sm font-semibold hover:bg-blue-700">
        Save Settings
      </button>
    </div>

  </form>
</AdminLayout>
