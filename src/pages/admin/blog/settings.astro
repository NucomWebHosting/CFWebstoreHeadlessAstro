---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import { getBlogSettings, saveBlogSettings } from "../../../lib/queries/admin-blog";

let error  = "";
let saved  = false;

if (Astro.request.method === "POST") {
  const d = await Astro.request.formData();
  const g   = (k: string) => (d.get(k) as string ?? "").trim();
  const bit = (k: string) => g(k) === "1";
  const num = (k: string, fallback = 0) => parseInt(g(k)) || fallback;

  try {
    await saveBlogSettings({
      MaxBlogs:            num("MaxBlogs", 9999),
      blog_columns:        num("blog_columns", 3),
      show_Cloud:          bit("show_Cloud"),
      show_Categories:     bit("show_Categories"),
      show_recentPosts:    bit("show_recentPosts"),
      show_search:         bit("show_search"),
      title:               g("title"),
      metadescription:     g("metadescription"),
      Keywords:            g("Keywords"),
      BlogReviews:         bit("BlogReviews"),
      BlogReview_add:      num("BlogReview_add"),
      BlogReview_flag:     bit("BlogReview_flag"),
      BlogReview_Approve:  bit("BlogReview_Approve"),
      Captcha:             bit("Captcha"),
    });
    return Astro.redirect("/admin/blog/settings?saved=1");
  } catch (e: unknown) {
    error = e instanceof Error ? e.message : String(e);
  }
}

saved = Astro.url.searchParams.get("saved") === "1";
const rec = await getBlogSettings();
---

<AdminLayout title="Blog Settings">
  <div class="flex items-center gap-3 mb-5">
    <a href="/admin/blog" class="text-sm text-blue-600 hover:underline">← Back to Blogs</a>
  </div>

  <!-- Sub-nav -->
  <div class="flex gap-2 mb-5 text-sm">
    <a href="/admin/blog"            class="px-3 py-1.5 rounded text-slate-400 hover:bg-slate-800 hover:text-white">Blogs</a>
    <a href="/admin/blog/categories" class="px-3 py-1.5 rounded text-slate-400 hover:bg-slate-800 hover:text-white">Categories</a>
    <a href="/admin/blog/settings"   class="px-3 py-1.5 rounded bg-slate-700 text-white font-medium">Settings</a>
  </div>

  {saved && (
    <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">Settings saved.</div>
  )}
  {error && (
    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
  )}

  {!rec ? (
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm px-6 py-10 text-center text-sm text-gray-400">
      No settings record found.
    </div>
  ) : (
    <form method="post" class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-4 max-w-2xl">

      <!-- General -->
      <div class="grid grid-cols-3 gap-3 items-center pt-2">
        <div class="text-right text-xs font-semibold text-gray-400 uppercase tracking-wider">General</div>
        <div class="col-span-2 border-t border-gray-100"></div>
      </div>

      <div class="grid grid-cols-3 gap-3 items-center">
        <label class="text-sm text-gray-600 font-medium text-right">Max Posts Per Page</label>
        <input type="number" name="MaxBlogs"
               value={rec.MaxBlogs >= 9999 ? "" : rec.MaxBlogs}
               min="1" max="9999" placeholder="Unlimited"
               class="w-28 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
      </div>

      <div class="grid grid-cols-3 gap-3 items-center">
        <label class="text-sm text-gray-600 font-medium text-right">Columns</label>
        <input type="number" name="blog_columns" value={rec.blog_columns} min="1" max="6"
               class="w-20 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
      </div>

      <!-- Sidebar -->
      <div class="grid grid-cols-3 gap-3 items-center pt-2">
        <div class="text-right text-xs font-semibold text-gray-400 uppercase tracking-wider">Side Bar</div>
        <div class="col-span-2 border-t border-gray-100"></div>
      </div>

      {[
        { key: "show_recentPosts", label: "Show Recent Posts",  val: rec.show_recentPosts },
        { key: "show_Categories",  label: "Show Categories",    val: rec.show_Categories  },
        { key: "show_search",      label: "Show Search",        val: rec.show_search      },
        { key: "show_Cloud",       label: "Show Tag Cloud",     val: rec.show_Cloud       },
      ].map(({ key, label, val }) => (
        <div class="grid grid-cols-3 gap-3 items-center">
          <span class="text-sm text-gray-600 font-medium text-right">{label}</span>
          <div class="col-span-2 flex gap-4">
            <label class="flex items-center gap-2 text-sm"><input type="radio" name={key} value="1" required checked={val} /> Yes</label>
            <label class="flex items-center gap-2 text-sm"><input type="radio" name={key} value="0" checked={!val} /> No</label>
          </div>
        </div>
      ))}

      <!-- Comments -->
      <div class="grid grid-cols-3 gap-3 items-center pt-2">
        <div class="text-right text-xs font-semibold text-gray-400 uppercase tracking-wider">Comments</div>
        <div class="col-span-2 border-t border-gray-100"></div>
      </div>

      <div class="grid grid-cols-3 gap-3 items-center">
        <span class="text-sm text-gray-600 font-medium text-right">Allow Blog Comments</span>
        <div class="col-span-2 flex gap-4">
          <label class="flex items-center gap-2 text-sm"><input type="radio" name="BlogReviews" value="1" required checked={rec.BlogReviews} /> Yes</label>
          <label class="flex items-center gap-2 text-sm"><input type="radio" name="BlogReviews" value="0" checked={!rec.BlogReviews} /> No</label>
        </div>
      </div>

      <div class="grid grid-cols-3 gap-3 items-center">
        <span class="text-sm text-gray-600 font-medium text-right">Use Captcha</span>
        <div class="col-span-2 flex gap-4">
          <label class="flex items-center gap-2 text-sm"><input type="radio" name="Captcha" value="1" required checked={rec.Captcha} /> Yes</label>
          <label class="flex items-center gap-2 text-sm"><input type="radio" name="Captcha" value="0" checked={!rec.Captcha} /> No</label>
        </div>
      </div>

      <div class="grid grid-cols-3 gap-3 items-center">
        <span class="text-sm text-gray-600 font-medium text-right">Approval Required</span>
        <div class="col-span-2 flex gap-4">
          <label class="flex items-center gap-2 text-sm"><input type="radio" name="BlogReview_Approve" value="1" required checked={rec.BlogReview_Approve} /> Yes</label>
          <label class="flex items-center gap-2 text-sm"><input type="radio" name="BlogReview_Approve" value="0" checked={!rec.BlogReview_Approve} /> No</label>
        </div>
      </div>

      <div class="grid grid-cols-3 gap-3 items-center">
        <span class="text-sm text-gray-600 font-medium text-right">Check Comments</span>
        <div class="col-span-2 flex gap-4">
          <label class="flex items-center gap-2 text-sm"><input type="radio" name="BlogReview_flag" value="1" required checked={rec.BlogReview_flag} /> Yes</label>
          <label class="flex items-center gap-2 text-sm"><input type="radio" name="BlogReview_flag" value="0" checked={!rec.BlogReview_flag} /> No</label>
        </div>
      </div>

      <div class="grid grid-cols-3 gap-3 items-start">
        <span class="text-sm text-gray-600 font-medium text-right pt-1">Who Can Comment</span>
        <div class="col-span-2 space-y-1">
          <label class="flex items-center gap-2 text-sm">
            <input type="radio" name="BlogReview_add" value="0" required checked={rec.BlogReview_add === 0} />
            Anyone — no login required
          </label>
          <label class="flex items-center gap-2 text-sm">
            <input type="radio" name="BlogReview_add" value="1" checked={rec.BlogReview_add === 1} />
            Registered Users — login required
          </label>
          <label class="flex items-center gap-2 text-sm">
            <input type="radio" name="BlogReview_add" value="2" checked={rec.BlogReview_add === 2} />
            Verified Users — login + verified email required
          </label>
        </div>
      </div>

      <!-- Blog Home Page SEO -->
      <div class="grid grid-cols-3 gap-3 items-center pt-2">
        <div class="text-right text-xs font-semibold text-gray-400 uppercase tracking-wider">Blog Home Page</div>
        <div class="col-span-2 border-t border-gray-100"></div>
      </div>

      <div class="grid grid-cols-3 gap-3 items-center">
        <label class="text-sm text-gray-600 font-medium text-right">HTML Title</label>
        <input type="text" name="title" value={rec.title ?? ""} maxlength="50"
               class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
      </div>

      <div class="grid grid-cols-3 gap-3 items-start">
        <label class="text-sm text-gray-600 font-medium text-right pt-1">Meta Description</label>
        <textarea name="metadescription" rows={3} maxlength="255"
                  class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">{rec.metadescription ?? ""}</textarea>
      </div>

      <div class="grid grid-cols-3 gap-3 items-start">
        <label class="text-sm text-gray-600 font-medium text-right pt-1">Keywords</label>
        <textarea name="Keywords" rows={3} maxlength="255"
                  class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">{rec.Keywords ?? ""}</textarea>
      </div>

      <div class="pt-2">
        <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded text-sm hover:bg-blue-700">
          Save Settings
        </button>
      </div>
    </form>
  )}
</AdminLayout>
