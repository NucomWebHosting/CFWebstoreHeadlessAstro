---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import {
  getBlogs, getBlogCategories, getBlogStatus, PAGE_SIZE,
} from "../../../lib/queries/admin-blog";

const sp = Astro.url.searchParams;
const search         = sp.get("search") ?? "";
const category_id    = sp.get("category_id") ?? "";
const display_status = sp.get("display_status") ?? "";
const order          = sp.get("order") ?? "";
const page           = parseInt(sp.get("page") ?? "1") || 1;

const [{ rows, total }, categories] = await Promise.all([
  getBlogs({ search, category_id, display_status, order, page }),
  getBlogCategories(),
]);

const totalPages = Math.ceil(total / PAGE_SIZE);

// Build paginated page numbers with ellipsis gaps
const pageNums: (number | "…")[] = Array.from({ length: totalPages }, (_, i) => i + 1)
  .filter(p => p === 1 || p === totalPages || Math.abs(p - page) <= 2)
  .reduce((acc: (number | "…")[], p, i, arr) => {
    if (i > 0 && p - (arr[i - 1] as number) > 1) acc.push("…");
    acc.push(p);
    return acc;
  }, []);

function filterQS(overrides: Record<string, string | number>) {
  const p: Record<string, string> = { search, category_id, display_status, order, page: String(page) };
  for (const [k, v] of Object.entries(overrides)) p[k] = String(v);
  return "?" + new URLSearchParams(
    Object.fromEntries(Object.entries(p).filter(([, v]) => v !== "" && v !== "0"))
  ).toString();
}

const colorMap: Record<string, string> = {
  green:  "bg-green-100 text-green-700",
  yellow: "bg-yellow-100 text-yellow-700",
  red:    "bg-red-100 text-red-700",
};
---

<AdminLayout title="Blog Manager">
  <div class="flex items-center justify-between mb-5">
    <a href="/admin/blog/new"
       class="bg-blue-600 text-white px-4 py-2 rounded text-sm hover:bg-blue-700">
      + New Blog
    </a>
    <div class="flex gap-2 text-sm">
      <a href="/admin/blog/categories"
         class="px-3 py-1.5 rounded text-slate-400 hover:bg-slate-800 hover:text-white">
        Categories
      </a>
      <a href="/admin/blog/settings"
         class="px-3 py-1.5 rounded text-slate-400 hover:bg-slate-800 hover:text-white">
        Settings
      </a>
    </div>
  </div>

  <!-- Filters -->
  <form method="get" class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 mb-5">
    <div class="flex flex-wrap gap-3 items-end">
      <div>
        <label class="block text-xs text-gray-500 mb-1">Search</label>
        <input type="text" name="search" value={search} maxlength="100" placeholder="Title, author, text…"
               class="border border-gray-300 rounded px-3 py-1.5 text-sm w-52 focus:outline-none focus:ring-1 focus:ring-blue-400" />
      </div>

      <div>
        <label class="block text-xs text-gray-500 mb-1">Category</label>
        <select name="category_id"
                class="border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">
          <option value="">All</option>
          {categories.map(c => (
            <option value={c.Category_ID} selected={category_id === String(c.Category_ID)}>{c.name}</option>
          ))}
        </select>
      </div>

      <div>
        <label class="block text-xs text-gray-500 mb-1">Status</label>
        <select name="display_status"
                class="border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">
          <option value="" selected={display_status === ""}>All</option>
          <option value="off"       selected={display_status === "off"}>Off</option>
          <option value="editor"    selected={display_status === "editor"}>Editor</option>
          <option value="current"   selected={display_status === "current"}>Current</option>
          <option value="scheduled" selected={display_status === "scheduled"}>Scheduled</option>
          <option value="expired"   selected={display_status === "expired"}>Expired</option>
        </select>
      </div>

      <div>
        <label class="block text-xs text-gray-500 mb-1">Order</label>
        <select name="order"
                class="border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">
          <option value=""        selected={order === ""}>Default</option>
          <option value="name"    selected={order === "name"}>Name</option>
          <option value="author"  selected={order === "author"}>Author</option>
          <option value="start"   selected={order === "start"}>Start</option>
          <option value="expire"  selected={order === "expire"}>Expire</option>
          <option value="created" selected={order === "created"}>Created</option>
        </select>
      </div>

      <div class="flex gap-2">
        <button type="submit"
                class="bg-blue-600 text-white px-4 py-1.5 rounded text-sm hover:bg-blue-700">
          Search
        </button>
        <a href="/admin/blog"
           class="px-4 py-1.5 rounded text-sm border border-gray-300 text-gray-600 hover:bg-gray-50">
          Clear
        </a>
      </div>
    </div>
  </form>

  <!-- Count + pagination top -->
  <div class="flex items-center justify-between mb-3">
    <span class="text-sm text-gray-500">{total} blog{total !== 1 ? "s" : ""}</span>
    {totalPages > 1 && (
      <div class="flex gap-1 text-sm">
        {page > 1 && (
          <a href={filterQS({ page: page - 1 })}
             class="px-2 py-1 rounded border border-gray-300 text-gray-600 hover:bg-gray-50">‹</a>
        )}
        {pageNums.map(p =>
          p === "…"
            ? <span class="px-2 py-1 text-gray-400">…</span>
            : <a href={filterQS({ page: p as number })}
                 class={`px-2 py-1 rounded border text-sm ${p === page ? "bg-blue-600 text-white border-blue-600" : "border-gray-300 text-gray-600 hover:bg-gray-50"}`}>
                {p}
              </a>
        )}
        {page < totalPages && (
          <a href={filterQS({ page: page + 1 })}
             class="px-2 py-1 rounded border border-gray-300 text-gray-600 hover:bg-gray-50">›</a>
        )}
      </div>
    )}
  </div>

  <!-- Table -->
  {rows.length === 0 ? (
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm px-6 py-10 text-center text-sm text-gray-400">
      No blogs found.
    </div>
  ) : (
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="px-4 py-2 text-left font-medium text-gray-600 text-xs">ID</th>
            <th class="px-4 py-2 text-left font-medium text-gray-600 text-xs">Title</th>
            <th class="px-4 py-2 text-left font-medium text-gray-600 text-xs">Author / Date</th>
            <th class="px-4 py-2 text-left font-medium text-gray-600 text-xs">Category</th>
            <th class="px-4 py-2 text-left font-medium text-gray-600 text-xs">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {rows.map(row => {
            const status = getBlogStatus(row);
            return (
              <tr class="hover:bg-gray-50">
                <td class="px-4 py-2 text-xs text-gray-400 font-mono">
                  <a href={`/admin/blog/${row.Blog_ID}`} class="text-blue-600 hover:underline">
                    {row.Blog_ID}
                  </a>
                </td>
                <td class="px-4 py-2 text-gray-800 max-w-xs">
                  <a href={`/admin/blog/${row.Blog_ID}`} class="hover:underline font-medium">
                    {row.Name.length > 60 ? row.Name.slice(0, 60) + "…" : row.Name}
                  </a>
                </td>
                <td class="px-4 py-2 text-gray-500 text-xs">
                  {row.Author && <div>{row.Author.length > 20 ? row.Author.slice(0, 20) + "…" : row.Author}</div>}
                  {row.Created && <div>{new Date(row.Created).toLocaleDateString()}</div>}
                </td>
                <td class="px-4 py-2 text-gray-500 text-xs">{row.category ?? "—"}</td>
                <td class="px-4 py-2">
                  <span class={`inline-block px-2 py-0.5 rounded text-xs font-medium ${colorMap[status.color] ?? ""}`}>
                    {status.label}
                  </span>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  )}
</AdminLayout>
