---
export const prerender = false;
import AdminLayout from "../../../components/layout/AdminLayout.astro";
import {
  getBlog, updateBlog, deleteBlog,
  getBlogCategories, getBlogUsers, getBlogStatus, generatePermalink,
} from "../../../lib/queries/admin-blog";

const id = parseInt(Astro.params.id ?? "0") || 0;
if (!id) return new Response(null, { status: 404 });

let error = "";

if (Astro.request.method === "POST") {
  const d = await Astro.request.formData();
  const g = (k: string) => (d.get(k) as string ?? "").trim();
  const bit = (k: string) => g(k) === "1";
  const action = g("_action");

  if (action === "delete") {
    await deleteBlog(id);
    return Astro.redirect("/admin/blog?deleted=1");
  }

  const name = g("Name");
  let permalink = g("Permalink").trim();
  if (!permalink && name) permalink = generatePermalink(name);

  try {
    await updateBlog(id, {
      User_ID:         parseInt(g("User_ID")) || 0,
      Name:            name,
      Permalink:       permalink,
      Author:          g("Author"),
      Display:         bit("Display"),
      Approved:        bit("Approved"),
      Start:           g("Start") || null,
      Expire:          g("Expire") || null,
      Highlight:       bit("Highlight"),
      Reviewable:      bit("Reviewable"),
      Sm_Image:        g("Sm_Image"),
      Lg_Image:        g("Lg_Image"),
      Short_Desc:      g("Short_Desc"),
      Long_Desc:       g("Long_Desc"),
      TitleTag:        g("TitleTag"),
      Metadescription: g("Metadescription"),
      Keywords:        g("Keywords"),
      PassParam:       g("PassParam"),
      Created:         g("Created") || null,
      category_id:     parseInt(g("category_id")) || 0,
      cloud:           g("cloud"),
    });
    return Astro.redirect(`/admin/blog/${id}?saved=1`);
  } catch (e: unknown) {
    error = e instanceof Error ? e.message : String(e);
  }
}

const saved   = Astro.url.searchParams.get("saved") === "1";
const deleted = Astro.url.searchParams.get("deleted") === "1"; // won't show (redirect)

const [rec, categories, users] = await Promise.all([
  getBlog(id),
  getBlogCategories(),
  getBlogUsers(),
]);

if (!rec) return new Response(`Blog ${id} not found.`, { status: 404, headers: { "content-type": "text/plain" } });

const status = getBlogStatus(rec);
const colorMap: Record<string, string> = {
  green:  "bg-green-100 text-green-700",
  yellow: "bg-yellow-100 text-yellow-700",
  red:    "bg-red-100 text-red-700",
};

function fmt(d: Date | null | string | undefined): string {
  if (!d) return "";
  return new Date(d).toISOString().slice(0, 10);
}
---

<AdminLayout title={`Blog #${id}`}>
  <Fragment slot="head">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/jodit@4/jodit.min.css" />
  </Fragment>
  <div class="flex items-center gap-3 mb-5">
    <a href="/admin/blog" class="text-sm text-blue-600 hover:underline">← Back to Blogs</a>
    <span class={`inline-block px-2 py-0.5 rounded text-xs font-medium ${colorMap[status.color] ?? ""}`}>
      {status.label}
    </span>
  </div>

  {saved && (
    <div class="mb-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700">Saved.</div>
  )}
  {error && (
    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{error}</div>
  )}

  <form method="post" class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-4 max-w-3xl">
    <input type="hidden" name="_action" value="update" />

    <div class="flex items-center justify-between border-b border-gray-100 pb-2 mb-2">
      <h2 class="text-sm font-semibold text-gray-700">Blog #{id}</h2>
    </div>

    <!-- Identity -->
    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">User <span class="text-red-500">*</span></label>
      <select name="User_ID" required
              class="col-span-2 w-56 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">
        {users.map(u => (
          <option value={u.User_ID} selected={rec.User_ID === u.User_ID}>{u.UserName}</option>
        ))}
      </select>
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Title <span class="text-red-500">*</span></label>
      <input type="text" name="Name" value={rec.Name} required maxlength="100"
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Permalink</label>
      <input type="text" name="Permalink" value={rec.Permalink ?? ""} maxlength="100"
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Author</label>
      <input type="text" name="Author" value={rec.Author ?? ""} maxlength="100"
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Date</label>
      <input type="date" name="Created" value={fmt(rec.Created)}
             class="w-44 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <!-- Display section -->
    <div class="grid grid-cols-3 gap-3 items-center pt-2">
      <div class="text-right text-xs font-semibold text-gray-400 uppercase tracking-wider">Display</div>
      <div class="col-span-2 border-t border-gray-100"></div>
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Category</label>
      <select name="category_id"
              class="col-span-2 w-56 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">
        <option value="0" selected={!rec.category_id}>— none —</option>
        {categories.map(c => (
          <option value={c.Category_ID} selected={rec.category_id === c.Category_ID}>{c.name}</option>
        ))}
      </select>
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <span class="text-sm text-gray-600 font-medium text-right">Display <span class="text-red-500">*</span></span>
      <div class="col-span-2 flex gap-4">
        <label class="flex items-center gap-2 text-sm"><input type="radio" name="Display" value="1" required checked={rec.Display} /> Yes</label>
        <label class="flex items-center gap-2 text-sm"><input type="radio" name="Display" value="0" checked={!rec.Display} /> No</label>
      </div>
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <span class="text-sm text-gray-600 font-medium text-right">Approved</span>
      <div class="col-span-2 flex gap-4">
        <label class="flex items-center gap-2 text-sm"><input type="radio" name="Approved" value="1" checked={rec.Approved} /> Yes</label>
        <label class="flex items-center gap-2 text-sm"><input type="radio" name="Approved" value="0" checked={!rec.Approved} /> No</label>
      </div>
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Start</label>
      <input type="date" name="Start" value={fmt(rec.Start)}
             class="w-44 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Expire</label>
      <input type="date" name="Expire" value={fmt(rec.Expire)}
             class="w-44 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <span class="text-sm text-gray-600 font-medium text-right">Highlight</span>
      <div class="col-span-2 flex gap-4">
        <label class="flex items-center gap-2 text-sm"><input type="radio" name="Highlight" value="1" checked={rec.Highlight} /> Yes</label>
        <label class="flex items-center gap-2 text-sm"><input type="radio" name="Highlight" value="0" checked={!rec.Highlight} /> No</label>
      </div>
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <span class="text-sm text-gray-600 font-medium text-right">Allow Comments</span>
      <div class="col-span-2 flex gap-4">
        <label class="flex items-center gap-2 text-sm"><input type="radio" name="Reviewable" value="1" checked={rec.Reviewable} /> Yes</label>
        <label class="flex items-center gap-2 text-sm"><input type="radio" name="Reviewable" value="0" checked={!rec.Reviewable} /> No</label>
      </div>
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Parameters</label>
      <input type="text" name="PassParam" value={rec.PassParam ?? ""} maxlength="100"
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <!-- Teaser section -->
    <div class="grid grid-cols-3 gap-3 items-center pt-2">
      <div class="text-right text-xs font-semibold text-gray-400 uppercase tracking-wider">Teaser</div>
      <div class="col-span-2 border-t border-gray-100"></div>
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Image</label>
      <div class="col-span-2 flex gap-2">
        <input type="text" name="Sm_Image" id="Sm_Image" value={rec.Sm_Image ?? ""} maxlength="100"
               class="flex-1 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
        <button type="button" data-picker="Sm_Image"
                class="shrink-0 px-3 py-1.5 text-xs font-medium border border-gray-300 rounded text-gray-600 hover:bg-gray-50">
          Browse
        </button>
      </div>
    </div>

    <div class="grid grid-cols-3 gap-3 items-start">
      <label class="text-sm text-gray-600 font-medium text-right pt-1">Text</label>
      <textarea name="Short_Desc" rows={5}
                class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm font-mono focus:outline-none focus:ring-1 focus:ring-blue-400">{rec.Short_Desc ?? ""}</textarea>
    </div>

    <!-- Post section -->
    <div class="grid grid-cols-3 gap-3 items-center pt-2">
      <div class="text-right text-xs font-semibold text-gray-400 uppercase tracking-wider">Post</div>
      <div class="col-span-2 border-t border-gray-100"></div>
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">Image</label>
      <div class="col-span-2 flex gap-2">
        <input type="text" name="Lg_Image" id="Lg_Image" value={rec.Lg_Image ?? ""} maxlength="100"
               class="flex-1 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
        <button type="button" data-picker="Lg_Image"
                class="shrink-0 px-3 py-1.5 text-xs font-medium border border-gray-300 rounded text-gray-600 hover:bg-gray-50">
          Browse
        </button>
      </div>
    </div>

    <div class="grid grid-cols-3 gap-3 items-start">
      <label class="text-sm text-gray-600 font-medium text-right pt-1">Content</label>
      <textarea name="Long_Desc" id="Long_Desc" rows={10}
                class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm font-mono focus:outline-none focus:ring-1 focus:ring-blue-400">{rec.Long_Desc ?? ""}</textarea>
    </div>

    <!-- SEO section -->
    <div class="grid grid-cols-3 gap-3 items-center pt-2">
      <div class="text-right text-xs font-semibold text-gray-400 uppercase tracking-wider">SEO</div>
      <div class="col-span-2 border-t border-gray-100"></div>
    </div>

    <div class="grid grid-cols-3 gap-3 items-center">
      <label class="text-sm text-gray-600 font-medium text-right">HTML Title</label>
      <input type="text" name="TitleTag" value={rec.TitleTag ?? ""} maxlength="255"
             class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400" />
    </div>

    <div class="grid grid-cols-3 gap-3 items-start">
      <label class="text-sm text-gray-600 font-medium text-right pt-1">Meta Description</label>
      <textarea name="Metadescription" rows={3} maxlength="255"
                class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">{rec.Metadescription ?? ""}</textarea>
    </div>

    <div class="grid grid-cols-3 gap-3 items-start">
      <label class="text-sm text-gray-600 font-medium text-right pt-1">Keywords</label>
      <textarea name="Keywords" rows={3} maxlength="255"
                class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">{rec.Keywords ?? ""}</textarea>
    </div>

    <div class="grid grid-cols-3 gap-3 items-start">
      <label class="text-sm text-gray-600 font-medium text-right pt-1">Tag Cloud</label>
      <textarea name="cloud" rows={2} maxlength="255"
                class="col-span-2 border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400">{rec.cloud ?? ""}</textarea>
    </div>

    <div class="pt-2">
      <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded text-sm hover:bg-blue-700">
        Update Blog
      </button>
    </div>
  </form>

  <!-- Jodit + image picker -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/jodit@4/jodit.min.js"></script>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      // ── Jodit on Long_Desc ────────────────────────────────────────────
      if (window.Jodit) {
        window.Jodit.make('#Long_Desc', {
          height: 500,
          buttons: [
            'bold','italic','underline','strikethrough','|',
            'ul','ol','|',
            'link','image','|',
            'table','hr','|',
            'undo','redo','|',
            'source'
          ],
          uploader: { insertImageAsBase64URI: false },
          allowResizeX: false,
        });
      }

      // ── Image picker popups ───────────────────────────────────────────
      window.setImageField = function (fieldname, url) {
        var el = document.getElementById(fieldname);
        if (el) el.value = url;
      };

      document.querySelectorAll('[data-picker]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var field = btn.getAttribute('data-picker');
          window.open(
            '/admin/media-picker?field=' + encodeURIComponent(field),
            'imgpicker',
            'width=900,height=650,toolbar=0,location=0,status=0,menubar=0,scrollbars=1,resizable=1'
          );
        });
      });
    });
  </script>

  <!-- Delete -->
  <div class="mt-5 max-w-3xl">
    <form method="post"
          onsubmit={`return confirm('Delete Blog #${id} and all related data?')`}>
      <input type="hidden" name="_action" value="delete" />
      <button type="submit" class="px-4 py-2 rounded text-sm border border-red-300 text-red-600 hover:bg-red-50">
        Delete Blog
      </button>
    </form>
  </div>
</AdminLayout>
