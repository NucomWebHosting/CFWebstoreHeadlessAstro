---
// Handles ALL permalink-based URLs — both categories and CMS pages.
// Route priority: more-specific routes (index, category/[id], product/[id], api/*)
// take priority, so this only fires for unmatched paths.
//
// Examples:
//   /Shop-by-Boat/Catalina-22/Hull-Deck/Cockpit/Teak-Plastic/  → category
//   /returns                                                     → CMS page
//   /about-us                                                    → CMS page

export const prerender = false;
import BaseLayout from "../components/layout/BaseLayout.astro";
import RichText from "../components/ui/RichText";
import ProductGrid from "../components/ui/ProductGrid";
import CategoryCard from "../components/ui/CategoryCard";
import Breadcrumb from "../components/ui/Breadcrumb";
import { getCategoryByPermalink, getSubcategories } from "../lib/queries/categories";
import { getProductsByCategory } from "../lib/queries/products";
import { getPageByPermalink, getPageByUrl } from "../lib/queries/pages";
import { getSettings } from "../lib/queries/settings";
import type { ProductListOptions } from "../lib/queries/products";

const { slug } = Astro.params;
if (!slug) return new Response(null, { status: 404 });

const sort   = Astro.url.searchParams.get("sort") as ProductListOptions["sort"] ?? undefined;
const search = Astro.url.searchParams.get("q") ?? undefined;
const saleOnly = Astro.url.searchParams.get("sale") === "1";

// Run settings + category lookup in parallel
const [settings, category] = await Promise.all([
  getSettings(),
  getCategoryByPermalink(slug),
]);

// ── Category path ─────────────────────────────────────────────────────────────
let subcategories: Awaited<ReturnType<typeof getSubcategories>> = [];
let products: Awaited<ReturnType<typeof getProductsByCategory>> = [];
let breadcrumbItems: { label: string; href?: string }[] = [];

if (category) {
  [subcategories, products] = await Promise.all([
    getSubcategories(category.Category_ID),
    getProductsByCategory(category.Category_ID, { sort, search, saleOnly }),
  ]);

  breadcrumbItems = [{ label: "Home", href: "/" }];
  if (category.ParentNames && category.ParentIDs) {
    const names = category.ParentNames.split(",");
    const ids   = category.ParentIDs.split(",");
    names.forEach((name, i) => {
      if (name.trim()) {
        breadcrumbItems.push({
          label: name.trim(),
          href: `/category/${ids[i]?.trim()}`,
        });
      }
    });
  }
  breadcrumbItems.push({ label: category.Name });
}

// ── CMS page path (only if no category matched) ───────────────────────────────
const pageData = category
  ? null
  : await getPageByPermalink(slug).then((p) => p ?? getPageByUrl(slug));

if (!category && !pageData) return new Response(null, { status: 404 });

// Resolve title/description for BaseLayout
const title       = category ? category.Name : (pageData!.Page_Title ?? pageData!.Page_Name);
const description = category ? (category.Metadescription ?? "") : (pageData!.Metadescription ?? "");
---

<BaseLayout title={title} description={description} settings={settings}>
  {category ? (
    <!-- ── Category layout ── -->
    <div class="container mx-auto px-4 py-8">
      <Breadcrumb items={breadcrumbItems} />

      <h1 class="text-3xl font-bold mt-4 mb-2">{category.Name}</h1>
      {category.Short_Desc && <p class="text-gray-600 mb-6">{category.Short_Desc}</p>}

      {subcategories.length > 0 && (
        <section class="mb-10">
          <h2 class="text-lg font-semibold mb-4 text-gray-700">Browse subcategories</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
            {subcategories.map((sub) => <CategoryCard category={sub} />)}
          </div>
        </section>
      )}

      <div class="flex flex-wrap gap-3 mb-6 items-center justify-between">
        <form method="get" class="flex gap-2">
          <input
            type="text" name="q" value={search ?? ""}
            placeholder="Search products..."
            class="border border-gray-300 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
          />
          <button type="submit" class="bg-blue-600 text-white px-4 py-1.5 rounded-lg text-sm hover:bg-blue-700">
            Search
          </button>
        </form>
        <select
          onchange="window.location.search = '?sort=' + this.value"
          class="border border-gray-300 rounded-lg px-3 py-1.5 text-sm focus:outline-none"
        >
          <option value="" selected={!sort}>Sort: Default</option>
          <option value="price_asc"  selected={sort === "price_asc"}>Price: Low to High</option>
          <option value="price_desc" selected={sort === "price_desc"}>Price: High to Low</option>
          <option value="name_asc"   selected={sort === "name_asc"}>Name A–Z</option>
          <option value="newest"     selected={sort === "newest"}>Newest</option>
          <option value="popular"    selected={sort === "popular"}>Most Popular</option>
        </select>
      </div>

      <p class="text-sm text-gray-500 mb-4">
        {products.length} product{products.length !== 1 ? "s" : ""}
      </p>
      <ProductGrid products={products} />

      {category.Long_Desc && (
        <div class="mt-12 border-t border-gray-200 pt-8">
          <RichText html={category.Long_Desc} />
        </div>
      )}
    </div>
  ) : (
    <!-- ── CMS page layout ── -->
    <div class="container mx-auto px-4 py-10">
      {pageData!.Sm_Image && (
        <img
          src={pageData!.Sm_Image}
          alt={pageData!.Page_Name}
          class="w-full max-h-96 object-cover rounded-xl mb-8"
        />
      )}
      <h1 class="text-4xl font-bold mb-6">{pageData!.Page_Title ?? pageData!.Page_Name}</h1>
      {pageData!.PageText && <RichText html={pageData!.PageText} />}
    </div>
  )}
</BaseLayout>
