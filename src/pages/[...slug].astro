---
export const prerender = false;
import { parseJsonColumn } from "../lib/db";
import BaseLayout from "../components/layout/BaseLayout.astro";
import RichText from "../components/ui/RichText";
import GridView from "../components/ui/GridView.astro";
import ProductFilterGrid from "../components/ui/ProductFilterGrid";
import ProductCard from "../components/ui/ProductCard";
import ProductGallery from "../components/ui/ProductGallery";
import CategoryCard from "../components/ui/CategoryCard";
import CategoryHeader from "../components/ui/CategoryHeader";
import Breadcrumb from "../components/ui/Breadcrumb";
import ContactUsPage from "../components/pages/ContactUsPage.astro";
import { getCategoryBySlug, getSubcategories, getCategoryContent, getCategoryAncestors } from "../lib/queries/categories";
import {
  getProductBySlug,
  getProductImages,
  getProductContent,
  getProductsByCategory,
  getRelatedProducts,
} from "../lib/queries/products";
import { getPageBySlug } from "../lib/queries/pages";
import { getEntityBlocksPublic } from "../lib/queries/content-blocks";
import BlockRenderer from "../components/blocks/BlockRenderer";
import ProductInfoPanel from "../components/product/ProductInfoPanel";
import CartDrawer from "../components/cart/CartDrawer";
import { getSettings } from "../lib/queries/settings";
import { getStore } from "../lib/queries/settings";
import { resolveImg } from "../lib/types";
import type { ProductListOptions } from "../lib/queries/products";

const { slug } = Astro.params;
if (!slug) return new Response(null, { status: 404 });

const sort     = Astro.url.searchParams.get("sort") as ProductListOptions["sort"] ?? undefined;
const search   = Astro.url.searchParams.get("q") ?? undefined;
const saleOnly = Astro.url.searchParams.get("sale") === "1";

// Run all three primary lookups in parallel — we'll use whichever returns a result
const [settings, store, category, product] = await Promise.all([
  getSettings(),
  getStore(),
  getCategoryBySlug(slug),
  getProductBySlug(slug),
]);

// ── Category path ─────────────────────────────────────────────────────────────
let subcategories: Awaited<ReturnType<typeof getSubcategories>> = [];
let categoryProducts: Awaited<ReturnType<typeof getProductsByCategory>> = [];
let catContent: Awaited<ReturnType<typeof getCategoryContent>> = null;
let breadcrumbItems: { label: string; href?: string }[] = [];

if (category) {
  [subcategories, categoryProducts, catContent] = await Promise.all([
    getSubcategories(category.category_id),
    getProductsByCategory(category.category_id, { sort, search, saleOnly }),
    getCategoryContent(category.category_id),
  ]);

  // Build breadcrumb by walking parent chain
  breadcrumbItems = [{ label: "Home", href: "/" }];
  const ancestors = await getCategoryAncestors(category.category_id);
  for (const a of ancestors) {
    breadcrumbItems.push({ label: a.name, href: `/category/${a.category_id}` });
  }
  breadcrumbItems.push({ label: category.name });
}

// Parse category display_config for grid/card/filter settings
const catDcRaw = catContent?.display_config;
const catDc = catDcRaw ? (typeof catDcRaw === "string" ? JSON.parse(catDcRaw) : catDcRaw) : {};
const cardStyle     = catDc.card_style ?? "default";
const displayFilter = Number(catDc.filter_display ?? 0);
const pcolumns      = catDc.pcolumns ? Number(catDc.pcolumns) : undefined;

// ── Product path ──────────────────────────────────────────────────────────────
let productImages: Awaited<ReturnType<typeof getProductImages>> = [];
let relatedProducts: Awaited<ReturnType<typeof getRelatedProducts>> = [];
let prodContent: Awaited<ReturnType<typeof getProductContent>> = null;

if (!category && product) {
  [productImages, relatedProducts, prodContent] = await Promise.all([
    getProductImages(product.product_id),
    getRelatedProducts(product.product_id),
    getProductContent(product.product_id),
  ]);
}

// ── CMS page path ─────────────────────────────────────────────────────────────
const pageData = (!category && !product)
  ? await getPageBySlug(slug)
  : null;

if (!category && !product && !pageData) return new Response(null, { status: 404 });

// ── Fetch blocks for the matched entity ──────────────────────────────────────
const entityBlocks = category
  ? await getEntityBlocksPublic("category", category.category_id)
  : product
  ? await getEntityBlocksPublic("product", product.product_id)
  : pageData
  ? await getEntityBlocksPublic("page", pageData.page_id)
  : [];

// ── Meta ──────────────────────────────────────────────────────────────────────
const title = category
  ? (catContent?.titletag ?? category.name)
  : product
  ? (prodContent?.titletag ?? product.name)
  : (pageData!.titletag ?? pageData!.title ?? pageData!.name);

const description = category
  ? (catContent?.metadescription ?? "")
  : product
  ? (prodContent?.metadescription ?? "")
  : (pageData!.metadescription ?? "");

const canonical = category?.slug
  ? `/${category.slug}`
  : product?.slug
  ? `/${product.slug}`
  : undefined;

// ── Product Schema.org ────────────────────────────────────────────────────────
const firstImg = productImages[0];
const schemaImg = resolveImg(firstImg?.lg_image ?? firstImg?.md_image ?? firstImg?.sm_image);

const price = product ? Number(product.price) : 0;
const productSchema = product
  ? JSON.stringify({
      "@context": "https://schema.org/",
      "@type": "Product",
      name: product.name,
      ...(schemaImg ? { image: schemaImg } : {}),
      ...(prodContent?.long_desc
        ? { description: prodContent.long_desc.replace(/<[^>]*>/g, " ").trim() }
        : {}),
      ...(price > 0
        ? {
            offers: {
              "@type": "AggregateOffer",
              url: canonical ?? "",
              lowPrice: price,
              priceCurrency: "USD",
            },
          }
        : {}),
    })
  : null;

// Parse product_data JSON from content for price_retail and sale/hot flags
let productData: Record<string, unknown> = parseJsonColumn(prodContent?.product_data, {});
const priceRetail = productData.price_retail ? Number(productData.price_retail) : null;
const isSale = !!productData.sale;
const isHot = !!productData.hot;
const onSale = isSale && priceRetail && priceRetail > Number(product?.price);
---

<BaseLayout title={title} description={description} settings={settings} canonical={canonical}>
  {productSchema && (
    <Fragment slot="head">
      <script type="application/ld+json" is:inline set:html={productSchema} />
    </Fragment>
  )}

  {/* ── Category page ── */}
  {category && (
    <div class="container mx-auto px-4 py-8">
      <Breadcrumb items={breadcrumbItems} />

      <div class="mt-4">
        <CategoryHeader category={category} />
      </div>

      {subcategories.length > 0 && (
        <section class="mb-10">
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
            {subcategories.map((sub) => (
              <CategoryCard category={sub} />
            ))}
          </div>
        </section>
      )}

      {categoryProducts.length > 0 && displayFilter > 0 ? (
        <section class="mb-10">
          <ProductFilterGrid
            products={categoryProducts}
            cardStyle={cardStyle}
            displayFilter={displayFilter}
            pcolumns={pcolumns}
            client:load
          />
        </section>
      ) : categoryProducts.length > 0 ? (
        <section class="mb-10">
          <GridView products={categoryProducts} cardStyle={cardStyle} />
        </section>
      ) : null}

      {categoryProducts.length === 0 && subcategories.length === 0 && (
        <p class="text-gray-400 py-12 text-center">No products found in this category.</p>
      )}

      {entityBlocks.length > 0 && (
        <div class="mt-8 space-y-8">
          {entityBlocks.map((block) => (
            <BlockRenderer client:load block={block} />
          ))}
        </div>
      )}
    </div>
  )}

  {/* ── Product page ── */}
  {!category && product && (
    <div class="container mx-auto px-4 py-8 max-w-7xl">
      <Breadcrumb items={[{ label: "Home", href: "/" }, { label: product.name }]} />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mt-6">
        <div>
          <ProductGallery
            images={productImages}
            productName={product.name}
            client:load
          />
        </div>

        <div>
          <h1 class="text-3xl font-bold text-gray-900 mb-2 leading-tight">{product.name}</h1>

          <ProductInfoPanel
            productId={product.product_id}
            price={Number(product.price)}
            priceRetail={priceRetail}
            isSale={isSale}
            isHot={isHot}
            onSale={!!onSale}
            shortDesc={prodContent?.short_desc ?? null}
            client:load
          />
        </div>
      </div>

      {prodContent?.long_desc && (
        <div class="mt-12 border-t border-gray-200 pt-8">
          <h2 class="text-xl font-semibold mb-4 text-gray-900">Product Details</h2>
          <div class="prose max-w-none text-gray-700">
            <RichText html={prodContent.long_desc} />
          </div>
        </div>
      )}

      {entityBlocks.length > 0 && (
        <div class="mt-12 space-y-8">
          {entityBlocks.map((block) => (
            <BlockRenderer client:load block={block} />
          ))}
        </div>
      )}

      {relatedProducts.length > 0 && (
        <div class="mt-16 border-t border-gray-200 pt-10">
          <h2 class="text-xl font-semibold mb-6 text-gray-900">You May Also Like</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
            {relatedProducts.map((p) => (
              <ProductCard product={p} />
            ))}
          </div>
        </div>
      )}
    </div>
  )}

  {/* ── CMS page ── */}
  {!category && !product && pageData && (
    <div class="container mx-auto px-4 py-10">
      {pageData.sm_image && (
        <img
          src={resolveImg(pageData.sm_image)}
          alt={pageData.name}
          class="w-full max-h-96 object-cover rounded-xl mb-8"
        />
      )}
      <h1 class="text-4xl font-bold mb-8">{pageData.title ?? pageData.name}</h1>
      {pageData.custom_include === "contact-us" ? (
        <ContactUsPage store={store} />
      ) : entityBlocks.length > 0 ? (
        <div class="space-y-8">
          {entityBlocks.map((block) => (
            <BlockRenderer client:load block={block} />
          ))}
        </div>
      ) : (
        pageData.long_desc && <RichText html={pageData.long_desc} />
      )}
    </div>
  )}

  {/* Slide-out cart drawer (product pages) */}
  {!category && product && (
    <CartDrawer client:load />
  )}
</BaseLayout>
