---
export const prerender = false;
import BaseLayout from "../../components/layout/BaseLayout.astro";
import RichText from "../../components/ui/RichText";
import Breadcrumb from "../../components/ui/Breadcrumb";
import { getProductById, getProductImages } from "../../lib/queries/products";
import { getSettings } from "../../lib/queries/settings";
import { getImageBaseUrl } from "../../lib/types";

const { id } = Astro.params;
const productId = Number(id);

if (isNaN(productId)) {
  return new Response(null, { status: 404 });
}

const [product, images, settings] = await Promise.all([
  getProductById(productId),
  getProductImages(productId),
  getSettings(),
]);

if (!product) {
  return new Response(null, { status: 404 });
}

const imageBaseUrl = getImageBaseUrl(settings);

function resolveImg(filename: string | null | undefined): string | null {
  if (!filename) return null;
  if (filename.startsWith("http")) return filename;
  return `${imageBaseUrl.replace(/\/$/, "")}/${filename}`;
}

const primaryImage = images[0];
const additionalImages = images.slice(1);

const bullets = [
  product.Bullet_point1,
  product.Bullet_point2,
  product.Bullet_point3,
  product.Bullet_point4,
  product.Bullet_point5,
].filter(Boolean) as string[];

const onSale = product.Sale && product.Retail_Price && product.Retail_Price > product.Base_Price;
---

<BaseLayout
  title={product.Name}
  description={product.Metadescription ?? ""}
  settings={settings}
>
  <div class="container mx-auto px-4 py-8">
    <Breadcrumb
      items={[
        { label: "Home", href: "/" },
        { label: product.Name },
      ]}
    />

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mt-6">
      <!-- Images -->
      <div>
        <div class="aspect-square bg-gray-100 rounded-xl overflow-hidden mb-3">
          {resolveImg(primaryImage?.Lg_image ?? primaryImage?.Md_image) ? (
            <img
              src={resolveImg(primaryImage.Lg_image ?? primaryImage.Md_image)!}
              alt={product.Name}
              class="w-full h-full object-contain"
            />
          ) : (
            <div class="w-full h-full flex items-center justify-center text-gray-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-24 h-24" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
          )}
        </div>

        {additionalImages.length > 0 && (
          <div class="grid grid-cols-4 gap-2">
            {additionalImages.map((img) => (
              <div class="aspect-square bg-gray-100 rounded-lg overflow-hidden">
                <img
                  src={resolveImg(img.Sm_image ?? img.Th_image) ?? ""}
                  alt={product.Name}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- Details -->
      <div>
        <h1 class="text-3xl font-bold text-gray-900 mb-2">{product.Name}</h1>

        {product.SKU && <p class="text-sm text-gray-400 mb-4">SKU: {product.SKU}</p>}

        <!-- Price -->
        <div class="flex items-baseline gap-3 mb-5">
          <span class="text-3xl font-bold text-gray-900">${product.Base_Price.toFixed(2)}</span>
          {onSale && (
            <span class="text-lg text-gray-400 line-through">${product.Retail_Price!.toFixed(2)}</span>
          )}
          {product.Sale && (
            <span class="text-sm bg-red-100 text-red-700 px-2 py-0.5 rounded font-medium">Sale</span>
          )}
        </div>

        <!-- Stock -->
        {product.NumInStock > 0 ? (
          <p class="text-sm text-green-600 font-medium mb-4">In Stock</p>
        ) : (
          <p class="text-sm text-red-500 font-medium mb-4">Out of Stock</p>
        )}

        <!-- Bullet points -->
        {bullets.length > 0 && (
          <ul class="space-y-1.5 mb-6">
            {bullets.map((b) => (
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="text-blue-500 mt-0.5">&#10003;</span>
                {b}
              </li>
            ))}
          </ul>
        )}

        <!-- Short description -->
        {product.Short_Desc && (
          <div class="text-sm text-gray-600 mb-6 border-t border-gray-100 pt-4">
            <RichText html={product.Short_Desc} />
          </div>
        )}
      </div>
    </div>

    <!-- Long description -->
    {product.Long_Desc && (
      <div class="mt-12 border-t border-gray-200 pt-8">
        <h2 class="text-xl font-semibold mb-4">Product Details</h2>
        <RichText html={product.Long_Desc} />
      </div>
    )}
  </div>
</BaseLayout>
