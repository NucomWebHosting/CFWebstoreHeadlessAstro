---
export const prerender = false;
import BaseLayout from "../../components/layout/BaseLayout.astro";
import GridView from "../../components/ui/GridView.astro";
import ProductFilterGrid from "../../components/ui/ProductFilterGrid";
import CategoryCard from "../../components/ui/CategoryCard";
import CategoryHeader from "../../components/ui/CategoryHeader";
import Breadcrumb from "../../components/ui/Breadcrumb";
import { getCategoryById, getSubcategories, getCategoryContent, getCategoryAncestors } from "../../lib/queries/categories";
import { getProductsByCategory } from "../../lib/queries/products";
import { getSettings } from "../../lib/queries/settings";

import type { ProductListOptions } from "../../lib/queries/products";

const { id } = Astro.params;
const categoryId = Number(id);

if (isNaN(categoryId)) {
  return new Response(null, { status: 404 });
}

const sort = Astro.url.searchParams.get("sort") as ProductListOptions["sort"] ?? undefined;
const search = Astro.url.searchParams.get("q") ?? undefined;
const saleOnly = Astro.url.searchParams.get("sale") === "1";

const [category, subcategories, products, settings, catContent] = await Promise.all([
  getCategoryById(categoryId),
  getSubcategories(categoryId),
  getProductsByCategory(categoryId, { sort, search, saleOnly }),
  getSettings(),
  getCategoryContent(categoryId),
]);

if (!category) {
  return new Response(null, { status: 404 });
}

// Build breadcrumb by walking parent chain
const breadcrumbItems: { label: string; href?: string }[] = [{ label: "Home", href: "/" }];
const ancestors = await getCategoryAncestors(category.category_id);
for (const a of ancestors) {
  breadcrumbItems.push({ label: a.name, href: `/category/${a.category_id}` });
}
breadcrumbItems.push({ label: category.name });

// Parse display_config for grid/card/filter settings
const dcRaw = catContent?.display_config;
const dc = dcRaw ? (typeof dcRaw === "string" ? JSON.parse(dcRaw) : dcRaw) : {};
const cardStyle     = dc.card_style ?? "default";
const displayFilter = Number(dc.filter_display ?? 0);
const pcolumns      = dc.pcolumns ? Number(dc.pcolumns) : undefined;
---

<BaseLayout
  title={catContent?.titletag ?? category.name}
  description={catContent?.metadescription ?? ""}
  settings={settings}
>
  <div class="container mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <div class="mt-4">
      <CategoryHeader category={category} />
    </div>

    <!-- Subcategories -->
    {subcategories.length > 0 && (
      <section class="mb-10">
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
          {subcategories.map((sub) => (
            <CategoryCard category={sub} />
          ))}
        </div>
      </section>
    )}

    <!-- Products -->
    {products.length > 0 && displayFilter > 0 ? (
      <ProductFilterGrid
        products={products}
        cardStyle={cardStyle}
        displayFilter={displayFilter}
        pcolumns={pcolumns}
        client:load
      />
    ) : products.length > 0 ? (
      <GridView products={products} cardStyle={cardStyle} />
    ) : null}

    {products.length === 0 && subcategories.length === 0 && (
      <p class="text-gray-400 py-12 text-center">No products found in this category.</p>
    )}
  </div>
</BaseLayout>
