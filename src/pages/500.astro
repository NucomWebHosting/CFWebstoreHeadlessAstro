---
export const prerender = false;
interface Props {
  error: unknown;
}
const { error } = Astro.props;
const message = error instanceof Error ? error.message : String(error);
const stack = error instanceof Error ? error.stack : undefined;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>500 — Server Error</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body { margin: 0; background: #0f172a; color: #e2e8f0; font-family: ui-monospace, monospace; padding: 2rem; }
    h1 { color: #f87171; font-size: 1.5rem; margin: 0 0 0.5rem; }
    .badge { display: inline-block; background: #ef4444; color: white; font-size: 0.75rem; font-weight: 700; padding: 0.15rem 0.5rem; border-radius: 0.25rem; margin-bottom: 1.25rem; letter-spacing: 0.05em; }
    .message { background: #1e293b; border: 1px solid #334155; border-radius: 0.5rem; padding: 1rem 1.25rem; font-size: 0.95rem; color: #fca5a5; margin-bottom: 1.5rem; word-break: break-word; }
    .stack { background: #1e293b; border: 1px solid #334155; border-radius: 0.5rem; padding: 1rem 1.25rem; font-size: 0.8rem; color: #94a3b8; white-space: pre-wrap; overflow-x: auto; line-height: 1.6; }
    .stack-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: #64748b; margin-bottom: 0.5rem; }
    a { color: #60a5fa; }
  </style>
</head>
<body>
  <div class="badge">500</div>
  <h1>Internal Server Error</h1>
  <div class="message">{message}</div>
  {stack && (
    <>
      <div class="stack-label">Stack trace</div>
      <div class="stack">{stack}</div>
    </>
  )}
  <p style="margin-top:1.5rem;font-size:0.8rem;color:#475569">
    <a href="/admin">← Back to dashboard</a>
  </p>
</body>
</html>
