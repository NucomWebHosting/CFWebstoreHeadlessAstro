---
interface Props {
  title: string;
}
const { title } = Astro.props;
const user = await Astro.session?.get("user");
const path = Astro.url.pathname;

const nav = [
  { href: "/admin",            label: "Dashboard"   },
  { href: "/admin/products",   label: "Products"    },
  { href: "/admin/categories", label: "Categories"  },
  { href: "/admin/orders",     label: "Orders"      },
  { href: "/admin/users",      label: "Users"       },
  { href: "/admin/pages",      label: "Pages"       },
  { href: "/admin/homepage",   label: "Homepage"    },
  { href: "/admin/settings",   label: "Settings"    },
];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} — Admin</title>
  <style>
    /* Inline Tailwind reset for the admin shell */
    *, *::before, *::after { box-sizing: border-box; }
    html, body { height: 100%; margin: 0; }
  </style>
</head>
<body class="bg-gray-100 text-gray-900 font-sans">
  <div class="flex min-h-screen">

    <!-- Sidebar -->
    <aside class="w-56 shrink-0 bg-slate-900 text-slate-100 flex flex-col">
      <div class="px-5 py-4 border-b border-slate-700">
        <span class="text-sm font-bold tracking-widest uppercase text-slate-300">Admin</span>
        {user && <div class="text-xs text-slate-500 mt-0.5">{user.username}</div>}
      </div>

      <nav class="flex-1 py-3 text-sm">
        {nav.map(({ href, label }) => {
          const active = path === href || (href !== "/admin" && path.startsWith(href));
          return (
            <a
              href={href}
              class={`flex items-center px-5 py-2.5 transition-colors ${
                active
                  ? "bg-slate-700 text-white font-medium"
                  : "text-slate-400 hover:bg-slate-800 hover:text-white"
              }`}
            >
              {label}
            </a>
          );
        })}
      </nav>

      <div class="p-4 border-t border-slate-700">
        <form method="post" action="/admin/logout">
          <button type="submit" class="text-sm text-slate-500 hover:text-white transition-colors">
            Logout
          </button>
        </form>
      </div>
    </aside>

    <!-- Main content -->
    <div class="flex-1 flex flex-col overflow-hidden">
      <header class="bg-white border-b border-gray-200 px-6 py-3 flex items-center">
        <h1 class="text-lg font-semibold text-gray-800">{title}</h1>
      </header>
      <main class="flex-1 overflow-auto p-6">
        <slot />
      </main>
    </div>

  </div>
</body>
</html>
