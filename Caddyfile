# Caddyfile — frontend.nucomwebhosting.com
# Cloudflare handles SSL termination; Caddy proxies to the Astro Node.js SSR server.
# Set Cloudflare SSL/TLS mode to "Full" (not Strict) for this setup.

{
    auto_https off
}

:80 {
    # Serve uploaded images directly from disk (bypasses Node)
    handle /images/* {
        uri strip_prefix /images
        root * /var/www/frontend.nucomwebhosting.com/images
        file_server
    }

    # Proxy all other requests to the Astro SSR Node.js process
    handle {
        reverse_proxy 127.0.0.1:4321
    }

    # Compression
    encode gzip zstd

    # Security headers
    header {
        X-Content-Type-Options  "nosniff"
        X-Frame-Options         "SAMEORIGIN"
        Referrer-Policy         "strict-origin-when-cross-origin"
    }

    # Access log
    log {
        output file /var/log/caddy/frontend.nucomwebhosting.com.log
    }

    handle_errors {
        respond "{err.status_code} {err.status_text}" {err.status_code}
    }
}
